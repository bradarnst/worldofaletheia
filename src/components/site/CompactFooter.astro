---
const currentYear = new Date().getFullYear();
---

<footer class="mt-16 border-t border-base-300/80 bg-base-100/92">
  <div class="mx-auto grid max-w-7xl gap-6 px-4 py-8 text-sm text-ink-700 md:grid-cols-[1.4fr_1fr_1fr] lg:px-8">
    <div class="space-y-2">
      <p class="font-semibold text-ink-950">World of Aletheia</p>
      <p class="max-w-sm text-sm leading-6 text-ink-700">
        A grounded fantasy setting shaped by consequence, contested history, and the fragile work of renewal.
      </p>
      <p class="text-xs text-ink-600">Copyright {currentYear} World of Aletheia</p>
    </div>

    <div class="space-y-2">
      <p class="font-semibold text-ink-950">Project</p>
      <ul class="space-y-2">
        <li><a href="/about" class="hover:text-primary">About</a></li>
        <li><a href="/contribute" class="hover:text-primary">Contribute</a></li>
        <li><a href="/contact" class="hover:text-primary">Contact</a></li>
      </ul>
    </div>

    <div class="space-y-2">
      <p class="font-semibold text-ink-950">Elsewhere</p>
      <ul class="space-y-2">
        <li><a href="https://github.com/bradarnst/worldofaletheia" class="hover:text-primary">GitHub</a></li>
      </ul>
    </div>
  </div>
</footer>
