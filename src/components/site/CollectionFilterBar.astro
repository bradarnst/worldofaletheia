---
import type { DiscoveryFacetOption, DiscoveryFilters } from '~/lib/content-index-page';

interface Props {
  basePath: string;
  filters: DiscoveryFilters;
  facets: {
    types: DiscoveryFacetOption[];
    subtypes: DiscoveryFacetOption[];
    tags: DiscoveryFacetOption[];
  };
}

const { basePath, filters, facets } = Astro.props;

const activeFilters = [
  filters.type ? { label: 'Type', value: filters.type, key: 'type' } : null,
  filters.subtype ? { label: 'Subtype', value: filters.subtype, key: 'subtype' } : null,
  filters.tag ? { label: 'Tag', value: filters.tag, key: 'tag' } : null,
].filter((item): item is { label: string; value: string; key: 'type' | 'subtype' | 'tag' } => item !== null);

function buildHref(overrides: Partial<DiscoveryFilters> = {}) {
  const next: DiscoveryFilters = {
    ...filters,
    ...overrides,
  };

  const params = new URLSearchParams();

  if (next.view !== 'latest') params.set('view', next.view);
  if (next.type) params.set('type', next.type);
  if (next.subtype) params.set('subtype', next.subtype);
  if (next.tag) params.set('tag', next.tag);
  if (next.page > 1 && next.view === 'latest') params.set('page', String(next.page));

  const query = params.toString();
  return query ? `${basePath}?${query}` : basePath;
}
---

<section class="-mt-10 relative z-20 mx-auto max-w-6xl px-4 lg:px-0">
  <div class="rounded-2xl border border-base-300/80 bg-base-100/96 p-4 shadow-lg backdrop-blur-sm">
    <form method="get" class="grid gap-3 md:grid-cols-2 xl:grid-cols-[minmax(11rem,1fr)_minmax(11rem,1fr)_auto]">
      <input type="hidden" name="view" value={filters.view} />

      {facets.types.length > 0 && (
        <label class="space-y-1">
          <span class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">Type</span>
          <select name="type" class="w-full rounded-xl border border-base-300/80 bg-base-100 px-3 py-2.5 text-sm text-ink-900 focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
            <option value="">All types</option>
            {facets.types.map((facet) => (
              <option value={facet.value} selected={filters.type === facet.value}>{facet.label} ({facet.count})</option>
            ))}
          </select>
        </label>
      )}

      <label class="space-y-1">
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">Tag</span>
        <select name="tag" class="w-full rounded-xl border border-base-300/80 bg-base-100 px-3 py-2.5 text-sm text-ink-900 focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
          <option value="">All tags</option>
          {facets.tags.map((facet) => (
            <option value={facet.value} selected={filters.tag === facet.value}>{facet.label} ({facet.count})</option>
          ))}
        </select>
      </label>

      <div class="flex items-end gap-2">
        <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-primary-content transition hover:bg-primary/90">
          Apply
        </button>
        <a href={basePath} class="inline-flex min-h-11 items-center justify-center rounded-xl border border-base-300/80 px-4 py-2 text-sm font-medium text-ink-700 transition hover:border-primary/35 hover:text-ink-950">
          Reset
        </a>
      </div>
    </form>

    {activeFilters.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {activeFilters.map((filter) => (
          <a href={buildHref({ [filter.key]: '', page: 1 } as Partial<DiscoveryFilters>)} class="inline-flex items-center rounded-full border border-base-300/70 bg-base-200/70 px-3 py-1 text-xs font-medium text-ink-700">
            {filter.label}: {filter.value}
          </a>
        ))}
      </div>
    )}
  </div>
</section>
