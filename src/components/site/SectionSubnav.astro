---
import SiteGlyph from '@components/site/SiteGlyph.astro';

interface LinkItem {
  href: string;
  label: string;
  icon?: string;
}

interface Props {
  links: LinkItem[];
  currentPath?: string;
}

const { links, currentPath = Astro.url.pathname } = Astro.props;

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<nav class="border-b border-base-300/80 bg-base-100/90 backdrop-blur-sm" aria-label="Section navigation">
  <div class="mx-auto flex max-w-7xl flex-wrap gap-2 px-4 py-3 lg:px-8">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'inline-flex items-center gap-2 rounded-full border px-3 py-2 text-sm font-medium transition-colors',
          isActive(link.href)
            ? 'border-primary/45 bg-primary/12 text-ink-950'
            : 'border-base-300/70 bg-base-100/80 text-ink-700 hover:border-primary/35 hover:text-ink-950',
        ]}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.icon && <SiteGlyph name={link.icon} class="h-4 w-4" />}
        <span>{link.label}</span>
      </a>
    ))}
  </div>
</nav>
