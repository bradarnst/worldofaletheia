---
import type { ImageMetadata } from 'astro';
import SiteGlyph from '@components/site/SiteGlyph.astro';

interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata;
  icon?: string;
  eyebrow?: string;
}

const { title, description, image, icon, eyebrow = 'Collection' } = Astro.props;
const backgroundStyle = image ? `--collection-bg-image: url('${image.src}')` : undefined;
---

<section class="collection-hero-shell relative overflow-hidden border-b border-base-300/70" style={backgroundStyle}>
  <div class="collection-hero-shell__backdrop absolute inset-0"></div>
  <div class="collection-hero-shell__tint absolute inset-0"></div>
  <div class="collection-hero-shell__content mx-auto max-w-7xl px-4 pb-16 pt-20 lg:px-8 lg:pb-20 lg:pt-24">
    <div class="max-w-3xl space-y-5">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-paper-100/90">{eyebrow}</p>
      <div class="flex items-start gap-4">
        {icon && (
          <span class="mt-1 flex h-12 w-12 items-center justify-center rounded-2xl border border-white/22 bg-black/18 text-paper-50 shadow-sm backdrop-blur-sm">
            <SiteGlyph name={icon} class="h-6 w-6" />
          </span>
        )}
        <div class="space-y-3">
          <h1 class="text-4xl font-bold text-paper-50 drop-shadow-sm md:text-5xl">{title}</h1>
          {description && <p class="max-w-2xl text-base leading-7 text-paper-100/92 md:text-lg">{description}</p>}
        </div>
      </div>
    </div>
  </div>
</section>
