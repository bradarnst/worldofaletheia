---
interface Props {
  content: any;
  relatedContent: any[];
  title?: string;
}

const { content, relatedContent, title = 'Related Content' } = Astro.props;
const grouped = {
  partOf: relatedContent.filter((item) => item.relationKind === 'partOf'),
  connectedTo: relatedContent.filter((item) => item.relationKind !== 'partOf'),
};
---

<div class="mt-12">
  <h2 class="text-2xl font-bold text-base-content mb-6">{title}</h2>
  
  {relatedContent.length === 0 ? (
    <p class="opacity-80">No related content found.</p>
  ) : (
    <div class="space-y-8">
      {grouped.partOf.length > 0 && (
        <section>
          <h3 class="text-sm uppercase tracking-wide font-semibold text-ink-700 mb-3">Part of</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {grouped.partOf.map((item) => (
              <a href={item.slug} class="card content-card bg-base-100 shadow-md hover:shadow-lg transition-shadow duration-200 border border-base-300/50">
                <div class="card-body p-4">
                  <div class="content-card__header flex justify-between items-start mb-2 gap-2">
                    <h3 class="card-title text-base font-bold text-ink-950">{item.title}</h3>
                    <span class="badge badge-outline badge-sm border-base-300 bg-base-200 text-ink-700">Same hierarchy</span>
                  </div>

                  <p class="text-sm mb-2 text-ink-700">{item.excerpt}</p>

                  <div class="flex flex-wrap gap-1 mb-2">
                    {(item.tags || []).slice(0, 3).map((tag: string) => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>

                  <div class="text-xs meta-muted">
                    <span>{item.author}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {grouped.connectedTo.length > 0 && (
        <section>
          <h3 class="text-sm uppercase tracking-wide font-semibold text-ink-700 mb-3">Connected to</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {grouped.connectedTo.map((item) => (
              <a href={item.slug} class="card content-card bg-base-100 shadow-md hover:shadow-lg transition-shadow duration-200 border border-base-300/50">
                <div class="card-body p-4">
                  <div class="content-card__header flex justify-between items-start mb-2 gap-2">
                    <h3 class="card-title text-base font-bold text-ink-950">{item.title}</h3>
                    <span class="badge badge-outline badge-sm border-base-300 bg-base-200 text-ink-700">{item.relationshipReason || 'Related topic'}</span>
                  </div>

                  <p class="text-sm mb-2 text-ink-700">{item.excerpt}</p>

                  <div class="flex flex-wrap gap-1 mb-2">
                    {(item.tags || []).slice(0, 3).map((tag: string) => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>

                  <div class="text-xs meta-muted">
                    <span>{item.author}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  )}
</div>
