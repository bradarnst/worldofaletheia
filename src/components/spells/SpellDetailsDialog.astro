---
import type { PublicSpell } from '@adapters/public-spell-api';
import { formatSpellField, getVisibleSpellKeywords, hasSpellKeywords } from '@utils/spell-browser';

interface Props {
  spell: PublicSpell;
  modalId: string;
}

const { spell, modalId } = Astro.props;
const visibleKeywords = getVisibleSpellKeywords(spell.keywords);
---

<dialog id={modalId} class="m-auto w-[min(94vw,52rem)] rounded-[1.5rem] border border-base-300 bg-base-100 p-0 text-left shadow-2xl backdrop:bg-ink-950/70">
  <article class="max-h-[90vh] overflow-y-auto p-6 md:p-8">
    <div class="mb-6 flex items-start justify-between gap-4 border-b border-base-300 pb-4">
      <div>
        <h2 class="pr-8 text-2xl font-bold text-ink-950">{spell.spell_name}</h2>
        <p class="mt-2 text-lg font-semibold text-primary">{spell.full_cost}</p>
        <p class="mt-2 text-sm text-ink-700">{spell.spell_types.join(', ')}</p>
      </div>
      <button class="ui-button ui-button--ghost ui-button--sm" onclick={`document.getElementById('${modalId}')?.close()`}>Close</button>
    </div>

    {hasSpellKeywords(spell.keywords) && (
      <section class="mb-4">
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Keywords</p>
        <p class="text-base text-ink-800">{visibleKeywords.join(', ')}</p>
      </section>
    )}

    <section class="mb-4 grid gap-4 md:grid-cols-3">
      <div>
        <p class="mb-1 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Casting Roll</p>
        <p class="text-base text-ink-800">{formatSpellField(spell.casting_roll)}</p>
      </div>
      <div>
        <p class="mb-1 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Range</p>
        <p class="text-base text-ink-800">{formatSpellField(spell.range)}</p>
      </div>
      <div>
        <p class="mb-1 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Duration</p>
        <p class="text-base text-ink-800">{formatSpellField(spell.duration)}</p>
      </div>
    </section>

    <section class="mb-4">
      <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Description</p>
      <p class="text-base leading-relaxed text-ink-800">{formatSpellField(spell.description)}</p>
    </section>

    <section class="mb-6">
      <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Statistics</p>
      <p class="whitespace-pre-wrap font-mono text-sm leading-relaxed text-ink-700">{formatSpellField(spell.statistics)}</p>
    </section>

    <section class="mb-4">
      <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Archmagister's Counsel</p>
      <p class="text-base leading-relaxed text-ink-800">{formatSpellField(spell.archmagisters_counsel)}</p>
    </section>

    <section class="mb-6 grid gap-4 md:grid-cols-2">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Source Spell</p>
        <p class="text-base text-ink-800">{formatSpellField(spell.source_lineage.source_spell_name)}</p>
      </div>
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Source Spell Types</p>
        <p class="text-base text-ink-800">{spell.source_lineage.source_spell_types.join(', ')}</p>
      </div>
    </section>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <button
        type="button"
        class="ui-button ui-button--secondary"
        data-spell-list-toggle
        data-spell-id={spell.spell_id}
        data-add-label="Add to Spell List"
        data-remove-label="Remove from Spell List"
        aria-pressed="false"
      >
        Add to Spell List
      </button>

      <form method="dialog">
        <button class="ui-button ui-button--primary">Close</button>
      </form>
    </div>
  </article>
</dialog>
