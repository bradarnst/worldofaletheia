---
import type { SpellSearchFilters } from '@utils/spell-browser';
import { getSpellListPageHref } from '@utils/spell-browser';

interface Props {
  currentPage: number;
  totalPages: number;
  filters: SpellSearchFilters;
}

const { currentPage, totalPages, filters } = Astro.props;

const pageLinks = [] as number[];
const windowStart = Math.max(1, currentPage - 2);
const windowEnd = Math.min(totalPages, currentPage + 2);

for (let page = windowStart; page <= windowEnd; page += 1) {
  pageLinks.push(page);
}

const showLeadingEllipsis = pageLinks.length > 0 && pageLinks[0] > 2;
const showTrailingEllipsis = pageLinks.length > 0 && pageLinks[pageLinks.length - 1] < totalPages - 1;
---

{totalPages > 1 && (
  <nav class="mb-6 flex flex-wrap items-center gap-2" aria-label="Spell list pagination">
    <a
      href={getSpellListPageHref(Math.max(1, currentPage - 1), filters)}
      class:list={['ui-button ui-button--secondary ui-button--sm', currentPage <= 1 && 'pointer-events-none opacity-50']}
      aria-disabled={currentPage <= 1}
    >
      Previous
    </a>

    <a href={getSpellListPageHref(1, filters)} class:list={['ui-button ui-button--sm', currentPage === 1 ? 'ui-button--primary' : 'ui-button--secondary']}>
      1
    </a>

    {showLeadingEllipsis && <span class="px-1 text-sm text-ink-700">…</span>}

    {pageLinks
      .filter((page) => page !== 1 && page !== totalPages)
      .map((page) => (
        <a href={getSpellListPageHref(page, filters)} class:list={['ui-button ui-button--sm', page === currentPage ? 'ui-button--primary' : 'ui-button--secondary']}>
          {page}
        </a>
      ))}

    {showTrailingEllipsis && <span class="px-1 text-sm text-ink-700">…</span>}

    {totalPages > 1 && (
      <a href={getSpellListPageHref(totalPages, filters)} class:list={['ui-button ui-button--sm', currentPage === totalPages ? 'ui-button--primary' : 'ui-button--secondary']}>
        {totalPages}
      </a>
    )}

    <a
      href={getSpellListPageHref(Math.min(totalPages, currentPage + 1), filters)}
      class:list={['ui-button ui-button--secondary ui-button--sm', currentPage >= totalPages && 'pointer-events-none opacity-50']}
      aria-disabled={currentPage >= totalPages}
    >
      Next
    </a>
  </nav>
)}
