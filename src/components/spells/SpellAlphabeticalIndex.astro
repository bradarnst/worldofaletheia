---
import type { PublicSpell } from '@adapters/public-spell-api';
import SpellDetailsDialog from '@components/spells/SpellDetailsDialog.astro';
import SpellPaginationNav from '@components/spells/SpellPaginationNav.astro';
import { getSpellModalId } from '@utils/spell-browser';

interface Props {
  spells: PublicSpell[];
  currentPage: number;
  pageSize: number;
  totalPages: number;
  totalSpells: number;
}

const { spells, currentPage, pageSize, totalPages, totalSpells } = Astro.props;

const startSpellNumber = totalSpells === 0 ? 0 : (currentPage - 1) * pageSize + 1;
const endSpellNumber = totalSpells === 0 ? 0 : startSpellNumber + spells.length - 1;
---

<p class="mb-6 text-lg text-ink-800 drop-shadow-md">
  Showing {startSpellNumber}-{endSpellNumber} of {totalSpells} sorcerer spells in alphabetical order.
</p>

<SpellPaginationNav currentPage={currentPage} totalPages={totalPages} />

<div class="ui-surface ui-surface--glass mb-8 overflow-hidden">
  <div class="overflow-x-auto p-5">
    <table class="min-w-full border-separate border-spacing-y-2 text-left">
      <thead>
        <tr class="text-sm uppercase tracking-[0.16em] text-ink-700">
          <th class="px-3 py-2">Spell Name</th>
          <th class="px-3 py-2">Type</th>
          <th class="px-3 py-2">Cost</th>
          <th class="px-3 py-2">Details</th>
        </tr>
      </thead>
      <tbody>
        {spells.map((spell, index) => {
          const modalId = getSpellModalId(spell, index);
          return (
            <tr class="rounded-xl bg-base-100 shadow-sm">
              <td class="rounded-l-xl px-3 py-3 font-semibold text-ink-950">{spell.spell_name}</td>
              <td class="px-3 py-3 text-sm text-ink-700">{spell.spell_types.join(', ')}</td>
              <td class="px-3 py-3 text-sm text-ink-700">{spell.full_cost}</td>
              <td class="rounded-r-xl px-3 py-3 text-sm">
                <button class="ui-button ui-button--primary ui-button--sm" onclick={`document.getElementById('${modalId}')?.showModal()`}>
                  Details
                </button>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>

<SpellPaginationNav currentPage={currentPage} totalPages={totalPages} />

<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
  <a href="/systems/gurps/resources/sorcerer-spells" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
    <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">Back to Sorcerer Spells</h3>
    <p class="mt-3 text-sm leading-7 text-ink-700">Browse spells by type.</p>
    <span class="mt-auto pt-6 text-sm font-semibold text-primary">Back</span>
  </a>

  <a href="/systems/gurps" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
    <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">GURPS Home</h3>
    <p class="mt-3 text-sm leading-7 text-ink-700">Back to the GURPS campaign guide.</p>
    <span class="mt-auto pt-6 text-sm font-semibold text-primary">Home</span>
  </a>
</div>

{spells.map((spell, index) => {
  const modalId = getSpellModalId(spell, index);
  return <SpellDetailsDialog spell={spell} modalId={modalId} />;
})}

<script>
  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') {
      return;
    }

    const openModal = document.querySelector('dialog[open]') as HTMLDialogElement | null;
    openModal?.close();
  });
</script>
