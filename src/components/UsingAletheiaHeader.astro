---
import RandomHeroImage from '@components/RandomHeroImage.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;

const utilityLinks = [
  { href: '/calendar', label: 'Calendar', description: 'In-world date lookup and date math' },
  { href: '/timeline', label: 'Timeline', description: 'Chronological lore context' },
];
---

<header class="bg-base-100 pb-4">
  <RandomHeroImage
    title={title}
    text={description}
    sectionClass="container mx-auto px-4 py-8"
    heightClass="min-h-[16rem] md:min-h-[18rem]"
    overlayClass="bg-transparent"
    titleClass="mb-3 text-3xl md:text-4xl font-bold"
    textClass="text-base md:text-lg opacity-95"
    seed={title}
  />

  <div class="container mx-auto px-4">
    <div class="flex flex-col gap-4 rounded-2xl border border-base-300 bg-base-200/60 px-5 py-4 shadow-sm md:flex-row md:items-center md:justify-between">
      <div class="space-y-1">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-ink-700">Shared Utility</p>
        <p class="text-sm text-ink-800">The Aletheia calendar is part of the world first, but it also supports campaign planning, scheduling, and in-session date math.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        {utilityLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'btn btn-sm',
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'btn-primary'
                : 'btn-outline',
            ]}
            aria-current={currentPath === link.href || currentPath.startsWith(link.href + '/') ? 'page' : undefined}
            title={link.description}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>
