---
import SectionSubnav from '@components/site/SectionSubnav.astro';

const currentPathWithSearch = `${Astro.url.pathname}${Astro.url.search}`;
const loginHref = `/login?next=${encodeURIComponent(currentPathWithSearch)}`;

const links = [
  { href: '/campaigns', label: 'Campaign Index', icon: 'Campaigns' },
  { href: loginHref, label: 'Login', icon: 'Login' },
];
---

<SectionSubnav links={links} />
