---
const currentPath = Astro.url.pathname;
const currentPathWithSearch = `${Astro.url.pathname}${Astro.url.search}`;
const loginHref = `/login?next=${encodeURIComponent(currentPathWithSearch)}`;

const links = [
  { href: '/campaigns', label: 'All Campaigns' },
  { href: loginHref, label: 'Sign in' },
];
---

<div class="tabs nav-readable tabs-border bg-base-200 justify-center gap-1 p-1 h-12">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'tab tab-sm',
        currentPath === link.href || currentPath.startsWith(link.href + '/')
          ? 'tab-active'
          : ''
      ]}
    >
      {link.label}
    </a>
  ))}
</div>
