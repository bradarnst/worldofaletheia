---
import ArticleContextHeader from '@components/site/ArticleContextHeader.astro';

interface Props {
  title: string;
  author?: string;
  created?: Date;
  campaign?: string;
  visibility?: 'public' | 'campaignMembers';
  excerpt?: string;
  tags?: string[];
  type?: string;
}

const { title, author, created, campaign, visibility, excerpt, tags = [], type } = Astro.props;

const details = [
  type ? { label: 'Type', value: type.replace(/[_-]/g, ' ') } : null,
  campaign ? { label: 'Campaign', value: campaign } : null,
  visibility ? { label: 'Visibility', value: visibility } : null,
  author ? { label: 'Author', value: author } : null,
  created ? { label: 'Created', value: created.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) } : null,
].filter((item): item is { label: string; value: string } => item !== null);
---

<ArticleContextHeader title={title} summary={excerpt} details={details} tags={tags} />
