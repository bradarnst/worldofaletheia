---
interface Props {
  title: string;
  author?: string;
  created?: Date;
  campaign?: string;
  visibility?: 'public' | 'campaignMembers';
  excerpt?: string;
  tags?: string[];
}

const { title, author, created, campaign, visibility, excerpt, tags } = Astro.props;
---

<header class="bg-base-100 pb-4">
  <div class="container mx-auto px-4 py-8 text-center max-w-5xl">
    <h1 class="text-4xl font-bold text-ink-950 mb-4">{title}</h1>
    
    {excerpt && <p class="text-xl text-ink-700 mb-4">{excerpt}</p>}
    
    <div class="flex flex-wrap items-center justify-center gap-3 text-sm meta-muted mb-4">
      {author && <span>By {author}</span>}
      {author && created && <span>•</span>}
      {created && <span>{created.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
      {campaign && <span class="px-2 py-1 rounded bg-green-100 text-green-800">{campaign}</span>}
      {visibility && <span class="px-2 py-1 rounded bg-blue-100 text-blue-800">{visibility}</span>}
    </div>
    
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 justify-center">
        {tags.map((tag) => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    )}
  </div>
</header>
