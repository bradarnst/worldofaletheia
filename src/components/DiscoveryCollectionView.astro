---
import type { ImageMetadata } from 'astro';
import CollectionFilterBar from '@components/site/CollectionFilterBar.astro';
import CollectionHeroShell from '@components/site/CollectionHeroShell.astro';
import ContentCard from '@components/ContentCard.astro';
import PaginationNav from '@components/PaginationNav.astro';
import type {
  ContentCardEntry,
  DiscoveryFacetOption,
  DiscoveryFilters,
  DiscoveryGroupPreview,
} from '~/lib/content-index-page';
import type { ContentIndexPagination } from '~/lib/content-index-repo';

interface Props {
  basePath: string;
  collectionLabel: string;
  cards: ContentCardEntry[];
  groups: DiscoveryGroupPreview[];
  facets: {
    types: DiscoveryFacetOption[];
    subtypes: DiscoveryFacetOption[];
    tags: DiscoveryFacetOption[];
  };
  filters: DiscoveryFilters;
  pagination: ContentIndexPagination;
  image?: ImageMetadata;
  emptyMessage: string;
  mode: 'index' | 'local' | 'error';
  errorMessage: string | null;
}

const {
  basePath,
  collectionLabel,
  cards,
  groups,
  facets,
  filters,
  pagination,
  image,
  emptyMessage,
  mode,
  errorMessage,
} = Astro.props;

function buildHref(overrides: Partial<DiscoveryFilters> = {}) {
  const next: DiscoveryFilters = {
    ...filters,
    ...overrides,
  };
  const params = new URLSearchParams();

  if (next.view !== 'latest') params.set('view', next.view);
  if (next.type) params.set('type', next.type);
  if (next.subtype) params.set('subtype', next.subtype);
  if (next.tag) params.set('tag', next.tag);
  if (next.view === 'latest' && next.page > 1) params.set('page', String(next.page));

  const query = params.toString();
  return query.length > 0 ? `${basePath}?${query}` : basePath;
}

const preservedParams = {
  ...(filters.view !== 'latest' ? { view: filters.view } : {}),
  ...(filters.type ? { type: filters.type } : {}),
  ...(filters.subtype ? { subtype: filters.subtype } : {}),
  ...(filters.tag ? { tag: filters.tag } : {}),
};

const heroDescription = mode === 'local'
  ? `Browse ${collectionLabel.toLowerCase()} in local fallback mode while the discovery index is unavailable.`
  : `Browse ${collectionLabel.toLowerCase()} through a scan-friendly discovery surface with type and tag filtering.`;
---

<CollectionHeroShell
  title={collectionLabel}
  description={heroDescription}
  image={image}
  icon={collectionLabel}
  eyebrow="Collection"
/>

<CollectionFilterBar basePath={basePath} filters={filters} facets={facets} />

<section class="mx-auto max-w-7xl px-4 pb-14 pt-10 lg:px-8 lg:pb-20">
  <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-600">Discovery</p>
      <h2 class="mt-2 text-2xl font-bold text-ink-950 md:text-3xl">
        {filters.view === 'grouped' ? `Grouped ${collectionLabel}` : `Latest ${collectionLabel}`}
      </h2>
      {mode === 'error' && errorMessage ? (
        <p class="mt-2 max-w-2xl text-sm text-warning-700">{errorMessage}</p>
      ) : (
        <p class="mt-2 text-sm text-ink-700">
          {filters.view === 'grouped'
            ? 'Browse the collection by taxonomy buckets.'
            : 'Browse the newest visible entries in a consistent, scan-first grid.'}
        </p>
      )}
    </div>

    <div class="inline-flex rounded-full border border-base-300/80 bg-base-100 p-1 text-sm">
      <a href={buildHref({ view: 'latest', page: 1 })} class:list={['rounded-full px-4 py-2 transition-colors', filters.view === 'latest' ? 'bg-primary text-primary-content' : 'text-ink-700 hover:text-ink-950']}>
        Latest
      </a>
      <a href={buildHref({ view: 'grouped', page: 1 })} class:list={['rounded-full px-4 py-2 transition-colors', filters.view === 'grouped' ? 'bg-primary text-primary-content' : 'text-ink-700 hover:text-ink-950']}>
        Grouped
      </a>
    </div>
  </div>

  {filters.view === 'grouped' ? (
    groups.length === 0 ? (
      <p class="rounded-2xl border border-base-300/70 bg-base-100/85 px-5 py-6 text-sm text-ink-700">No grouped entries match the current filters.</p>
    ) : (
      <div class="space-y-10">
        {groups.map((group) => (
          <section class="rounded-[1.75rem] border border-base-300/70 bg-base-100/88 p-5 shadow-sm backdrop-blur-sm">
            <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="text-xl font-semibold text-ink-950">{group.label}</h3>
                <p class="mt-1 text-sm text-ink-700">{group.count} entries in this {group.field} grouping.</p>
              </div>
              <a
                href={buildHref({
                  view: 'latest',
                  page: 1,
                  type: group.field === 'type' ? group.value : filters.type,
                  subtype: group.field === 'subtype' ? group.value : filters.subtype,
                })}
                class="text-sm font-medium text-primary hover:text-secondary"
              >
                View all
              </a>
            </div>
            <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
              {group.items.map((item) => (
                <ContentCard content={item} />
              ))}
            </div>
          </section>
        ))}
      </div>
    )
  ) : cards.length === 0 ? (
    <p class="rounded-2xl border border-base-300/70 bg-base-100/85 px-5 py-6 text-sm text-ink-700">{emptyMessage}</p>
  ) : (
    <>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {cards.map((item) => (
          <ContentCard content={item} />
        ))}
      </div>

      <PaginationNav
        currentPage={pagination.page}
        totalPages={pagination.totalPages}
        basePath={basePath}
        preservedParams={preservedParams}
      />
    </>
  )}
</section>
