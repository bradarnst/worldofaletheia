---
interface Props {
  tags: string[];
  maxTags?: number;
  className?: string;
}

const { tags, maxTags = 10, className = '' } = Astro.props;
---

<div class="mt-6">
  <h3 class="text-lg font-bold text-ink-950 mb-4">Tags</h3>
  
  {tags.length === 0 ? (
    <p class="meta-muted text-sm">No tags available.</p>
  ) : (
    <div class="flex flex-wrap gap-2">
      {tags.slice(0, maxTags).map((tag) => (
        <a 
          href={`/tags/${tag.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} 
          class="tag-chip hover:bg-primary-200 transition-colors duration-200"
        >
          {tag}
        </a>
      ))}
      
      {tags.length > maxTags && (
        <span class="text-sm meta-muted">+ {tags.length - maxTags} more</span>
      )}
    </div>
  )}
</div>
