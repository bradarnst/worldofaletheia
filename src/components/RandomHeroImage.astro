---
import type { ImageMetadata } from 'astro';
import HeroImage from '@components/HeroImage.astro';

import boatInMangroves from '@images/boat-in-mangroves.png';
import desertTent from '@images/desert-tent.png';
import dwarvenMountainEntrance from '@images/dwarven-mountain-entrance.png';
import fertileLandsToCity from '@images/fertile-lands-to-city.png';
import forestRoad from '@images/forest-road.png';
// import jungleRuin from '@images/jungle-ruin.png';
import lakePort from '@images/lake-port.png';
import rideOnTheBeach from '@images/ride-on-the-beach.png';
import savannaFarmland from '@images/savanna-farmland.png';
import wheatFields from '@images/wheat-fields.png';

type HeroImageItem = {
  image: ImageMetadata;
  alt: string;
};

export interface RandomHeroImageProps {
  images?: HeroImageItem[];
  title: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
  sectionClass?: string;
  heightClass?: string;
  overlayClass?: string;
  contentClass?: string;
  titleClass?: string;
  textClass?: string;
  seed?: string | number;
}

const defaultImages: HeroImageItem[] = [
  { image: boatInMangroves, alt: 'A small boat moving through dense mangrove waterways.' },
  { image: desertTent, alt: 'A tent settlement in a broad desert under clear sky.' },
  { image: dwarvenMountainEntrance, alt: 'A carved entrance set into a rugged mountain face.' },
  { image: fertileLandsToCity, alt: 'Fertile countryside leading toward a distant city.' },
  { image: forestRoad, alt: 'A winding road cutting through dense forest.' },
  // { image: jungleRuin, alt: 'Dense jungle growth surrounding old stone structures.' },
  { image: lakePort, alt: 'A lakeside port with boats and low settlement buildings.' },
  { image: rideOnTheBeach, alt: 'Travelers riding along a wide coastline at low tide.' },
  { image: savannaFarmland, alt: 'Open savanna transitioning into cultivated farmlands.' },
  { image: wheatFields, alt: 'Golden wheat fields stretching toward distant hills.' },
];

const props = Astro.props as RandomHeroImageProps;
const sourceImages = (props.images && props.images.length > 0) ? props.images : defaultImages;

const seedValue = props.seed ?? Math.floor(Date.now() / 86400000);
const normalizedSeed = typeof seedValue === 'number'
  ? Math.abs(seedValue)
  : Array.from(seedValue).reduce((acc, char) => acc + char.charCodeAt(0), 0);

const selected = sourceImages.length > 0
  ? sourceImages[normalizedSeed % sourceImages.length]
  : { image: defaultImages[0].image, alt: '' };

const safeAlt = selected.alt?.trim() || props.title;
const darkerHeroImages = new Set<ImageMetadata>([
  boatInMangroves,
  dwarvenMountainEntrance,
  forestRoad,
  jungleRuin,
  lakePort,
]);
const mediaClass = darkerHeroImages.has(selected.image) ? 'hero-image-media--dark' : '';
---

<HeroImage
  image={selected.image}
  alt={safeAlt}
  title={props.title}
  text={props.text}
  ctaLabel={props.ctaLabel}
  ctaHref={props.ctaHref}
  sectionClass={props.sectionClass}
  heightClass={props.heightClass}
  overlayClass={props.overlayClass}
  mediaClass={mediaClass}
  contentClass={props.contentClass}
  titleClass={props.titleClass}
  textClass={props.textClass}
/>
