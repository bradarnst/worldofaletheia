---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/systems', label: 'General' },
  { href: '/systems/gurps', label: 'GURPS' },
];
---

<div class="nav-readable flex justify-center bg-base-200/70 px-4 py-2">
  <div class="ui-segmented">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'ui-segmented__item',
        currentPath === link.href || currentPath.startsWith(link.href + '/')
          ? 'ui-segmented__item--active'
          : ''
      ]}
    >
      {link.label}
    </a>
  ))}
  </div>
</div>
