---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface HeroImageProps {
  image: ImageMetadata;
  alt: string;
  title: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
  sectionClass?: string;
  heightClass?: string;
  overlayClass?: string;
  mediaClass?: string;
  contentClass?: string;
  titleClass?: string;
  textClass?: string;
}

const {
  image,
  alt,
  title,
  text,
  ctaLabel,
  ctaHref,
  sectionClass = 'w-full',
  heightClass = 'min-h-[24rem]',
  overlayClass = 'bg-transparent',
  mediaClass = '',
  contentClass = 'site-hero-content text-neutral-content text-center px-6',
  titleClass = 'mb-4 text-4xl md:text-5xl font-bold font-lora',
  textClass = 'mb-6 text-base md:text-lg opacity-95',
} = Astro.props as HeroImageProps;

const safeAlt = alt?.trim() || title;
const hasCta = Boolean(ctaLabel && ctaHref);
const hasActionsSlot = Astro.slots.has('actions');
---

<section class={sectionClass} data-hero-title={title} data-hero-overlay={overlayClass} data-hero-media-class={mediaClass}>
  <div class={`site-hero-shell ${heightClass}`}>
    <Picture
      src={image}
      alt={safeAlt}
      widths={[640, 960, 1280, 1600]}
      formats={['avif', 'webp']}
      class={`site-hero-media ${mediaClass} absolute inset-0 h-full w-full object-cover`}
    />
    <div class={`site-hero-overlay ${overlayClass} absolute inset-0 pointer-events-none`} aria-hidden="true"></div>
    <div class={contentClass}>
      <div class="max-w-3xl">
        <h1 class={`hero-image-title ${titleClass}`}>{title}</h1>
        {text && <p class={textClass}>{text}</p>}
        {hasActionsSlot ? (
          <div class="flex flex-wrap justify-center gap-3">
            <slot name="actions" />
          </div>
        ) : hasCta && (
          <div class="flex flex-wrap justify-center gap-3">
            <a href={ctaHref} class="ui-button ui-button--primary">{ctaLabel}</a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
