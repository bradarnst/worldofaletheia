---
import type { CalendarMonthLeapDayPlacement } from '~/lib/aletheia-calendar';

interface Props {
  placement: CalendarMonthLeapDayPlacement;
}

const { placement } = Astro.props;
---

<div class="col-span-6 rounded-xl border border-warning/60 bg-warning/10 px-4 py-3 shadow-sm">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="space-y-1">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700">Leap Day</p>
      <p class="text-sm text-ink-800">
        {placement.leapDay.weekday}, inserted after {placement.afterDate.monthName} {placement.afterDate.day} and before {placement.beforeDate.monthName} {placement.beforeDate.day}.
      </p>
    </div>
    <span class="badge badge-warning">Intercalary</span>
  </div>
</div>
