---
import EclipseMarkerIcon from '@components/calendar/EclipseMarkerIcon.astro';
---

<div class="flex flex-wrap items-center gap-3 text-xs text-ink-700">
  <span class="font-semibold uppercase tracking-[0.18em]">Eclipse Markers</span>
  <span class="inline-flex items-center gap-1 rounded-full border border-base-300 bg-base-100 px-2 py-1">
    <EclipseMarkerIcon kind="solar" />
    Solar eclipse occurs
  </span>
  <span class="inline-flex items-center gap-1 rounded-full border border-base-300 bg-base-100 px-2 py-1">
    <EclipseMarkerIcon kind="lunar" />
    Lunar eclipse occurs
  </span>
</div>
