---
import MoonPhaseIcon from '@components/calendar/MoonPhaseIcon.astro';
import EclipseMarkerIcon from '@components/calendar/EclipseMarkerIcon.astro';
import {
  formatAletheiaDateRange,
  type CalendarDayData,
} from '~/lib/aletheia-calendar';

interface Props {
  day: CalendarDayData;
  closeHref?: string;
  previousHref?: string;
  nextHref?: string;
}

const {
  day,
  closeHref,
  previousHref,
  nextHref,
} = Astro.props;
---

<section id="calendar-agenda" class="ui-surface p-5">
  <div class="space-y-5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <h2 class="text-xl font-semibold text-ink-950">{day.date.kind === 'month' ? `${day.date.weekday}, ${day.date.monthName} ${day.date.day}, ${day.date.year}` : `${day.date.weekday}, Leap Day, ${day.date.year}`}</h2>
        <p class="mt-1 text-sm text-ink-700">Full agenda for the selected day.</p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        {previousHref && <a href={previousHref} class="ui-button ui-button--secondary ui-button--sm">Previous day</a>}
        {nextHref && <a href={nextHref} class="ui-button ui-button--secondary ui-button--sm">Next day</a>}
        {closeHref && <a href={closeHref} class="ui-button ui-button--secondary ui-button--sm">Hide agenda</a>}
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-xl border border-base-300 bg-base-200/60 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">Weekday</p>
        <p class="mt-2 text-sm text-ink-900">{day.date.weekday}</p>
      </div>
      <div class="rounded-xl border border-base-300 bg-base-200/60 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">Moon</p>
        <div class="mt-2 flex items-center gap-2 text-sm text-ink-900">
          <MoonPhaseIcon label={day.date.moonPhaseLabel} size={16} />
          <span>{day.date.moonPhaseLabel}</span>
        </div>
      </div>
      <div class="rounded-xl border border-base-300 bg-base-200/60 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">Eclipses</p>
        {day.eclipses.length > 0 ? (
          <div class="mt-2 space-y-2">
            {day.eclipses.map((eclipse) => (
              <div class="flex items-center gap-2 text-sm text-ink-900">
                <EclipseMarkerIcon kind={eclipse.kind} size={14} />
                <span>
                  {eclipse.kind} eclipse occurs at {String(eclipse.hour).padStart(2, '0')}:{String(eclipse.minute).padStart(2, '0')}.
                </span>
              </div>
            ))}
          </div>
        ) : (
          <p class="mt-2 text-sm text-ink-900">No solar or lunar eclipse occurs on this date.</p>
        )}
      </div>
    </div>

    <div class="flex items-center justify-between gap-3">
      <div>
        <h3 class="text-xl font-semibold text-ink-950">Agenda</h3>
        <p class="text-sm text-ink-700">Full lore event detail for the selected day.</p>
      </div>
      <span class="ui-pill ui-pill--outline">{day.events.length}</span>
    </div>

    {day.events.length > 0 ? (
      <div class="space-y-3">
        {day.events.map((event) => (
          <article class="rounded-xl border border-base-300 bg-base-200/60 p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <a href={event.href} class="font-semibold text-ink-950 transition-colors hover:text-primary">{event.title}</a>
                <p class="text-sm text-ink-700">{formatAletheiaDateRange(event.startDate, event.endDate)}</p>
              </div>
              {!event.isSingleDay && <span class="ui-pill ui-pill--outline">{event.durationDays} days</span>}
            </div>
            {event.excerpt && <p class="mt-3 text-sm text-ink-800">{event.excerpt}</p>}
          </article>
        ))}
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-base-300 bg-base-200/40 p-6 text-sm text-ink-700">
        No lore events are projected onto this day yet.
      </div>
    )}
  </div>
</section>
