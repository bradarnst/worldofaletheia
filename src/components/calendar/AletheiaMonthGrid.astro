---
import MoonPhaseIcon from '@components/calendar/MoonPhaseIcon.astro';
import EclipseMarkerIcon from '@components/calendar/EclipseMarkerIcon.astro';
import type { AletheiaDate, CalendarMonthData, CalendarMonthSlot } from '~/lib/aletheia-calendar';

interface Props {
  month: CalendarMonthData;
  selectedAbsDay?: number;
  compact?: boolean;
  getDateHref?: (date: AletheiaDate) => string;
}

const {
  month,
  selectedAbsDay,
  compact = false,
  getDateHref,
} = Astro.props;

const weekdayLabels = ['Primus', 'Secundus', 'Tertius', 'Quartus', 'Quintus', 'Deorum'];
const visibleSlots: CalendarMonthSlot[] = month.slots;
const slotRows: CalendarMonthSlot[][] = [];

for (let index = 0; index < visibleSlots.length; index += 6) {
  slotRows.push(visibleSlots.slice(index, index + 6));
}
---

<div class="space-y-3">
  <div class="grid grid-cols-6 gap-2 text-center text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">
    {weekdayLabels.map((label) => (
      <div class="rounded-lg border border-base-300 bg-base-200/70 px-2 py-2">{label}</div>
    ))}
  </div>

  <div class="space-y-3">
    {slotRows.map((row) => (
      <div class:list={[
        'grid grid-cols-6 gap-2',
        compact ? 'text-xs' : 'text-sm',
      ]}>
        {row.map((slot) => {
          if (slot.kind === 'empty') {
            return <div class:list={['rounded-xl border border-dashed border-base-300/70 bg-base-200/25', compact ? 'min-h-20' : 'min-h-36']} aria-hidden="true" />;
          }

          const isSelected = selectedAbsDay === slot.date.absDay;
          const visibleEvents = compact ? [] : slot.events.slice(0, 1);
          const hiddenEventCount = compact ? slot.events.length : Math.max(slot.events.length - visibleEvents.length, 0);
          const href = getDateHref?.(slot.date);
          const Wrapper = href ? 'a' : 'div';
          const isLeapDay = slot.kind === 'leapday';

          if (isLeapDay) {
            return (
              <Wrapper
                href={href}
                class:list={[
                  'rounded-xl border border-warning/60 bg-warning/10 p-2 shadow-sm transition-colors',
                  compact ? 'min-h-20' : 'min-h-36',
                  href ? 'block hover:border-primary hover:bg-warning/15' : 'block',
                  isSelected ? 'ring-1 ring-primary/40 border-primary' : '',
                ]}
                title="Festival Leap Day"
              >
                <div class="flex items-start justify-between gap-2">
                  <div>
                    <p class:list={['font-semibold text-ink-950', compact ? 'text-sm' : 'text-base']}>
                      LD
                    </p>
                    {!compact && <p class="text-xs text-ink-700">{slot.date.weekday}</p>}
                  </div>
                  <div class="flex flex-col items-end gap-1">
                    <span class="inline-flex items-center rounded-full border border-base-300 bg-base-100 px-2 py-1 text-ink-700" title={slot.date.moonPhaseLabel}>
                      <MoonPhaseIcon label={slot.date.moonPhaseLabel} size={compact ? 14 : 16} />
                      <span class="sr-only">{slot.date.moonPhaseLabel}</span>
                    </span>
                    <span class="ui-pill ui-pill--warning">FLD</span>
                    {!compact && slot.eclipses.length > 0 && (
                      <span class="inline-flex items-center gap-1 rounded-full border border-warning/40 bg-base-100 px-2 py-1 text-warning">
                        {slot.eclipses.map((eclipse) => (
                          <span title={`${eclipse.kind} eclipse occurs`}>
                            <EclipseMarkerIcon kind={eclipse.kind} size={11} />
                            <span class="sr-only">{eclipse.kind} eclipse occurs</span>
                          </span>
                        ))}
                      </span>
                    )}
                  </div>
                </div>

                {compact && slot.eclipses.length > 0 && (
                  <div class="mt-2 flex items-center justify-center gap-1 text-warning">
                    {slot.eclipses.map((eclipse) => (
                      <span title={`${eclipse.kind} eclipse occurs`}>
                        <EclipseMarkerIcon kind={eclipse.kind} size={12} />
                        <span class="sr-only">{eclipse.kind} eclipse occurs</span>
                      </span>
                    ))}
                  </div>
                )}

                {!compact && slot.events.length > 0 && (
                  <div class="mt-3 space-y-2">
                    {slot.events.slice(0, 1).map((event) => (
                      <span class="block rounded-lg border border-base-300 bg-base-200/60 px-2 py-1 text-xs text-ink-800">
                        {event.title}
                      </span>
                    ))}
                    {slot.events.length > 1 && (
                      <p class="text-xs font-medium text-ink-700">+{slot.events.length - 1} more</p>
                    )}
                  </div>
                )}
              </Wrapper>
            );
          }

          return (
            <Wrapper
              href={href}
              class:list={[
                'rounded-xl border bg-base-100 p-2 shadow-sm transition-colors',
                compact ? 'min-h-20' : 'min-h-36',
                href ? 'block hover:border-primary hover:bg-base-100' : 'block',
                isSelected ? 'border-primary shadow-md ring-1 ring-primary/40' : 'border-base-300',
                slot.date.isFestivalDay ? 'bg-warning/10' : '',
              ]}
            >
              <div class="flex items-start justify-between gap-2">
                <div>
                  <p class:list={['font-semibold text-ink-950', compact ? 'text-sm' : 'text-base']}>
                    {slot.date.day}
                  </p>
                  {!compact && <p class="text-xs text-ink-700">{slot.date.weekday}</p>}
                </div>
                <div class="flex flex-col items-end gap-1">
                  <span class="inline-flex items-center rounded-full border border-base-300 bg-base-100 px-2 py-1 text-ink-700" title={slot.date.moonPhaseLabel}>
                    <MoonPhaseIcon label={slot.date.moonPhaseLabel} size={compact ? 14 : 16} />
                    <span class="sr-only">{slot.date.moonPhaseLabel}</span>
                  </span>
                  {slot.kind === 'day' && slot.date.isFestivalDay && (
                    <span class="ui-pill ui-pill--warning">F{slot.date.festivalDayNumber}</span>
                  )}
                  {!compact && slot.eclipses.length > 0 && (
                    <span class="inline-flex items-center gap-1 rounded-full border border-warning/40 bg-base-100 px-2 py-1 text-warning">
                      {slot.eclipses.map((eclipse) => (
                        <span title={`${eclipse.kind} eclipse occurs`}>
                          <EclipseMarkerIcon kind={eclipse.kind} size={11} />
                          <span class="sr-only">{eclipse.kind} eclipse occurs</span>
                        </span>
                      ))}
                    </span>
                  )}
                  {compact && slot.events.length > 0 && (
                    <span class="ui-pill ui-pill--primary ui-pill--count">{slot.events.length}</span>
                  )}
                </div>
              </div>

              {!compact && (
                <div class="mt-3 space-y-2">
                  {visibleEvents.map((event) => (
                    <span class="block rounded-lg border border-base-300 bg-base-200/60 px-2 py-1 text-xs text-ink-800">
                      {event.title}
                    </span>
                  ))}
                  {hiddenEventCount > 0 && (
                    <p class="text-xs font-medium text-ink-700">+{hiddenEventCount} more</p>
                  )}
                </div>
              )}
            </Wrapper>
          );
        })}
      </div>
    ))}
  </div>
</div>
