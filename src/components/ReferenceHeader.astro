---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const {
  title,
  description,
  eyebrow = 'Reference',
} = Astro.props;
---

<section class="border-b border-base-300/70 px-1 pb-5 pt-1">
  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-ink-700">{eyebrow}</p>
  <h1 class="mt-2 text-3xl font-bold text-ink-950 md:text-4xl">{title}</h1>
  {description && <p class="mt-3 max-w-3xl text-base text-ink-800 md:text-lg">{description}</p>}
</section>
