---
import { Image } from 'astro:assets';
import NavCardLink from '@components/site/NavCardLink.astro';
import SiteGlyph from '@components/site/SiteGlyph.astro';
import aletheiaLogo from '@images/aletheia-logo.png';

const themes = [
  { value: 'golden-savanna', label: 'Golden Savanna' },
  { value: 'dark-jungle', label: 'Dark Jungle' },
];

const currentPath = Astro.url.pathname;
const currentPathWithSearch = `${Astro.url.pathname}${Astro.url.search}`;
const loginHref = `/login?next=${encodeURIComponent(currentPathWithSearch)}`;

const navGroups = [
  {
    label: 'World of Aletheia',
    icon: 'Canon',
    matches: ['/aletheia-world-canon', '/lore', '/places', '/sentients', '/bestiary', '/flora', '/factions'],
    items: [
      { href: '/lore', title: 'Lore', description: 'Myths, histories, cosmology, and world truths.', icon: 'Lore' },
      { href: '/places', title: 'Places', description: 'Regions, settlements, ruins, and terrain.', icon: 'Places' },
      { href: '/sentients', title: 'Sentients', description: 'Peoples, cultures, lineages, and deities.', icon: 'Sentients' },
      { href: '/bestiary', title: 'Bestiary', description: 'Creatures, monsters, animals, and spirits.', icon: 'Bestiary' },
      { href: '/flora', title: 'Flora', description: 'Plants, fungi, herbs, and stranger growths.', icon: 'Flora' },
      { href: '/factions', title: 'Factions', description: 'Guilds, powers, institutions, and rival orders.', icon: 'Factions' },
    ],
  },
  {
    label: 'Using Aletheia',
    icon: 'Using',
    matches: ['/using-aletheia', '/systems', '/meta', '/about'],
    items: [
      { href: '/systems', title: 'Systems', description: 'Rules support, mechanics context, and play material.', icon: 'Systems' },
      { href: '/meta', title: 'Meta', description: 'Project notes, planning, and usage guidance.', icon: 'Meta' },
      { href: '/about', title: 'About', description: 'How the world is built and how the site is used.', icon: 'About' },
    ],
  },
  {
    label: 'Reference',
    icon: 'Reference',
    matches: ['/references'],
    items: [
      { href: '/references/calendar', title: 'Calendar', description: 'Months, cycles, civic time, and seasonal structure.', icon: 'Calendar' },
      { href: '/references/timeline', title: 'Timeline', description: 'Events placed into historical sequence.', icon: 'Timeline' },
      { href: '/references/maps', title: 'Maps', description: 'Geography and spatial reference surfaces.', icon: 'Maps' },
    ],
  },
  {
    label: 'Campaigns',
    icon: 'Campaigns',
    matches: ['/campaigns'],
    items: [
      { href: '/campaigns', title: 'Campaign Index', description: 'Public campaigns, records, and evolving stories.', icon: 'Campaigns' },
    ],
  },
];

function isGroupActive(matches: string[]) {
  return matches.some((prefix) => currentPath === prefix || currentPath.startsWith(`${prefix}/`));
}
---

<header class="sticky top-0 z-50 border-b border-base-300/70 bg-base-100/90 backdrop-blur-xl" style="font-family: var(--font-family-ui);">
  <div class="relative flex w-full items-center gap-3 px-4 py-2 lg:px-6 xl:px-8">
    <a href="/" class="flex min-w-0 shrink-0 items-center gap-3 text-ink-950 transition hover:text-primary lg:min-w-[15rem] xl:min-w-[16rem]">
      <Image src={aletheiaLogo} alt="World of Aletheia logo" width={48} height={32} class="h-8 w-12 shrink-0" />
      <span class="min-w-0">
        <span class="block truncate font-semibold tracking-[0.2em] text-[0.65rem] uppercase text-ink-600">World Archive</span>
        <span class="block truncate text-lg font-semibold">World of Aletheia</span>
      </span>
    </a>

    <nav class="absolute left-1/2 top-1/2 hidden min-w-0 -translate-x-1/2 -translate-y-1/2 items-center justify-center gap-1.5 lg:flex" aria-label="Primary" data-nav-root>
      {navGroups.map((group) => (
        <details class="group relative" data-nav-dropdown>
          <summary class:list={[
            'flex h-8 cursor-pointer list-none items-center gap-2 rounded-md border px-3 text-[0.82rem] font-medium transition-colors',
            isGroupActive(group.matches)
              ? 'border-primary/45 bg-primary/12 text-ink-950'
              : 'border-transparent text-ink-700 hover:border-base-300/70 hover:bg-base-100 hover:text-ink-950',
          ]} aria-expanded="false">
            <SiteGlyph name={group.icon} class="h-4 w-4" />
            <span>{group.label}</span>
          </summary>
          <div class="absolute left-1/2 top-full z-30 mt-2.5 hidden w-[32rem] max-w-[min(90vw,32rem)] -translate-x-1/2 rounded-2xl border border-base-300/80 bg-base-100/96 p-3.5 shadow-2xl group-open:block">
            <div class:list={['grid gap-3', group.items.length > 3 ? 'md:grid-cols-2' : 'grid-cols-1']}>
              {group.items.map((item) => (
                <NavCardLink href={item.href} title={item.title} description={item.description} icon={item.icon} compact />
              ))}
            </div>
          </div>
        </details>
      ))}
    </nav>

    <div class="ml-auto hidden items-center gap-2 lg:flex">
      <button type="button" class="inline-flex h-8 items-center gap-2 rounded-md border border-base-300/70 bg-base-100 px-3 text-[0.82rem] font-medium text-ink-600 transition hover:border-base-300 hover:text-ink-950" aria-label="Global search coming soon">
        <SiteGlyph name="Search" class="h-4 w-4" />
        <span>Search</span>
      </button>

      <label class="relative isolate flex h-8 w-8 overflow-hidden rounded-md border border-base-300/70 bg-base-100 text-ink-700 transition hover:border-base-300 hover:text-ink-950" aria-label="Theme selector" title="Theme">
        <span class="sr-only">Theme</span>
        <SiteGlyph name="Theme" class="h-4 w-4" />
        <select class="absolute inset-0 cursor-pointer opacity-0 js-theme-picker" aria-label="Select theme">
          {themes.map((theme) => (
            <option value={theme.value}>{theme.label}</option>
          ))}
        </select>
      </label>
      <a href={loginHref} class="inline-flex h-8 items-center rounded-md border border-base-300/70 px-3.5 text-[0.82rem] font-medium text-ink-700 transition hover:border-primary/35 hover:text-ink-950">Login</a>
      <a href="/contribute" class="inline-flex h-8 items-center rounded-md bg-primary px-3.5 text-[0.82rem] font-semibold text-primary-content transition hover:bg-primary/90">Contribute</a>
    </div>

    <details class="relative ml-auto lg:hidden" data-mobile-nav>
      <summary class="flex h-8 w-8 cursor-pointer list-none items-center justify-center rounded-md border border-base-300/70 bg-base-100 text-ink-800">
        <SiteGlyph name="Menu" class="h-4 w-4" />
      </summary>
      <div class="absolute right-0 top-full z-40 mt-2.5 w-[min(92vw,24rem)] rounded-2xl border border-base-300/80 bg-base-100/98 p-4 shadow-2xl">
        <div class="space-y-3">
          {navGroups.map((group) => (
            <details class="rounded-xl border border-base-300/70 bg-base-100/88 p-3">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold text-ink-950">
                <span class="flex items-center gap-2"><SiteGlyph name={group.icon} class="h-4 w-4" />{group.label}</span>
                <span class="text-ink-500">+</span>
              </summary>
              <div class="mt-3 space-y-3">
                {group.items.map((item) => (
                  <NavCardLink href={item.href} title={item.title} description={item.description} icon={item.icon} compact />
                ))}
              </div>
            </details>
          ))}

          <div class="grid gap-2 sm:grid-cols-2">
            <a href={loginHref} class="rounded-lg border border-base-300/70 px-4 py-3 text-sm font-medium text-ink-700">Login</a>
            <a href="/contribute" class="rounded-lg bg-primary px-4 py-3 text-sm font-semibold text-primary-content">Contribute</a>
          </div>

          <label class="flex items-center gap-3 rounded-lg border border-base-300/70 px-4 py-3 text-sm font-medium text-ink-700">
            <SiteGlyph name="Theme" class="h-4 w-4" />
            <span class="min-w-0 flex-1">Theme</span>
            <select class="min-w-0 bg-transparent js-theme-picker" aria-label="Select theme">
              {themes.map((theme) => (
                <option value={theme.value}>{theme.label}</option>
              ))}
            </select>
          </label>
        </div>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  (() => {
    const STORAGE_KEY = 'aletheia-theme';
    const DEFAULT_THEME = 'golden-savanna';
    const ALLOWED_THEMES = ['golden-savanna', 'dark-jungle'];

    const getActiveTheme = () => {
      const current = document.documentElement.getAttribute('data-theme');
      if (current && ALLOWED_THEMES.includes(current)) return current;

      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved && ALLOWED_THEMES.includes(saved)) return saved;
      } catch {
        // Ignore storage access errors
      }

      return DEFAULT_THEME;
    };

    const applyTheme = (theme) => {
      if (!ALLOWED_THEMES.includes(theme)) return;
      document.documentElement.setAttribute('data-theme', theme);
      try {
        localStorage.setItem(STORAGE_KEY, theme);
      } catch {
        // Ignore storage access errors
      }
      document.querySelectorAll('.js-theme-picker').forEach((picker) => {
        if (picker instanceof HTMLSelectElement) picker.value = theme;
      });
    };

    const initialTheme = getActiveTheme();
    document.querySelectorAll('.js-theme-picker').forEach((picker) => {
      if (picker instanceof HTMLSelectElement) {
        picker.value = initialTheme;
        if (picker.dataset.themeBound === 'true') return;
        picker.dataset.themeBound = 'true';
        picker.addEventListener('change', (event) => {
          const next = (event.currentTarget instanceof HTMLSelectElement)
            ? event.currentTarget.value
            : DEFAULT_THEME;
          applyTheme(next);
        });
      }
    });

    const navRoot = document.querySelector('[data-nav-root]');
    const mobileNav = document.querySelector('[data-mobile-nav]');
    const dropdowns = navRoot instanceof HTMLElement
      ? Array.from(navRoot.querySelectorAll('[data-nav-dropdown]')).filter((dropdown) => dropdown instanceof HTMLDetailsElement)
      : [];

    const closeDropdown = (dropdown) => {
      dropdown.open = false;
      const summary = dropdown.querySelector('summary');
      if (summary instanceof HTMLElement) summary.setAttribute('aria-expanded', 'false');
    };

    dropdowns.forEach((dropdown) => {
      const summary = dropdown.querySelector('summary');
      if (summary instanceof HTMLElement) {
        summary.setAttribute('aria-expanded', dropdown.open ? 'true' : 'false');
      }

      dropdown.addEventListener('toggle', () => {
        if (summary instanceof HTMLElement) {
          summary.setAttribute('aria-expanded', dropdown.open ? 'true' : 'false');
        }

        if (!dropdown.open) return;

        dropdowns.forEach((otherDropdown) => {
          if (otherDropdown !== dropdown) closeDropdown(otherDropdown);
        });
      });
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node)) return;

      if (!(navRoot instanceof HTMLElement) || !navRoot.contains(event.target)) {
        dropdowns.forEach((dropdown) => closeDropdown(dropdown));
      }

      if (mobileNav instanceof HTMLDetailsElement && !mobileNav.contains(event.target)) {
        mobileNav.open = false;
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;

      const openDropdown = dropdowns.find((dropdown) => dropdown.open);
      if (openDropdown) {
        closeDropdown(openDropdown);
        const summary = openDropdown.querySelector('summary');
        if (summary instanceof HTMLElement) summary.focus();
      }

      if (mobileNav instanceof HTMLDetailsElement) {
        mobileNav.open = false;
      }
    });
  })();
</script>
