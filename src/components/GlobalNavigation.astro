---
import { Image } from 'astro:assets';
import aletheiaLogo from '@images/aletheia-logo.png';
---

<div class="navbar bg-paper-200  text-ink-200 sticky top-0 z-50 shadow-md border-b border-base-300">
  
  <!-- LEFT: Identity -->
  <div class="navbar-start">
    <!-- Mobile Dropdown (Hamburger) -->
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-1 p-2 shadow bg-base-100 rounded-box w-52">
        <!-- Mobile users get everything here -->
        <li><a href="/" class="hover:text-gray-200" >Home</a></li>
        <li><a href="/about" class="hover:text-gray-200" >About</a></li>
        <li><a href="/lore" class="hover:text-gray-200" >Lore</a></li>
        <li><a href="/sentients" class="hover:text-gray-200" >Sentients</a></li>
        <li><a href="/places" class="hover:text-gray-200" >Places</a></li>
        <li><a href="/factions" class="hover:text-gray-200" >Factions</a></li>
        <li><a href="/creatures" class="hover:text-gray-200" >Creatures</a></li>
        <li><a href="/meta" class="hover:text-gray-200" >Meta</a></li>
        <li><a href="/campaigns" class="hover:text-gray-200" >Campaigns</a></li>
        <li><a href="/systems" class="hover:text-gray-200" >Systems</a></li>
        <li><a href="/systems/gurps" class="text-secondary hover:text-gray-200">GURPS</a></li>
        <!-- <li>
          <a>Regions</a>
          <ul class="p-2">
            <li><a>Northern Wastes</a></li>
            <li><a>Iron Guilds</a></li>
          </ul>
        </li> -->
      </ul>
    </div>
    
    <!-- Logo & Title -->
    <a href="/" class="btn btn-ghost text-xl font-serif tracking-widest">
      <Image src={aletheiaLogo} alt="World of Aletheia logo" width={48} height={32} class="h-8 w-12 mr-2" />
        World of Aletheia
    </a>
  </div>

  <!-- CENTER: Main Navigation -->
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal p-2 bg-base-100 shadow-lg rounded-t-none">
      <li><a href="/" class="hover:text-accent-400">Home</a></li>
      <li><a href="/aletheia-world-canon" class="hover:text-accent-400">World of Aletheia</a></li>
      <li><a href="/using-aletheia" class="hover:text-accent-400">Using Aletheia</a></li>
      <li><a href="/campaigns" class="hover:text-accent-400">Campaigns</a></li>
    </ul>
  </div>

  <!-- RIGHT: Utilities & The "System" Link -->
  <div class="navbar-end hidden lg:flex">
    <ul class="menu menu-horizontal px-1">
      <li><a href="/about" class="hover:text-gray-200">About</a></li>
      
      <!-- The "Regions" Dropdown (For quick jumping when NOT on homepage) -->
