---
import ArticleContextHeader from '@components/site/ArticleContextHeader.astro';
import PublicationMetadataNotice from '@components/PublicationMetadataNotice.astro';
import { formatAuthors } from '@utils/contributors';

interface Props {
  title: string;
  authors?: string[];
  created?: Date;
  campaign?: string;
  excerpt?: string;
  tags?: string[];
  publication?: string;
  contentState?: string;
  audienceWarnings?: string[];
  type?: string;
  subtype?: string;
}

const {
  title,
  authors = [],
  created,
  campaign,
  excerpt,
  tags = [],
  publication,
  contentState,
  audienceWarnings = [],
  type,
  subtype,
} = Astro.props;
const authorsLabel = formatAuthors(authors);

const details = [
  type ? { label: 'Type', value: type.replace(/[_-]/g, ' ') } : null,
  subtype ? { label: 'Subtype', value: subtype.replace(/[_-]/g, ' ') } : null,
  campaign ? { label: 'Campaign', value: campaign } : null,
  authorsLabel ? { label: 'Authors', value: authorsLabel } : null,
  created ? { label: 'Created', value: created.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) } : null,
].filter((item): item is { label: string; value: string } => item !== null);
---

<ArticleContextHeader title={title} summary={excerpt} details={details} tags={tags}>
  <PublicationMetadataNotice slot="notices" publication={publication} contentState={contentState} audienceWarnings={audienceWarnings} />
</ArticleContextHeader>
