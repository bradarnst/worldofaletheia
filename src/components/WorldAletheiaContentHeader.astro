---
import ArticleContextHeader from '@components/site/ArticleContextHeader.astro';
import { formatAuthors } from '@utils/contributors';

interface Props {
  title: string;
  authors?: string[];
  created?: Date;
  excerpt?: string;
  tags?: string[];
  type?: string;
  subtype?: string;
  parentChain?: Array<{ label: string; href: string }>;
  relationships?: Array<{ label: string; href: string; kind?: 'partOf' | 'connectedTo' }>;
}

const { title, authors = [], created, excerpt, tags = [], type, subtype, parentChain = [], relationships = [] } = Astro.props;
const authorsLabel = formatAuthors(authors);

const details = [
  type ? { label: 'Type', value: type.replace(/[_-]/g, ' ') } : null,
  subtype ? { label: 'Subtype', value: subtype.replace(/[_-]/g, ' ') } : null,
  authorsLabel ? { label: 'Authors', value: authorsLabel } : null,
  created ? { label: 'Created', value: created.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) } : null,
].filter((item): item is { label: string; value: string } => item !== null);
---

<ArticleContextHeader title={title} summary={excerpt} breadcrumbs={parentChain} details={details} relationships={relationships} tags={tags} />
