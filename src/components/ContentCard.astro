---
import SiteGlyph from '@components/site/SiteGlyph.astro';

interface Props {
  content: any;
  showExcerpt?: boolean;
  showTags?: boolean;
  showStatus?: boolean;
  showCampaign?: boolean;
  image?: any;
  imageAlt?: string;
  relationshipHints?: string[];
}

const { content, showExcerpt = true, showTags = true, showStatus = false, showCampaign = true, relationshipHints = [] } = Astro.props;

const data = content.data || content;
const collection = content.collection || '';
const id = content.id || '';
const shouldShowStatusBadge = showStatus || (data.status && data.status !== 'publish' && data.status !== 'published');
const iconName = data.type || collection || 'Entry';
const href = collection && id ? `/${collection}/${id}` : '#';
const createdDate = data.created instanceof Date
  ? data.created
  : data['created-date'] instanceof Date
    ? data['created-date']
    : null;
---

<a href={href} class="content-card group flex h-full flex-col rounded-[1.6rem] border border-base-300/80 bg-base-100 p-5 shadow-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
  <div class="content-card__header mb-4 flex items-start justify-between gap-3">
    <div class="flex min-w-0 items-start gap-3">
      <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-base-200 text-ink-700 group-hover:text-primary transition-colors">
        <SiteGlyph name={iconName} />
      </span>
      <div class="min-w-0 space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-600">{data.type ? String(data.type).replace(/[_-]/g, ' ') : collection}</p>
        <h3 class="text-xl font-semibold leading-tight text-ink-950 transition-colors group-hover:text-primary">{data.title}</h3>
      </div>
    </div>
    {shouldShowStatusBadge && <span class="rounded-full border border-info/35 bg-info/10 px-2.5 py-1 text-xs font-medium text-info-700">{data.status}</span>}
  </div>

  {showExcerpt && data.excerpt && <p class="text-sm leading-7 text-ink-800">{data.excerpt}</p>}

  {showCampaign && data.campaign && (
    <div class="mt-4 flex flex-wrap gap-2 text-xs text-ink-700">
      <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1">{data.campaign}</span>
      {data.author && <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1">{data.author}</span>}
    </div>
  )}

  {relationshipHints.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {relationshipHints.slice(0, 2).map((hint) => (
        <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1 text-xs text-ink-700">{hint}</span>
      ))}
    </div>
  )}

  {showTags && data.tags && data.tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {data.tags.slice(0, 3).map((tag: string) => (
        <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1 text-xs font-medium text-ink-700">{tag}</span>
      ))}
    </div>
  )}

  {createdDate && (
    <div class="mt-auto pt-5 text-xs font-medium uppercase tracking-[0.14em] text-ink-600">
      {createdDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </div>
  )}
</a>
