---
import SiteGlyph from '@components/site/SiteGlyph.astro';

interface Props {
  content: any;
  showExcerpt?: boolean;
  showTags?: boolean;
  showStatus?: boolean;
  showCampaign?: boolean;
  image?: any;
  imageAlt?: string;
  relationshipHints?: string[];
}

const { content, showExcerpt = true, showTags = true, showStatus = false, showCampaign = true, relationshipHints = [] } = Astro.props;

const data = content.data || content;
const collection = content.collection || '';
const id = content.id || '';
const contentStateLabels: Record<string, string> = {
  mayChange: 'May change',
  unfinished: 'Unfinished',
};
const audienceWarningLabels: Record<string, string> = {
  gmSpoilers: 'GM spoilers',
};
const visibleContentState = typeof data.contentState === 'string' && data.contentState !== 'stable'
  ? contentStateLabels[data.contentState] ?? data.contentState
  : null;
const audienceWarnings = Array.isArray(data.audienceWarnings) ? data.audienceWarnings : [];
const visibleAudienceWarnings = audienceWarnings
  .map((warning: string) => audienceWarningLabels[warning] ?? warning)
  .filter((warning: string) => warning.length > 0);
const shouldShowStatusBadge = showStatus && data.status;
const shouldShowPreviewBadge = data.publication === 'preview';
const iconName = data.type || collection || 'Entry';
const href = collection && id ? `/${collection}/${id}` : '#';
const authorsLabel = Array.isArray(data.authors) && data.authors.length > 0
  ? data.authors.join(', ')
  : typeof data.author === 'string' && data.author.trim().length > 0
    ? data.author
    : null;
const shouldShowMetadataChips = (showCampaign && data.campaign) || authorsLabel;
const createdDate = data.createdAt instanceof Date
  ? data.createdAt
  : null;
---

<a href={href} class="content-card group flex h-full flex-col rounded-[1.6rem] border border-base-300/80 bg-base-100 p-5 shadow-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
  <div class="content-card__header mb-4 flex items-start justify-between gap-3">
    <div class="flex min-w-0 items-start gap-3">
      <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-base-200 text-ink-700 group-hover:text-primary transition-colors">
        <SiteGlyph name={iconName} />
      </span>
      <div class="min-w-0 space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-600">{data.type ? String(data.type).replace(/[_-]/g, ' ') : collection}</p>
        <h3 class="text-xl font-semibold leading-tight text-ink-950 transition-colors group-hover:text-primary">{data.title}</h3>
      </div>
    </div>
    {(shouldShowStatusBadge || shouldShowPreviewBadge || visibleContentState || visibleAudienceWarnings.length > 0) && (
      <div class="flex shrink-0 flex-wrap justify-end gap-2">
        {shouldShowPreviewBadge && <span class="badge badge-info badge-outline">Preview</span>}
        {visibleContentState && <span class="badge badge-warning badge-outline">{visibleContentState}</span>}
        {visibleAudienceWarnings.map((warning: string) => <span class="badge badge-secondary badge-outline">{warning}</span>)}
        {shouldShowStatusBadge && <span class="badge badge-info badge-outline">{data.status}</span>}
      </div>
    )}
  </div>

  {showExcerpt && data.excerpt && <p class="text-sm leading-7 text-ink-800">{data.excerpt}</p>}

  {shouldShowMetadataChips && (
    <div class="mt-4 flex flex-wrap gap-2 text-xs text-ink-700">
      {showCampaign && data.campaign && <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1">{data.campaign}</span>}
      {authorsLabel && <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1">{authorsLabel}</span>}
    </div>
  )}

  {relationshipHints.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {relationshipHints.slice(0, 2).map((hint) => (
        <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1 text-xs text-ink-700">{hint}</span>
      ))}
    </div>
  )}

  {showTags && data.tags && data.tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {data.tags.slice(0, 3).map((tag: string) => (
        <span class="rounded-full border border-base-300/80 bg-base-200/70 px-3 py-1 text-xs font-medium text-ink-700">{tag}</span>
      ))}
    </div>
  )}

  {createdDate && (
    <div class="mt-auto pt-5 text-xs font-medium uppercase tracking-[0.14em] text-ink-600">
      {createdDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </div>
  )}
</a>
