---
interface Props {
  content: any;
  showExcerpt?: boolean;
  showTags?: boolean;
  showStatus?: boolean;
  showCampaign?: boolean;
}

const { content, showExcerpt = true, showTags = true, showStatus = true, showCampaign = true } = Astro.props;

// Handle both old and new Astro v6 content structures
const data = content.data || content;
const collection = content.collection || '';
const id = content.id || '';
---

<a href={`/${collection}/${id}`} class="card content-card bg-base-100 shadow-md hover:shadow-lg transition-shadow duration-200">
  <div class="card-body p-6">
    <div class="content-card__header flex justify-between items-start mb-3 gap-3">
      <h3 class="card-title text-xl font-bold text-base-content">{data.title}</h3>
      {showStatus && <span class="badge badge-info badge-outline whitespace-nowrap">{data.status}</span>}
    </div>
  
    {showCampaign && data.campaign && (
      <div class="flex items-center text-sm text-secondary opacity-90 mb-3 gap-2">
        <span class="badge badge-success badge-outline">{data.campaign}</span>
        <span>•</span>
        <span>{data.author}</span>
      </div>
    )}
    
    {showExcerpt && data.excerpt && (
      <p class="mb-4 text-base-content opacity-95">{data.excerpt}</p>
    )}
    
    {showTags && data.tags && data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {data.tags.map((tag: string) => (
          <span class="badge badge-outline badge-sm text-primary border-primary/35 bg-primary/10">{tag}</span>
        ))}
      </div>
    )}
    
    <div class="mt-4 text-sm text-secondary opacity-90">
      <span>{data.created.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
    </div>
  </div>
</a>
