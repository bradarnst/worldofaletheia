---
interface Props {
  content: any;
  showExcerpt?: boolean;
  showTags?: boolean;
  showStatus?: boolean;
  showCampaign?: boolean;
}

const { content, showExcerpt = true, showTags = true, showStatus = true, showCampaign = true } = Astro.props;
---

<a href={content.slug} class="block p-6 bg-white rounded-lg border border-gray-200 hover:shadow-md transition-shadow duration-200">
  <div class="flex justify-between items-start mb-3">
    <h3 class="text-xl font-bold text-gray-900">{content.title}</h3>
    {showStatus && <span class="px-2 py-1 rounded bg-blue-100 text-blue-800 text-sm">{content.status}</span>}
  </div>
  
  {showCampaign && content.campaign && (
    <div class="flex items-center text-sm text-gray-500 mb-3">
      <span class="px-2 py-1 bg-green-100 text-green-800 rounded mr-2">{content.campaign}</span>
      <span>•</span>
      <span class="ml-2">{content.author}</span>
    </div>
  )}
  
  {showExcerpt && content.excerpt && (
    <p class="text-gray-600 mb-4">{content.excerpt}</p>
  )}
  
  {showTags && content.tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {content.tags.map((tag: string) => (
        <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded-full text-xs">{tag}</span>
      ))}
    </div>
  )}
  
  <div class="mt-4 text-sm text-gray-500">
    <span>{content.created.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
  </div>
</a>