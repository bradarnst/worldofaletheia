---
import { getCollection, getEntry, render } from 'astro:content';
import WorldAletheiaContentLayout from '@layouts/WorldAletheiaContentLayout.astro';
import { getFilteredCollection } from '@utils/content-filter';

export async function getStaticPaths() {
  const bestiaryCollection = getFilteredCollection(await getCollection('bestiary'));
  return bestiaryCollection.map((item) => ({
    params: { slug: item.id },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry('bestiary', slug as string);

if (!entry) {
  throw new Error(`Bestiary entry with slug '${slug}' not found`);
}

const { Content } = await render(entry);
---

<WorldAletheiaContentLayout content={entry}>
  <article class="reading-prose">
    <Content />
  </article>
</WorldAletheiaContentLayout>
