---
import DiscoveryCollectionView from '@components/DiscoveryCollectionView.astro';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import wheatFields from '@images/wheat-fields.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'bestiary',
  searchParams: Astro.url.searchParams,
  locals: Astro.locals,
});
---

<WorldAletheiaLayout title="Bestiary - World of Aletheia" description="Explore monsters, beasts, and other creatures of Aletheia">
  <DiscoveryCollectionView
    basePath="/bestiary"
    collectionLabel="Bestiary"
    image={wheatFields}
    emptyMessage="No published bestiary entries found."
    {...discoveryPage}
  />
</WorldAletheiaLayout>
