---
import { getCollection } from 'astro:content';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';

const flora = await getCollection('flora');
const publishedFlora = flora.filter((item) => item.data.status === 'publish');

const allTags = [...new Set(publishedFlora.flatMap(item => item.data.tags))];
---

<WorldAletheiaLayout title="Flora - World of Aletheia" description="Explore plants, fungi, herbs, and other flora of Aletheia">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Flora</h2>
      
      {publishedFlora.length === 0 ? (
        <p class="text-gray-600">No published flora entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedFlora.map((item) => (
            <ContentCard content={item} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</WorldAletheiaLayout>
