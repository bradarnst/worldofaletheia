---
import DiscoveryCollectionView from '@components/DiscoveryCollectionView.astro';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import savannaFarmland from '@images/savanna-farmland.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'flora',
  searchParams: Astro.url.searchParams,
  locals: Astro.locals,
});
---

<WorldAletheiaLayout title="Flora - World of Aletheia" description="Explore plants, fungi, herbs, and other flora of Aletheia">
  <DiscoveryCollectionView
    basePath="/flora"
    collectionLabel="Flora"
    image={savannaFarmland}
    emptyMessage="No published flora entries found."
    {...discoveryPage}
  />
</WorldAletheiaLayout>
