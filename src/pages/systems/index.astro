---
import DiscoveryCollectionView from '@components/DiscoveryCollectionView.astro';
import { GAME_SYSTEMS } from '@data/game-systems';
import UsingAletheiaLayout from '@layouts/UsingAletheiaLayout.astro';
import boatInMangroves from '@images/boat-in-mangroves.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'systems',
  searchParams: Astro.url.searchParams,
  locals: Astro.locals,
});
---

<UsingAletheiaLayout title="Systems - World of Aletheia" description="Explore magic, combat, skill, economy, and social systems of Aletheia">
  <DiscoveryCollectionView
    basePath="/systems"
    collectionLabel="Systems"
    image={boatInMangroves}
    emptyMessage="No published system entries found."
    {...discoveryPage}
  >
    <section class="mx-auto max-w-7xl px-4 pt-8 lg:px-8 lg:pt-10">
      <div class="rounded-[1.75rem] border border-base-300/70 bg-base-100/88 p-6 shadow-sm backdrop-blur-sm lg:p-8">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-600">Game systems</p>
          <h2 class="mt-2 text-2xl font-bold text-ink-950 md:text-3xl">System-specific rules hubs</h2>
          <p class="mt-3 text-sm leading-7 text-ink-700 md:text-base">
            Start with a dedicated game system guide, then use the discovery view below to browse the wider rules archive.
          </p>
        </div>

        <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
          {GAME_SYSTEMS.map((system) => (
            <article class="flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm">
              <h3 class="text-xl font-semibold text-ink-950">{system.label}</h3>
              <p class="mt-3 text-sm leading-7 text-ink-700">{system.description}</p>
              <a href={system.href} class="mt-auto pt-6 text-sm font-semibold text-primary hover:text-secondary">
                Open {system.label}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </DiscoveryCollectionView>
</UsingAletheiaLayout>
