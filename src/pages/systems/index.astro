---
import { getCollection } from 'astro:content';
import UsingAletheiaLayout from '@layouts/UsingAletheiaLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';

const systems = await getCollection('systems');
const publishedSystems = systems.filter((item) => item.data.status === 'published');

const allTags = [...new Set(publishedSystems.flatMap(item => item.data.tags))];
---

<UsingAletheiaLayout title="Systems - World of Aletheia" description="Explore magic, combat, skill, economy, and social systems of Aletheia">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Systems</h2>
      
      {publishedSystems.length === 0 ? (
        <p class="text-gray-600">No published system entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedSystems.map((item) => (
            <ContentCard content={item} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</UsingAletheiaLayout>