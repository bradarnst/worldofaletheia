---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';

const systems = await getCollection('systems');
const publishedSystems = systems.filter((item) => item.data.status === 'published');

// Get all unique tags
const allTags = [...new Set(publishedSystems.flatMap(item => item.data.tags))];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Systems - World of Aletheia</title>
</head>
<body>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Systems</h1>
      <p class="text-xl text-gray-600">Explore magic, combat, skill, economy, and social systems of Aletheia</p>
    </header>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Systems</h2>
      
      {publishedSystems.length === 0 ? (
        <p class="text-gray-600">No published system entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedSystems.map((item) => (
            <ContentCard content={item.data} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</body>
</html>