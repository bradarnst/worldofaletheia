---
import { getCollection } from 'astro:content';
import UsingAletheiaLayout from '@layouts/UsingAletheiaLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';
import boatInMangroves from '@images/boat-in-mangroves.png';

const systems = await getCollection('systems');
const publishedSystems = systems.filter((item) => item.data.status === 'publish');

const allTags = [...new Set(publishedSystems.flatMap(item => item.data.tags))];
---

<UsingAletheiaLayout title="Systems - World of Aletheia" description="Explore magic, combat, skill, economy, and social systems of Aletheia">
  <div class="mb-8 rounded-xl border border-base-300 bg-base-200/60 p-4 text-sm text-ink-700">
    <div class="font-semibold mb-1">Future-ready discovery</div>
    <p class="meta-muted">Prepared for future filters by system type, subtype, and tags with alphabetical and grouped views in later phases.</p>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-ink-950 mb-6">Latest Systems</h2>
      
      {publishedSystems.length === 0 ? (
        <p class="meta-muted">No published system entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedSystems.map((item, index) => (
            <ContentCard content={item} image={index % 2 === 0 ? boatInMangroves : undefined} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-ink-950 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</UsingAletheiaLayout>
