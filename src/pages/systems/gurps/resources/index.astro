---
import Layout from '@layouts/GurpsLayout.astro';

const title = 'Resources - GURPS - World of Aletheia';
const description = 'Helpful lists and references for GURPS gameplay in the World of Aletheia.';

const categories = [
  { href: '/systems/gurps/resources/sorcerer-spells', title: 'Sorcerer Spells', description: 'Comprehensive spell list for the World of Aletheia.', cta: 'Browse' },
  { title: 'Skills', description: 'Recommended skills and skill combinations for character development.', cta: 'Coming soon' },
  { title: 'Equipment', description: 'Campaign-appropriate gear and equipment guidance.', cta: 'Coming soon' },
  { title: 'Reference Tables', description: 'Quick tables and charts for common game mechanics.', cta: 'Coming soon' },
];

const nextLinks = [
  { href: '/systems/gurps/character-creation', title: 'Character Creation', description: 'Tips for creating characters with house rules.', cta: 'Learn more' },
  { href: '/systems/gurps/external-links', title: 'External Links', description: 'Curated GURPS resources and references.', cta: 'Explore' },
];
---

<Layout title={title} description={description}>
  <div class="max-w-6xl">
    <h1 class="mb-6 text-5xl font-bold text-ink-950 drop-shadow-lg lg:text-6xl">Resources</h1>
    <p class="mb-8 text-lg text-ink-800 drop-shadow-md">Helpful lists and references for GURPS gameplay in the World of Aletheia.</p>

    <div class="mb-8 grid grid-cols-1 gap-6 md:grid-cols-2">
      {categories.map((category) => {
        const Wrapper = category.href ? 'a' : 'div';
        return (
          <Wrapper href={category.href} class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
            <h2 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">{category.title}</h2>
            <p class="mt-3 text-sm leading-7 text-ink-700">{category.description}</p>
            <span class="mt-auto pt-6 text-sm font-semibold text-primary">{category.cta}</span>
          </Wrapper>
        );
      })}
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {nextLinks.map((link) => (
        <a href={link.href} class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
          <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">{link.title}</h3>
          <p class="mt-3 text-sm leading-7 text-ink-700">{link.description}</p>
          <span class="mt-auto pt-6 text-sm font-semibold text-primary">{link.cta}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
