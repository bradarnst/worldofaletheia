---
export const prerender = true;

import Layout from '@layouts/GurpsLayout.astro';
import SpellAlphabeticalIndex from '@components/spells/SpellAlphabeticalIndex.astro';
import spellsData from '@data/spells/spells-raw.json';
import { SPELLS_PAGE_SIZE, getSpellListPageHref, paginateSpells, sortSpellsByName } from '@utils/spell-browser';

const sortedSpells = sortSpellsByName(spellsData.spells);
const totalPages = Math.max(1, Math.ceil(sortedSpells.length / SPELLS_PAGE_SIZE));

export async function getStaticPaths() {
  const pathTotalPages = Math.max(1, Math.ceil(spellsData.spells.length / SPELLS_PAGE_SIZE));

  return Array.from({ length: Math.max(0, pathTotalPages - 1) }, (_, index) => ({
    params: {
      page: String(index + 2),
    },
  }));
}

const currentPage = Number(Astro.params.page);
const paginatedSpells = paginateSpells(sortedSpells, currentPage, SPELLS_PAGE_SIZE);

if (!Number.isInteger(currentPage) || currentPage < 2 || currentPage > totalPages) {
  return Astro.redirect(getSpellListPageHref(1), 302);
}

const title = `All Spells (Alphabetical) - Page ${paginatedSpells.currentPage} - Sorcerer Spells - GURPS - World of Aletheia`;
const description = `Alphabetical index page ${paginatedSpells.currentPage} of ${paginatedSpells.totalPages} for ${paginatedSpells.totalSpells} sorcerer spells.`;
---

<Layout title={title} description={description}>
  <h1 class="mb-6 text-5xl font-bold text-ink-950 drop-shadow-lg lg:text-6xl">All Spells (Alphabetical)</h1>
  <SpellAlphabeticalIndex
    spells={paginatedSpells.spells}
    currentPage={paginatedSpells.currentPage}
    pageSize={paginatedSpells.pageSize}
    totalPages={paginatedSpells.totalPages}
    totalSpells={paginatedSpells.totalSpells}
  />
</Layout>
