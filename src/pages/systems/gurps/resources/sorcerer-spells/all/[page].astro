---
import { isPublicSpellApiError, listSourceSpellTypes, listSpells, listSpellTypes } from '@adapters/public-spell-api';
import Layout from '@layouts/GurpsLayout.astro';
import SpellAlphabeticalIndex from '@components/spells/SpellAlphabeticalIndex.astro';
import SpellListClientScript from '@components/spells/SpellListClientScript.astro';
import SpellListStatusPanel from '@components/spells/SpellListStatusPanel.astro';
import SpellSearchForm from '@components/spells/SpellSearchForm.astro';
import {
  SPELLS_PAGE_SIZE,
  createEmptySpellPage,
  getSpellListPageHref,
  getSpellSearchFilters,
  hasSpellSearchFilters,
  sortSpellTypeLabels,
} from '@utils/spell-browser';

const requestedPage = Number(Astro.params.page);
const filters = getSpellSearchFilters(Astro.url.searchParams);

if (!Number.isInteger(requestedPage) || requestedPage < 2) {
  return Astro.redirect(getSpellListPageHref(1, filters), 302);
}

let paginatedSpells = createEmptySpellPage(requestedPage, SPELLS_PAGE_SIZE);
let spellTypes: string[] = [];
let sourceSpellTypes: string[] = [];
let unavailableMessage: string | null = null;

try {
  paginatedSpells = await listSpells({ page: requestedPage, pageSize: SPELLS_PAGE_SIZE, ...filters });
} catch (error) {
  if (!isPublicSpellApiError(error)) {
    throw error;
  }

  Astro.response.status = error.status;
  if (error.retryAfter) {
    Astro.response.headers.set('Retry-After', error.retryAfter);
  }

  unavailableMessage = error.message;
}

if (!unavailableMessage) {
  try {
    const [resolvedSpellTypes, resolvedSourceSpellTypes] = await Promise.all([listSpellTypes(), listSourceSpellTypes()]);
    spellTypes = resolvedSpellTypes;
    sourceSpellTypes = sortSpellTypeLabels(resolvedSourceSpellTypes);
  } catch (error) {
    if (!isPublicSpellApiError(error)) {
      throw error;
    }
  }
}

if (!unavailableMessage && paginatedSpells.page !== requestedPage) {
  return Astro.redirect(getSpellListPageHref(paginatedSpells.page, filters), 302);
}

const hasFilters = hasSpellSearchFilters(filters);
const hasFullTextSearch = filters.q !== '';
const titlePrefix = hasFilters ? 'Search Spells' : 'All Spells (Alphabetical)';
const title = `${titlePrefix} - Page ${paginatedSpells.page} - Sorcerer Spells - GURPS - World of Aletheia`;
const description = hasFullTextSearch
  ? `Full-text spell search page ${paginatedSpells.page} of ${paginatedSpells.totalPages} for ${paginatedSpells.total} matching sorcerer spells.`
  : hasFilters
    ? `Filtered spell browser page ${paginatedSpells.page} of ${paginatedSpells.totalPages} for ${paginatedSpells.total} sorcerer spells.`
    : `Alphabetical index page ${paginatedSpells.page} of ${paginatedSpells.totalPages} for ${paginatedSpells.total} sorcerer spells.`;
---

<Layout title={title} description={description}>
  <h1 class="mb-6 text-5xl font-bold text-ink-950 drop-shadow-lg lg:text-6xl">{titlePrefix}</h1>
  {unavailableMessage ? (
    <section class="ui-surface ui-surface--glass p-6">
      <h2 class="mb-3 text-2xl font-semibold text-ink-950">Spell Catalog Unavailable</h2>
      <p class="text-ink-800">{unavailableMessage}</p>
    </section>
  ) : (
    <>
      <section class="ui-surface ui-surface--glass mb-8 p-6">
        <SpellSearchForm filters={filters} spellTypes={spellTypes} sourceSpellTypes={sourceSpellTypes} />
      </section>

      <SpellListStatusPanel className="mb-8" />

      <SpellAlphabeticalIndex
        spells={paginatedSpells.items}
        currentPage={paginatedSpells.page}
        pageSize={paginatedSpells.pageSize}
        totalPages={paginatedSpells.totalPages}
        totalSpells={paginatedSpells.total}
        filters={filters}
      />
    </>
  )}

  <SpellListClientScript />
</Layout>
