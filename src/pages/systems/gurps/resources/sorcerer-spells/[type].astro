---
import Layout from '@layouts/GurpsLayout.astro';
import spellsData from '@data/spells/spells-raw.json';
import spellTypes from '@data/spells/spell-types.json';

// Get the spell type from the URL
const { type } = Astro.params;

// Convert URL slug back to spell type name
const spellTypeName = spellTypes.find(st => 
  st.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') === type
);

// Filter spells by type
const spells = spellsData.spells
  .filter(spell => spell.spell_type === spellTypeName)
  .sort((a, b) => a.spell_name.localeCompare(b.spell_name));

const title = `${spellTypeName} - Sorcerer Spells - GURPS - World of Aletheia`;
const description = `${spells.length} ${spellTypeName} spells for World of Aletheia GURPS campaigns.`;

// Generate static paths for all spell types
export async function getStaticPaths() {
  return spellTypes.map(spellType => ({
    params: { 
      type: spellType.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
    }
  }));
}
---

<Layout title={title} description={description}>
	<!-- Main content -->
	<div class="max-w-6xl">
		<h1 class="text-5xl lg:text-6xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
			{spellTypeName}
		</h1>
		<p class="text-lg text-ink-800 mb-8 drop-shadow-md">
			{spells.length} spell{spells.length !== 1 ? 's' : ''} in this category.
		</p>
		
		<!-- Spell Cards Grid -->
		{spells.length > 0 ? (
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
				{spells.map((spell) => {
					// Truncate description to first 150 characters
					const descriptionBlurb = spell.description.length > 150 
						? spell.description.substring(0, 150) + '...' 
						: spell.description;
					
					// Truncate statistics to first 120 characters
					const statisticsBlurb = (spell.statistics && spell.statistics.length > 120)
						? spell.statistics.substring(0, 120) + '...' 
						: spell.statistics || '';
					
					return (
						<div class="card bg-base-100/90 backdrop-blur-sm shadow-lg hover:shadow-xl transition-shadow h-full flex flex-col">
							<div class="card-body p-3 flex flex-col h-full">
								{/* Spell Title - Prominent */}
								<h2 class="card-title font-lora text-lg text-ink-950 mb-1">
									{spell.spell_name}
								</h2>
								
								{/* Cost - Prominent */}
								<div class="mb-2 pb-2 border-b border-base-300">
									<p class="text-xs font-semibold text-primary">
										💰 {spell.full_cost}
									</p>
								</div>
								
								{/* Keywords - Slightly Prominent */}
								{spell.keywords && spell.keywords !== 'None' && (
									<div class="mb-2">
										<p class="text-xs font-semibold text-ink-700 uppercase tracking-wide">
											Keywords
										</p>
										<p class="text-xs text-ink-800">
											{spell.keywords}
										</p>
									</div>
								)}
								
								{/* Casting Roll */}
								<div class="mb-2 text-xs">
									<span class="font-semibold text-ink-700">Casting:</span>
									<span class="text-ink-800 ml-1">{spell.casting_roll}</span>
								</div>
								
								{/* Range and Duration */}
								<div class="mb-2 text-xs space-y-1">
									<div>
										<span class="font-semibold text-ink-700">Range:</span>
										<span class="text-ink-800 ml-1">{spell.range}</span>
									</div>
									<div>
										<span class="font-semibold text-ink-700">Duration:</span>
										<span class="text-ink-800 ml-1">{spell.duration}</span>
									</div>
								</div>
								
								{/* Description Blurb */}
								<div class="mb-2 flex-grow">
									<p class="text-xs font-semibold text-ink-700 uppercase tracking-wide mb-1">
										Description
									</p>
									<p class="text-xs text-ink-800 line-clamp-2">
										{descriptionBlurb}
									</p>
								</div>
								
								{/* Statistics Blurb */}
								<div class="mb-3">
									<p class="text-xs font-semibold text-ink-700 uppercase tracking-wide mb-1">
										Statistics
									</p>
									<p class="text-xs text-ink-700 line-clamp-1 font-mono">
										{statisticsBlurb}
									</p>
								</div>
								
								{/* View Details Button */}
								<div class="card-actions justify-end mt-auto">
									<button 
										class="btn btn-primary btn-sm"
										onclick={`document.getElementById('spell-modal-${spell.spell_name.replace(/\s+/g, '-').toLowerCase()}').showModal()`}
									>
										View Details
									</button>
								</div>
							</div>
						</div>
					);
				})}
			</div>
		) : (
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl">
				<div class="card-body">
					<p>No spells found in this category.</p>
				</div>
			</div>
		)}
		
		<!-- Navigation cards -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<a href="/gurps/resources/sorcerer-spells" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h3 class="card-title font-lora">← Back to Sorcerer Spells</h3>
					<p>Browse other spell types.</p>
					<div class="card-actions justify-end">
						<div class="btn btn-primary btn-sm">Back</div>
					</div>
				</div>
			</a>
			
			<a href="/gurps/resources/sorcerer-spells/all" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h3 class="card-title font-lora">All Spells</h3>
					<p>View alphabetical spell index.</p>
					<div class="card-actions justify-end">
						<div class="btn btn-primary btn-sm">View</div>
					</div>
				</div>
			</a>
		</div>
	</div>

	<!-- Spell Detail Modals -->
	{spells.map((spell) => {
			const modalId = `spell-modal-${spell.spell_name.replace(/\s+/g, '-').toLowerCase()}`;
			return (
				<dialog id={modalId} class="modal modal-bottom sm:modal-middle">
					<div class="modal-box max-h-[90vh] overflow-y-auto">
						{/* Close Button */}
						<button 
							class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2"
							onclick={`document.getElementById('${modalId}').close()`}
						>
							✕
						</button>

						{/* Spell Title */}
						<h2 class="font-lora text-2xl font-bold text-ink-950 mb-4 pr-8">
							{spell.spell_name}
						</h2>

						{/* Cost */}
						<div class="mb-4 pb-4 border-b border-base-300">
							<p class="text-lg font-semibold text-primary">
								💰 {spell.full_cost}
							</p>
						</div>

						{/* Keywords */}
						{spell.keywords && spell.keywords !== 'None' && (
							<div class="mb-4">
								<p class="text-sm font-semibold text-ink-700 uppercase tracking-wide mb-2">
									Keywords
								</p>
								<p class="text-base text-ink-800">
									{spell.keywords}
								</p>
							</div>
						)}

						{/* Casting Roll */}
						<div class="mb-4">
							<p class="text-sm font-semibold text-ink-700 uppercase tracking-wide mb-1">
								Casting Roll
							</p>
							<p class="text-base text-ink-800">
								{spell.casting_roll}
							</p>
						</div>

						{/* Range */}
						<div class="mb-4">
							<p class="text-sm font-semibold text-ink-700 uppercase tracking-wide mb-1">
								Range
							</p>
							<p class="text-base text-ink-800">
								{spell.range}
							</p>
						</div>

						{/* Duration */}
						<div class="mb-4">
							<p class="text-sm font-semibold text-ink-700 uppercase tracking-wide mb-1">
								Duration
							</p>
							<p class="text-base text-ink-800">
								{spell.duration}
							</p>
						</div>

						{/* Full Description */}
						<div class="mb-4">
							<p class="text-sm font-semibold text-ink-700 uppercase tracking-wide mb-2">
								Description
							</p>
							<p class="text-base text-ink-800 leading-relaxed">
								{spell.description}
							</p>
						</div>

						{/* Full Statistics */}
						<div class="mb-6">
							<p class="text-sm font-semibold text-ink-700 uppercase tracking-wide mb-2">
								Statistics
							</p>
							<p class="text-sm text-ink-700 font-mono leading-relaxed whitespace-pre-wrap">
								{spell.statistics}
							</p>
						</div>

						{/* Close Button at Bottom */}
						<div class="modal-action">
							<button 
								class="btn btn-primary"
								onclick={`document.getElementById('${modalId}').close()`}
							>
								Close
							</button>
						</div>
					</div>

					{/* Backdrop - click to close */}
					<form method="dialog" class="modal-backdrop">
						<button>close</button>
					</form>
				</dialog>
			);
		})}

		<script>
			// Handle Escape key to close modals
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') {
					const openModal = document.querySelector('dialog[open]') as HTMLDialogElement;
					if (openModal) {
						openModal.close();
					}
				}
			});
	</script>
</Layout>
