---
import Layout from '@layouts/GurpsLayout.astro';
import spellsData from '@data/spells/spells-raw.json';
import spellTypes from '@data/spells/spell-types.json';

const { type } = Astro.params;

const spellTypeName = spellTypes.find((spellType) => spellType.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') === type);

const spells = spellsData.spells
  .filter((spell) => spell.spell_type === spellTypeName)
  .sort((a, b) => a.spell_name.localeCompare(b.spell_name));

const title = `${spellTypeName} - Sorcerer Spells - GURPS - World of Aletheia`;
const description = `${spells.length} ${spellTypeName} spells for World of Aletheia GURPS campaigns.`;

export async function getStaticPaths() {
  return spellTypes.map((spellType) => ({
    params: {
      type: spellType.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
    },
  }));
}
---

<Layout title={title} description={description}>
  <div class="max-w-6xl">
    <h1 class="mb-6 text-5xl font-bold text-ink-950 drop-shadow-lg lg:text-6xl">{spellTypeName}</h1>
    <p class="mb-8 text-lg text-ink-800 drop-shadow-md">{spells.length} spell{spells.length !== 1 ? 's' : ''} in this category.</p>

    {spells.length > 0 ? (
      <div class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
        {spells.map((spell) => {
          const descriptionBlurb = spell.description.length > 150 ? `${spell.description.substring(0, 150)}...` : spell.description;
          const statisticsBlurb = spell.statistics && spell.statistics.length > 120 ? `${spell.statistics.substring(0, 120)}...` : spell.statistics || '';

          return (
            <article class="flex h-full flex-col rounded-[1.35rem] border border-base-300/80 bg-base-100/92 p-4 shadow-sm backdrop-blur-sm">
              <h2 class="mb-1 text-lg font-semibold text-ink-950">{spell.spell_name}</h2>
              <div class="mb-2 border-b border-base-300 pb-2">
                <p class="text-xs font-semibold text-primary">{spell.full_cost}</p>
              </div>

              {spell.keywords && spell.keywords !== 'None' && (
                <div class="mb-2">
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">Keywords</p>
                  <p class="text-xs text-ink-800">{spell.keywords}</p>
                </div>
              )}

              <div class="mb-2 text-xs">
                <span class="font-semibold text-ink-700">Casting:</span>
                <span class="ml-1 text-ink-800">{spell.casting_roll}</span>
              </div>

              <div class="mb-2 space-y-1 text-xs">
                <div>
                  <span class="font-semibold text-ink-700">Range:</span>
                  <span class="ml-1 text-ink-800">{spell.range}</span>
                </div>
                <div>
                  <span class="font-semibold text-ink-700">Duration:</span>
                  <span class="ml-1 text-ink-800">{spell.duration}</span>
                </div>
              </div>

              <div class="mb-2 flex-grow">
                <p class="mb-1 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">Description</p>
                <p class="line-clamp-2 text-xs text-ink-800">{descriptionBlurb}</p>
              </div>

              <div class="mb-3">
                <p class="mb-1 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">Statistics</p>
                <p class="line-clamp-1 font-mono text-xs text-ink-700">{statisticsBlurb}</p>
              </div>

              <div class="mt-auto flex justify-end">
                <button
                  class="ui-button ui-button--primary ui-button--sm"
                  onclick={`document.getElementById('spell-modal-${spell.spell_name.replace(/\s+/g, '-').toLowerCase()}')?.showModal()`}
                >
                  View Details
                </button>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <div class="ui-surface ui-surface--glass p-6">
        <p>No spells found in this category.</p>
      </div>
    )}

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <a href="/systems/gurps/resources/sorcerer-spells" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">Back to Sorcerer Spells</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Browse other spell types.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">Back</span>
      </a>

      <a href="/systems/gurps/resources/sorcerer-spells/all" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">All Spells</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">View alphabetical spell index.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">View</span>
      </a>
    </div>
  </div>

  {spells.map((spell) => {
    const modalId = `spell-modal-${spell.spell_name.replace(/\s+/g, '-').toLowerCase()}`;
    return (
      <dialog id={modalId} class="m-auto w-[min(94vw,52rem)] rounded-[1.5rem] border border-base-300 bg-base-100 p-0 text-left shadow-2xl backdrop:bg-ink-950/70">
        <article class="max-h-[90vh] overflow-y-auto p-6 md:p-8">
          <div class="mb-6 flex items-start justify-between gap-4 border-b border-base-300 pb-4">
            <div>
              <h2 class="pr-8 text-2xl font-bold text-ink-950">{spell.spell_name}</h2>
              <p class="mt-2 text-lg font-semibold text-primary">{spell.full_cost}</p>
            </div>
            <button class="ui-button ui-button--ghost ui-button--sm" onclick={`document.getElementById('${modalId}')?.close()`}>Close</button>
          </div>

          {spell.keywords && spell.keywords !== 'None' && (
            <section class="mb-4">
              <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Keywords</p>
              <p class="text-base text-ink-800">{spell.keywords}</p>
            </section>
          )}

          <section class="mb-4 grid gap-4 md:grid-cols-3">
            <div>
              <p class="mb-1 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Casting Roll</p>
              <p class="text-base text-ink-800">{spell.casting_roll}</p>
            </div>
            <div>
              <p class="mb-1 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Range</p>
              <p class="text-base text-ink-800">{spell.range}</p>
            </div>
            <div>
              <p class="mb-1 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Duration</p>
              <p class="text-base text-ink-800">{spell.duration}</p>
            </div>
          </section>

          <section class="mb-4">
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Description</p>
            <p class="text-base leading-relaxed text-ink-800">{spell.description}</p>
          </section>

          <section class="mb-6">
            <p class="mb-2 text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Statistics</p>
            <p class="whitespace-pre-wrap font-mono text-sm leading-relaxed text-ink-700">{spell.statistics}</p>
          </section>

          <div class="flex justify-end">
            <form method="dialog">
              <button class="ui-button ui-button--primary">Close</button>
            </form>
          </div>
        </article>
      </dialog>
    );
  })}

  <script>
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const openModal = document.querySelector('dialog[open]') as HTMLDialogElement | null;
        openModal?.close();
      }
    });
  </script>
</Layout>
