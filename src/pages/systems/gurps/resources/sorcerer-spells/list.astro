---
import SpellListClientScript from '@components/spells/SpellListClientScript.astro';
import Layout from '@layouts/GurpsLayout.astro';

const title = 'Saved Spell List - Sorcerer Spells - GURPS - World of Aletheia';
const description = 'Temporary browser-local spell list for reviewing and printing selected sorcerer spells.';
---

<Layout title={title} description={description}>
  <div class="max-w-6xl">
    <section class="ui-surface ui-surface--glass mb-8 p-6 print:shadow-none">
      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between print:block">
        <div>
          <h1 class="mb-3 text-5xl font-bold text-ink-950 drop-shadow-lg lg:text-6xl">Saved Spell List</h1>
          <p class="text-lg text-ink-800">Your spell list is stored only in this browser on this device.</p>
        </div>

        <div class="flex flex-wrap items-center gap-3 print:hidden">
          <div class="rounded-[1rem] border border-base-300 bg-base-100/80 px-4 py-3 text-sm text-ink-800">
            <span class="font-semibold text-ink-950" data-spell-list-count>0</span>
            {' '}
            saved
          </div>
          <button
            type="button"
            class="ui-button ui-button--secondary"
            data-spell-list-clear
            data-confirm-title="Clear Spell List?"
            data-confirm-message="This removes all saved spells from this browser on this device."
          >
            Clear Spell List
          </button>
          <button type="button" class="ui-button ui-button--secondary" data-spell-list-print>Print Spell List</button>
          <a href="/systems/gurps/resources/sorcerer-spells/all" class="ui-button ui-button--primary">Browse All Spells</a>
        </div>
      </div>
    </section>

    <section class="ui-surface ui-surface--glass mb-8 p-6 print:hidden">
      <h2 class="mb-2 text-2xl font-semibold text-ink-950">How this works</h2>
      <p class="text-ink-800">Add spells from the browser or spell detail dialogs, then return here to review or print the current list. Clearing browser storage or switching devices will clear this temporary list.</p>
    </section>

    <section data-saved-spell-list-root>
      <div class="ui-surface ui-surface--glass mb-8 p-6" data-saved-spell-list-loading>
        <p class="text-ink-800">Loading saved spell details...</p>
      </div>

      <div class="ui-surface ui-surface--glass mb-8 border border-dashed border-base-300 p-8 text-center" data-saved-spell-list-empty hidden>
        <h2 class="text-2xl font-semibold text-ink-950">No spells saved yet</h2>
        <p class="mt-3 text-ink-700">Add spells from the Sorcerer Spells browser to build a temporary list for play or printing.</p>
        <div class="mt-5 flex justify-center">
          <a href="/systems/gurps/resources/sorcerer-spells/all" class="ui-button ui-button--primary">Browse All Spells</a>
        </div>
      </div>

      <div class="ui-surface mb-8 border-warning/35 bg-warning/10 p-5 print:hidden" data-saved-spell-list-stale hidden></div>
      <div class="ui-surface mb-8 border-warning/35 bg-warning/10 p-5 print:hidden" data-saved-spell-list-unavailable hidden></div>

      <div class="space-y-6" data-saved-spell-list-items></div>
    </section>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 print:hidden">
      <a href="/systems/gurps/resources/sorcerer-spells/all" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">Browse All Spells</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Return to the alphabetical spell browser and keep adding to this temporary list.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">Browse</span>
      </a>

      <a href="/systems/gurps/resources/sorcerer-spells" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">Sorcerer Spells Home</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Return to the spell overview, attribution, and browse-by-type entry point.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">Home</span>
      </a>
    </div>
  </div>

  <SpellListClientScript mode="list" />
</Layout>

<style>
  @media print {
    .spell-print-card {
      break-inside: avoid-page;
      page-break-inside: avoid;
      box-shadow: none;
      border: 1px solid color-mix(in oklab, var(--border-subtle), transparent 20%);
    }
  }
</style>
