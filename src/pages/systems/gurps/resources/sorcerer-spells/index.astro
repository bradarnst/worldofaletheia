---
import Layout from '@layouts/GurpsLayout.astro';
import spellTypes from '@data/spells/spell-types.json';

const title = 'Sorcerer Spells - GURPS - World of Aletheia';
const description = 'Comprehensive reference for sorcerer spells in the World of Aletheia.';
---

<Layout title={title} description={description}>
  <div class="max-w-6xl">
    <h1 class="mb-6 text-5xl font-bold text-ink-950 drop-shadow-lg lg:text-6xl">Sorcerer Spells</h1>
    <p class="mb-8 text-lg text-ink-800 drop-shadow-md">Comprehensive reference for sorcerer spells in the World of Aletheia.</p>

    <section class="ui-surface mb-8 border-2 border-primary/35 p-6">
      <h2 class="mb-3 text-lg font-semibold text-ink-950">Spell Source Attribution</h2>
      <p class="mb-3 text-ink-800">
        These 676 sorcerer spells are sourced from the <strong>Generic Universal Eggplant</strong> blog, an excellent resource for GURPS spell variants and homebrew content.
      </p>
      <p class="mb-4 text-ink-800">
        <strong>Source:</strong>
        {' '}
        <a href="https://enragedeggplant.blogspot.com/" target="_blank" class="font-semibold text-primary transition-colors hover:text-secondary">
          Generic Universal Eggplant - Sorcery Spells
        </a>
      </p>
      <p class="text-sm text-ink-800">
        The spells have been organized and integrated into this site to provide easy reference for World of Aletheia campaigns.
      </p>
    </section>

    <section class="ui-surface ui-surface--glass mb-8 p-6">
      <h2 class="mb-4 text-2xl font-semibold text-ink-950">Browse Spells</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/systems/gurps/resources/sorcerer-spells/all" class="ui-button ui-button--primary">All Spells (Alphabetical)</a>
      </div>
    </section>

    <section class="ui-surface ui-surface--glass mb-8 p-6">
      <h2 class="mb-4 text-2xl font-semibold text-ink-950">Spell Types</h2>
      <p class="mb-6 text-ink-800">Browse spells organized by type. There are {spellTypes.length} spell types available.</p>

      <div class="grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3">
        {spellTypes.map((spellType) => {
          const slug = spellType.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
          return (
            <a href={`/systems/gurps/resources/sorcerer-spells/${slug}`} class="ui-button ui-button--secondary justify-start">
              {spellType}
            </a>
          );
        })}
      </div>
    </section>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <a href="/systems/gurps/resources" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">Back to Resources</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">View all GURPS resources.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">Back</span>
      </a>

      <a href="/systems/gurps" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">GURPS Home</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Back to the GURPS campaign guide.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">Home</span>
      </a>
    </div>
  </div>
</Layout>
