---
import { isPublicSpellApiError, listSourceSpellTypes, listSpells, listSpellTypes } from '@adapters/public-spell-api';
import SpellListClientScript from '@components/spells/SpellListClientScript.astro';
import SpellListStatusPanel from '@components/spells/SpellListStatusPanel.astro';
import SpellSearchForm from '@components/spells/SpellSearchForm.astro';
import Layout from '@layouts/GurpsLayout.astro';
import { getSpellListPageHref, sortSpellTypeLabels } from '@utils/spell-browser';

const title = 'Sorcerer Spells - GURPS - World of Aletheia';
const description = 'Comprehensive reference for sorcerer spells in the World of Aletheia.';

let spellTypes: string[] = [];
let sourceSpellTypes: string[] = [];
let totalSpells = 0;
let unavailableMessage: string | null = null;

const emptyFilters = {
  q: '',
  name: '',
  type: '',
  sourceName: '',
  sourceType: '',
};

try {
  // TODO: We only need the total spell count here, but the contract has no
  // dedicated count/HEAD endpoint, so we issue a 1-item list query. If the
  // public spell API ever grows /spell-count or supports pageSize=0, switch to
  // that to avoid serializing one unused spell payload on every page render.
  const [resolvedSpellTypes, firstSpellPage] = await Promise.all([
    listSpellTypes(),
    listSpells({ page: 1, pageSize: 1 }),
  ]);

  spellTypes = resolvedSpellTypes;
  totalSpells = firstSpellPage.total;
} catch (error) {
  if (!isPublicSpellApiError(error)) {
    throw error;
  }

  Astro.response.status = error.status;
  if (error.retryAfter) {
    Astro.response.headers.set('Retry-After', error.retryAfter);
  }

  unavailableMessage = error.message;
}

if (!unavailableMessage) {
  try {
    sourceSpellTypes = sortSpellTypeLabels(await listSourceSpellTypes());
  } catch (error) {
    if (!isPublicSpellApiError(error)) {
      throw error;
    }
  }
}
---

<Layout title={title} description={description}>
  <div class="max-w-6xl">
    <h1 class="mb-6 text-5xl font-bold text-ink-950 drop-shadow-lg lg:text-6xl">Sorcerer Spells</h1>
    <p class="mb-8 text-lg text-ink-800 drop-shadow-md">Comprehensive reference for sorcerer spells in the World of Aletheia.</p>

    <section class="ui-surface mb-8 border-2 border-primary/35 p-6">
      <h2 class="mb-3 text-lg font-semibold text-ink-950">Spell Source Attribution</h2>
      <p class="mb-3 text-ink-800">
        These {totalSpells} sorcerer spells are sourced from the <strong>Generic Universal Eggplant</strong> blog, an excellent resource for GURPS spell variants and homebrew content.
      </p>
      <p class="mb-4 text-ink-800">
        <strong>Source:</strong>
        {' '}
        <a href="https://enragedeggplant.blogspot.com/" target="_blank" class="font-semibold text-primary transition-colors hover:text-secondary">
          Generic Universal Eggplant - Sorcery Spells
        </a>
      </p>
      <p class="text-sm text-ink-800">
        The spells have been organized and integrated into this site to provide easy reference for World of Aletheia campaigns.
      </p>
    </section>

    {unavailableMessage ? (
      <section class="ui-surface ui-surface--glass mb-8 p-6">
        <h2 class="mb-4 text-2xl font-semibold text-ink-950">Spell Catalog Unavailable</h2>
        <p class="text-ink-800">{unavailableMessage}</p>
      </section>
    ) : (
      <>
        <section class="ui-surface ui-surface--glass mb-8 p-6">
          <h2 class="mb-4 text-2xl font-semibold text-ink-950">Find Spells</h2>
          <p class="mb-5 text-ink-800">Search by text, spell name prefix, spell type, or source lineage without leaving the server-rendered spell browser.</p>
          <SpellSearchForm filters={emptyFilters} spellTypes={spellTypes} sourceSpellTypes={sourceSpellTypes} clearHref={getSpellListPageHref(1)} />
        </section>

        <SpellListStatusPanel className="mb-8" />

        <section class="ui-surface ui-surface--glass mb-8 p-6">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <h2 class="mb-2 text-2xl font-semibold text-ink-950">Browse by type</h2>
              <p class="text-ink-800">There are {spellTypes.length} spell types available. Type chips now open the unified filtered results view.</p>
            </div>
            <a href={getSpellListPageHref(1)} class="ui-button ui-button--primary">All Spells (Alphabetical)</a>
          </div>

          <details class="mt-6 rounded-[1.25rem] border border-base-300 bg-base-100/70 p-4">
            <summary class="cursor-pointer text-sm font-semibold uppercase tracking-[0.16em] text-ink-700">Open spell type list</summary>
            <div class="mt-4 flex flex-wrap gap-2">
              {spellTypes.map((spellType) => {
                return (
                  <a href={getSpellListPageHref(1, { type: spellType })} class="ui-button ui-button--secondary ui-button--sm">
                    {spellType}
                  </a>
                );
              })}
            </div>
          </details>
        </section>
      </>
    )}

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <a href="/systems/gurps/resources" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">Back to Resources</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">View all GURPS resources.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">Back</span>
      </a>

      <a href="/systems/gurps" class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100/92 p-5 shadow-sm backdrop-blur-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
        <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">GURPS Home</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Back to the GURPS campaign guide.</p>
        <span class="mt-auto pt-6 text-sm font-semibold text-primary">Home</span>
      </a>
    </div>
  </div>

  <SpellListClientScript />
</Layout>
