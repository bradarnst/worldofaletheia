---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';

const sent = Astro.url.searchParams.get('sent') === '1';
---

<MainSiteLayout
  title="Forgot password - World of Aletheia"
  description="Request password reset instructions for World of Aletheia."
  robots="noindex,nofollow"
>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div class="ui-surface p-6 md:p-8">
      <h1 class="mb-4 text-3xl font-bold text-ink-950 md:text-4xl">Forgot password?</h1>
      {sent && (
        <p class="alert alert-success mb-6 text-sm" role="status">
          If an account exists for that email, we’ll send password reset instructions.
        </p>
      )}
      <form action="/api/auth/request-password-reset" method="POST" class="space-y-4">
        <label class="ui-field w-full">
          <span class="ui-field-label">Email</span>
          <input type="email" name="email" required class="ui-field-control" autocomplete="email" />
        </label>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <button type="submit" class="ui-button ui-button--primary">Send reset link</button>
          <a href="/login" class="ui-button ui-button--secondary">Back to sign in</a>
        </div>
      </form>
    </div>
  </section>
</MainSiteLayout>
