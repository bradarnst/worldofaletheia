---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';
---

<MainSiteLayout
  title="Forgot password - World of Aletheia"
  description="Request password reset instructions for World of Aletheia."
  robots="noindex,nofollow"
>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div class="ui-surface p-6 md:p-8">
      <h1 class="mb-4 text-3xl font-bold text-ink-950 md:text-4xl">Forgot password?</h1>
      <p id="forgot-password-status" class="mb-6 text-sm text-ink-800" aria-live="polite">
        Enter your account email and we’ll send password reset instructions if the account can use email/password sign-in.
      </p>
      <form id="forgot-password-form" class="space-y-4">
        <label class="ui-field w-full">
          <span class="ui-field-label">Email</span>
          <input type="email" name="email" required class="ui-field-control" autocomplete="email" />
        </label>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <button type="submit" class="ui-button ui-button--primary">Send reset link</button>
          <a href="/login" class="ui-button ui-button--secondary">Back to sign in</a>
        </div>
      </form>
    </div>
  </section>
</MainSiteLayout>

<script>
  const form = document.getElementById('forgot-password-form') as HTMLFormElement | null;
  const status = document.getElementById('forgot-password-status');

  function setStatus(message: string, tone: 'info' | 'ok' | 'error' = 'info') {
    if (!status) return;
    status.textContent = message;
    status.className = tone === 'ok'
      ? 'alert alert-success mb-6 text-sm'
      : tone === 'error'
        ? 'alert alert-warning mb-6 text-sm'
        : 'mb-6 text-sm text-ink-800';
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const formData = new FormData(form);
    const email = String(formData.get('email') ?? '');
    const redirectTo = new URL('/reset-password', window.location.origin).toString();

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
    }

    try {
      await fetch('/api/auth/request-password-reset', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, redirectTo }),
      });

      setStatus('If an account exists for that email, we’ll send password reset instructions.', 'ok');
      form.reset();
    } catch {
      setStatus('If an account exists for that email, we’ll send password reset instructions.', 'ok');
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = 'Send reset link';
      }
    }
  });
</script>
