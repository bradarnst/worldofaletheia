---
import { getCollection } from 'astro:content';
import CalendarAgendaList from '@components/calendar/CalendarAgendaList.astro';
import CalendarDayAgenda from '@components/calendar/CalendarDayAgenda.astro';
import CalendarEclipseLegend from '@components/calendar/CalendarEclipseLegend.astro';
import EclipseMarkerIcon from '@components/calendar/EclipseMarkerIcon.astro';
import AletheiaMonthGrid from '@components/calendar/AletheiaMonthGrid.astro';
import MoonPhaseIcon from '@components/calendar/MoonPhaseIcon.astro';
import ReferenceLayout from '@layouts/ReferenceLayout.astro';
import { getFilteredCollection } from '@utils/content-filter';
import {
  MONTHS,
  buildCalendarDayData,
  buildEclipseProjectionMapForYearRange,
  buildCalendarMonthData,
  buildCalendarWeekData,
  buildCalendarYearData,
  buildEventProjectionMap,
  formatAletheiaDate,
  formatAletheiaDateLabel,
  getMonthReferenceDate,
  getNextMonthDate,
  getPreviousMonthDate,
  getYearNavigationDate,
  getYearViewYear,
  normalizeLoreEvents,
  resolveCalendarSelection,
  shiftAletheiaDate,
  type AletheiaDate,
  type CalendarView,
  type EnrichedAletheiaDate,
} from '~/lib/aletheia-calendar';

type AgendaMode = 'day' | 'week' | 'month' | 'year';

interface AgendaBadge {
  label: string;
  tone?: 'default' | 'warning';
}

interface AgendaEntry {
  title: string;
  href?: string;
  meta?: string;
  excerpt?: string;
  badges?: AgendaBadge[];
}

interface AgendaGroup {
  title: string;
  subtitle?: string;
  badges?: AgendaBadge[];
  entries: AgendaEntry[];
  emptyText?: string;
}

function buildCalendarHref(view: CalendarView, date: AletheiaDate, options: { agenda?: AgendaMode | null } = {}): string {
  const searchParams = new URLSearchParams({
    view,
    year: String(date.year),
  });

  if (date.kind === 'month') {
    searchParams.set('month', String(date.monthIndex));
    searchParams.set('day', String(date.day));
    searchParams.set('date', formatAletheiaDate(date));
  } else {
    searchParams.set('date', formatAletheiaDate(date));
  }

  if (options.agenda) {
    searchParams.set('agenda', options.agenda);
  }

  return `/references/calendar?${searchParams.toString()}`;
}

function buildTimelineHref(date: AletheiaDate): string {
  const searchParams = new URLSearchParams({
    year: String(date.year),
    date: formatAletheiaDate(date),
  });

  if (date.kind === 'month') {
    searchParams.set('month', String(date.monthIndex));
    searchParams.set('day', String(date.day));
  }

  return `/references/timeline?${searchParams.toString()}`;
}

function getWeekNavigationDate(date: AletheiaDate, deltaWeeks: number): AletheiaDate {
  return shiftAletheiaDate(date, deltaWeeks * 6);
}

const loreEntries = getFilteredCollection(await getCollection('lore'));
const loreEvents = normalizeLoreEvents(loreEntries.filter((entry) => entry.data.type === 'event'));
const eventProjectionMap = buildEventProjectionMap(loreEvents);

const selection = resolveCalendarSelection(Astro.url.searchParams);
const selectedDate = selection.date;
const agendaParam = Astro.url.searchParams.get('agenda');
const agendaMode: AgendaMode | null = agendaParam === 'day' || agendaParam === 'week' || agendaParam === 'month' || agendaParam === 'year'
  ? agendaParam
  : null;
const isAgendaMode = agendaMode !== null;
const activeGranularity = isAgendaMode ? agendaMode : selection.view;
const eclipseProjectionMap = buildEclipseProjectionMapForYearRange(selectedDate.year - 1, selectedDate.year + 1);
const selectedDayData = buildCalendarDayData(selectedDate, eventProjectionMap, eclipseProjectionMap);
const selectedEnrichedDate = selectedDayData.date;
const monthReferenceDate = getMonthReferenceDate(selectedDate);

const monthData = buildCalendarMonthData(monthReferenceDate.year, monthReferenceDate.monthIndex, eventProjectionMap, eclipseProjectionMap);
const weekData = buildCalendarWeekData(selectedDate, eventProjectionMap, eclipseProjectionMap);
const yearData = buildCalendarYearData(getYearViewYear(selectedDate), eventProjectionMap, eclipseProjectionMap);
const yearEclipseCount = yearData.reduce((total, month) => total + month.eclipseSummary.eclipseCount, 0);
const yearSolarCount = yearData.reduce((total, month) => total + month.eclipseSummary.solarCount, 0);
const yearLunarCount = yearData.reduce((total, month) => total + month.eclipseSummary.lunarCount, 0);

const previousHref = selection.view === 'week'
  ? buildCalendarHref('week', getWeekNavigationDate(selectedDate, -1), { agenda: agendaMode })
  : selection.view === 'year'
    ? buildCalendarHref('year', getYearNavigationDate(selectedDate, -1), { agenda: agendaMode })
    : buildCalendarHref('month', getPreviousMonthDate(selectedDate), { agenda: agendaMode });
const nextHref = selection.view === 'week'
  ? buildCalendarHref('week', getWeekNavigationDate(selectedDate, 1), { agenda: agendaMode })
  : selection.view === 'year'
    ? buildCalendarHref('year', getYearNavigationDate(selectedDate, 1), { agenda: agendaMode })
    : buildCalendarHref('month', getNextMonthDate(selectedDate), { agenda: agendaMode });

const monthSelectValue = selectedDate.kind === 'month' ? String(selectedDate.monthIndex) : String(monthReferenceDate.monthIndex);
const dayInputValue = selectedDate.kind === 'month' ? String(selectedDate.day) : String(monthReferenceDate.day);
const currentViewDateHref = (date: AletheiaDate) => buildCalendarHref(selection.view, date, { agenda: agendaMode });
const buildAgendaHref = (mode: AgendaMode) => `${buildCalendarHref(selection.view, selectedDate, { agenda: mode })}#calendar-agenda`;
const clearAgendaHref = buildCalendarHref(selection.view, selectedDate);
const agendaDefaultMode: AgendaMode = agendaMode ?? selection.view;
const agendaToggleHref = buildAgendaHref(agendaDefaultMode);
const dayAgendaPreviousHref = `${buildCalendarHref(selection.view, shiftAletheiaDate(selectedDate, -1), { agenda: 'day' })}#calendar-agenda`;
const dayAgendaNextHref = `${buildCalendarHref(selection.view, shiftAletheiaDate(selectedDate, 1), { agenda: 'day' })}#calendar-agenda`;
const weekAgendaPreviousHref = `${buildCalendarHref('week', getWeekNavigationDate(selectedDate, -1), { agenda: 'week' })}#calendar-agenda`;
const weekAgendaNextHref = `${buildCalendarHref('week', getWeekNavigationDate(selectedDate, 1), { agenda: 'week' })}#calendar-agenda`;
const monthAgendaPreviousHref = `${buildCalendarHref('month', getPreviousMonthDate(selectedDate), { agenda: 'month' })}#calendar-agenda`;
const monthAgendaNextHref = `${buildCalendarHref('month', getNextMonthDate(selectedDate), { agenda: 'month' })}#calendar-agenda`;
const yearAgendaPreviousHref = `${buildCalendarHref('year', getYearNavigationDate(selectedDate, -1), { agenda: 'year' })}#calendar-agenda`;
const yearAgendaNextHref = `${buildCalendarHref('year', getYearNavigationDate(selectedDate, 1), { agenda: 'year' })}#calendar-agenda`;
const calendarModeOptions = [
  { value: 'month', label: 'Month' },
  { value: 'week', label: 'Week' },
  { value: 'year', label: 'Year' },
] as const;
const agendaModeOptions = [
  { value: 'day', label: 'Day' },
  { value: 'week', label: 'Week' },
  { value: 'month', label: 'Month' },
  { value: 'year', label: 'Year' },
] as const;

function getDateBadges(date: EnrichedAletheiaDate, eclipseCount: number): AgendaBadge[] {
  const badges: AgendaBadge[] = [];

  if (date.kind === 'leapday') {
    badges.push({ label: 'FLD', tone: 'warning' });
  }

  if (date.kind === 'month' && date.isFestivalDay) {
    badges.push({ label: `F${date.festivalDayNumber}`, tone: 'warning' });
  }

  if (eclipseCount > 0) {
    badges.push({ label: `${eclipseCount} eclipse${eclipseCount === 1 ? '' : 's'}` });
  }

  return badges;
}

const weekAgendaGroups: AgendaGroup[] = weekData.items.map((item) => ({
  title: formatAletheiaDateLabel(item.date),
  badges: getDateBadges(item.date, item.eclipses.length),
  entries: item.events.map((event) => ({
    title: event.title,
    href: event.href,
    meta: event.isSingleDay ? formatAletheiaDateLabel(event.startDate) : `${formatAletheiaDateLabel(event.startDate)} to ${formatAletheiaDateLabel(event.endDate)}`,
    excerpt: event.excerpt,
    badges: event.isSingleDay ? [] : [{ label: `${event.durationDays} days` }],
  })),
  emptyText: item.eclipses.length > 0 ? 'No projected lore events on this day.' : 'No projected lore events on this day.',
}));

const monthAgendaGroups: AgendaGroup[] = monthData.slots
  .filter((slot): slot is Exclude<typeof monthData.slots[number], { kind: 'empty' }> => slot.kind !== 'empty')
  .filter((slot) => slot.events.length > 0 || slot.eclipses.length > 0 || slot.date.absDay === selectedEnrichedDate.absDay)
  .map((slot) => ({
    title: formatAletheiaDateLabel(slot.date),
    badges: getDateBadges(slot.date, slot.eclipses.length),
    entries: slot.events.map((event) => ({
      title: event.title,
      href: event.href,
      meta: event.isSingleDay ? formatAletheiaDateLabel(event.startDate) : `${formatAletheiaDateLabel(event.startDate)} to ${formatAletheiaDateLabel(event.endDate)}`,
      excerpt: event.excerpt,
      badges: event.isSingleDay ? [] : [{ label: `${event.durationDays} days` }],
    })),
    emptyText: slot.eclipses.length > 0 ? 'No projected lore events on this date.' : 'No projected lore events on this date.',
  }));

const yearAgendaGroups: AgendaGroup[] = yearData
  .filter((month) => month.eventCount > 0 || month.eclipseSummary.eclipseCount > 0 || month.leapDayPlacement !== null)
  .map((month) => ({
    title: `${month.monthName} ${month.year}`,
    badges: [
      ...(month.leapDayPlacement ? [{ label: 'FLD', tone: 'warning' as const }] : []),
      ...(month.eclipseSummary.eclipseCount > 0 ? [{ label: `${month.eclipseSummary.eclipseCount} eclipse${month.eclipseSummary.eclipseCount === 1 ? '' : 's'}` }] : []),
    ],
    entries: month.slots
      .filter((slot): slot is Exclude<typeof month.slots[number], { kind: 'empty' }> => slot.kind !== 'empty')
      .filter((slot) => slot.events.length > 0 || slot.eclipses.length > 0 || slot.kind === 'leapday')
      .map((slot) => ({
        title: formatAletheiaDateLabel(slot.date),
        href: buildCalendarHref('month', slot.date, { agenda: 'day' }),
        meta: slot.events.length > 0 ? `${slot.events.length} event${slot.events.length === 1 ? '' : 's'}` : 'No projected lore events',
        badges: getDateBadges(slot.date, slot.eclipses.length),
      })),
    emptyText: 'No notable dates in this month.',
  }));
---

<ReferenceLayout title="Aletheia Calendar - Reference" description="View the civic calendar of Aletheia by month, week, or year.">
  <section class="space-y-6">
    <div class="grid gap-4 xl:grid-cols-[minmax(0,1.8fr)_minmax(320px,1fr)]">
      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body gap-3">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="space-y-1">
              <h2 class="text-xl font-semibold text-ink-950">Calendar</h2>
              <p class="text-sm text-ink-800 md:text-base">
                Twelve 31-day months, a six-day week, Leap Day, projected lore events, and eclipse markers.
              </p>
            </div>

            <div class="flex items-center gap-2">
              <div class="join" aria-label="Display mode">
                <a
                  href={clearAgendaHref}
                  class:list={['btn btn-xs join-item js-calendar-display-toggle', !isAgendaMode ? 'btn-primary' : 'btn-outline']}
                  title="Show calendar view"
                  aria-label="Show calendar view"
                  data-display-mode="calendar"
                >
                  Cal
                </a>
                <a
                  href={agendaToggleHref}
                  class:list={['btn btn-xs join-item js-calendar-display-toggle', isAgendaMode ? 'btn-primary' : 'btn-outline']}
                  title="Show agenda view"
                  aria-label="Show agenda view"
                  data-display-mode="agenda"
                >
                  Ag
                </a>
              </div>
              <a href={buildTimelineHref(selectedDate)} class="btn btn-sm btn-outline">Timeline</a>
            </div>
          </div>

          <CalendarEclipseLegend />

          <form method="get" class="grid gap-3 md:grid-cols-2 xl:grid-cols-[minmax(7rem,9rem)_minmax(7rem,1fr)_minmax(10rem,1fr)_auto_auto] xl:items-end js-calendar-control-form" data-display-mode={isAgendaMode ? 'agenda' : 'calendar'} data-active-granularity={activeGranularity}>
            {isAgendaMode && <input type="hidden" name="view" value={agendaMode === 'day' ? 'month' : agendaMode} class="js-calendar-view-input" />}
            <label class="form-control gap-2">
              <span class="label-text font-semibold text-ink-800">{isAgendaMode ? 'Agenda' : 'View'}</span>
              <select
                name={isAgendaMode ? 'agenda' : 'view'}
                class="select select-bordered w-full js-calendar-granularity"
                data-display-mode={isAgendaMode ? 'agenda' : 'calendar'}
              >
                {(isAgendaMode ? agendaModeOptions : calendarModeOptions).map((option) => (
                  <option value={option.value} selected={activeGranularity === option.value}>{option.label}</option>
                ))}
              </select>
            </label>

            <label class="form-control gap-2">
              <span class="label-text font-semibold text-ink-800">Year</span>
              <input name="year" type="number" min="0" value={selectedDate.year} class="input input-bordered w-full" />
            </label>

            <label class="form-control gap-2">
              <span class="label-text font-semibold text-ink-800">Month</span>
              <select name="month" class="select select-bordered w-full">
                {MONTHS.map((monthName, index) => (
                  <option value={index + 1} selected={monthSelectValue === String(index + 1)}>
                    {index + 1} - {monthName}
                  </option>
                ))}
              </select>
            </label>

            <label class="form-control gap-2">
              <span class="label-text font-semibold text-ink-800">Day</span>
              <input name="day" type="number" min="1" max="31" value={dayInputValue} class="input input-bordered w-full" />
            </label>

            <button type="submit" class="btn btn-primary">Go</button>
          </form>
        </div>
      </div>

      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body gap-3">
          <h2 class="text-lg font-semibold text-ink-950">{formatAletheiaDateLabel(selectedEnrichedDate)}</h2>

          <div class="flex flex-wrap gap-2 text-sm">
            <span class="badge badge-outline">{selectedEnrichedDate.weekday}</span>
            <span class="badge badge-outline gap-2">
              <MoonPhaseIcon label={selectedEnrichedDate.moonPhaseLabel} size={14} />
              {selectedEnrichedDate.moonPhaseLabel}
            </span>
            {selectedEnrichedDate.kind === 'month' && selectedEnrichedDate.isFestivalDay && (
              <span class="badge badge-warning">Festival Day {selectedEnrichedDate.festivalDayNumber}</span>
            )}
            {selectedEnrichedDate.kind === 'leapday' && <span class="badge badge-warning">FLD</span>}
            {selectedDayData.eclipseSummary.solarCount > 0 && <span class="badge badge-warning gap-1"><EclipseMarkerIcon kind="solar" size={12} />Solar eclipse occurs</span>}
            {selectedDayData.eclipseSummary.lunarCount > 0 && <span class="badge badge-warning gap-1"><EclipseMarkerIcon kind="lunar" size={12} />Lunar eclipse occurs</span>}
          </div>

        </div>
      </div>
    </div>

    {!isAgendaMode && selection.view === 'month' && (
      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body gap-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <a href={previousHref} class="btn btn-sm btn-outline">Previous month</a>
            <div class="text-center">
              <h2 class="text-xl font-semibold text-ink-950">{monthData.monthName} {monthData.year}</h2>
            </div>
            <a href={nextHref} class="btn btn-sm btn-outline">Next month</a>
          </div>

          <div class="flex justify-end">
            <div class="flex flex-wrap items-center justify-end gap-2">
              {monthData.eclipseSummary.eclipseCount > 0 && (
                <>
                  {monthData.eclipseSummary.solarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="solar" size={12} />{monthData.eclipseSummary.solarCount}</span>}
                  {monthData.eclipseSummary.lunarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="lunar" size={12} />{monthData.eclipseSummary.lunarCount}</span>}
                </>
              )}
              <span class="badge badge-outline">{monthData.eventCount} dated lore events</span>
            </div>
          </div>

          <AletheiaMonthGrid month={monthData} selectedAbsDay={selectedEnrichedDate.absDay} getDateHref={currentViewDateHref} />
        </div>
      </div>
    )}

    {!isAgendaMode && selection.view === 'week' && (
      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body gap-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <a href={previousHref} class="btn btn-sm btn-outline">Previous week</a>
            <div class="text-center">
              <h2 class="text-xl font-semibold text-ink-950">Around {formatAletheiaDateLabel(selectedEnrichedDate)}</h2>
            </div>
            <a href={nextHref} class="btn btn-sm btn-outline">Next week</a>
          </div>

          <div class="grid gap-4 xl:grid-cols-6">
            {weekData.items.map((item) => (
              <article class:list={[
                'card border shadow-sm',
                item.date.absDay === selectedEnrichedDate.absDay ? 'border-primary bg-base-100 ring-1 ring-primary/40' : 'border-base-300 bg-base-100',
                item.date.kind === 'leapday' ? 'bg-warning/10' : '',
              ]}>
                <div class="card-body gap-3 p-4">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700">{item.date.weekday}</p>
                    <h3 class="mt-1 text-lg font-bold text-ink-950">
                      <a href={buildCalendarHref('week', item.date, { agenda: agendaMode })} class="transition-colors hover:text-primary">
                        {item.date.kind === 'month' ? `${item.date.monthName} ${item.date.day}` : 'Leap Day'}
                      </a>
                    </h3>
                    <p class="text-sm text-ink-700">Year {item.date.year}</p>
                  </div>
                  <div class="flex flex-wrap gap-2 text-xs">
                    <span class="badge badge-outline gap-2">
                      <MoonPhaseIcon label={item.date.moonPhaseLabel} size={14} />
                      {item.date.moonPhaseLabel}
                    </span>
                    {item.date.kind === 'month' && item.date.isFestivalDay && <span class="badge badge-warning">Festival {item.date.festivalDayNumber}</span>}
                    {item.date.kind === 'leapday' && <span class="badge badge-warning">FLD</span>}
                    {item.eclipses.length > 0 && (
                      <span class="inline-flex items-center gap-1 rounded-full border border-warning/40 bg-base-100 px-2 py-1 text-warning">
                        {item.eclipses.map((eclipse) => (
                          <span title={`${eclipse.kind} eclipse occurs`}>
                            <EclipseMarkerIcon kind={eclipse.kind} size={11} />
                            <span class="sr-only">{eclipse.kind} eclipse occurs</span>
                          </span>
                        ))}
                      </span>
                    )}
                  </div>
                  <div class="space-y-2 text-sm text-ink-800">
                    {item.events.length > 0 ? item.events.slice(0, 3).map((event) => (
                      <a href={event.href} class="block rounded-lg border border-base-300 bg-base-200/60 px-2 py-1 transition-colors hover:border-primary">
                        {event.title}
                      </a>
                    )) : <p>No events.</p>}
                  </div>
                </div>
              </article>
            ))}
          </div>
          {weekData.eclipseSummary.eclipseCount > 0 && (
            <div class="flex justify-end">
              <div class="flex flex-wrap items-center gap-2">
                {weekData.eclipseSummary.solarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="solar" size={12} />{weekData.eclipseSummary.solarCount}</span>}
                {weekData.eclipseSummary.lunarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="lunar" size={12} />{weekData.eclipseSummary.lunarCount}</span>}
              </div>
            </div>
          )}
        </div>
      </div>
    )}

    {!isAgendaMode && selection.view === 'year' && (
      <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body gap-6">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <a href={previousHref} class="btn btn-sm btn-outline">Previous year</a>
            <div class="text-center">
              <h2 class="text-xl font-semibold text-ink-950">Year {getYearViewYear(selectedDate)}</h2>
            </div>
            <a href={nextHref} class="btn btn-sm btn-outline">Next year</a>
          </div>

          <div class="flex justify-end">
            <div class="flex flex-wrap items-center justify-end gap-2">
              {yearEclipseCount > 0 && (
                <>
                  {yearSolarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="solar" size={12} />{yearSolarCount}</span>}
                  {yearLunarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="lunar" size={12} />{yearLunarCount}</span>}
                </>
              )}
              <a href={buildTimelineHref(selectedDate)} class="btn btn-sm btn-outline">View timeline from this year</a>
            </div>
          </div>

          <div class="grid gap-6 xl:grid-cols-2">
            {yearData.map((yearMonth) => (
              <section class="rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm">
                <div class="mb-4 flex items-start justify-between gap-3">
                  <div>
                    <a href={buildCalendarHref('month', { kind: 'month', year: yearMonth.year, monthIndex: yearMonth.monthIndex, monthName: yearMonth.monthName, day: 1 }, { agenda: agendaMode })} class="inline-flex items-center gap-2 rounded-lg px-2 py-1 -mx-2 text-lg font-semibold text-ink-950 transition-colors hover:bg-base-200 hover:text-primary">
                      {yearMonth.monthName}
                      <span class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-ink-700">Open</span>
                    </a>
                    {yearMonth.eclipseSummary.eclipseCount > 0 && (
                      <div class="mt-2 flex flex-wrap gap-2">
                        {yearMonth.eclipseSummary.solarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="solar" size={12} />{yearMonth.eclipseSummary.solarCount}</span>}
                        {yearMonth.eclipseSummary.lunarCount > 0 && <span class="badge badge-outline gap-1"><EclipseMarkerIcon kind="lunar" size={12} />{yearMonth.eclipseSummary.lunarCount}</span>}
                      </div>
                    )}
                  </div>
                  <span class="badge badge-outline">{yearMonth.eventCount} events</span>
                </div>
                <AletheiaMonthGrid month={yearMonth} compact={true} selectedAbsDay={monthReferenceDate.year === yearMonth.year && monthReferenceDate.monthIndex === yearMonth.monthIndex ? selectedEnrichedDate.absDay : undefined} />
              </section>
            ))}
          </div>
        </div>
      </div>
    )}

    {agendaMode === 'day' && (
      <CalendarDayAgenda
        day={selectedDayData}
        closeHref={clearAgendaHref}
        previousHref={dayAgendaPreviousHref}
        nextHref={dayAgendaNextHref}
      />
    )}

    {agendaMode === 'week' && (
      <CalendarAgendaList
        title="Week agenda"
        description="Full event list for the six civic days in the active week."
        groups={weekAgendaGroups}
        emptyMessage="No projected lore events fall within this week."
        closeHref={clearAgendaHref}
        previousHref={weekAgendaPreviousHref}
        previousLabel="Previous week"
        nextHref={weekAgendaNextHref}
        nextLabel="Next week"
      />
    )}

    {agendaMode === 'month' && (
      <CalendarAgendaList
        title={`${monthData.monthName} agenda`}
        description="Full month agenda for selected and notable dates."
        groups={monthAgendaGroups}
        emptyMessage="No projected lore events or eclipses fall within this month."
        closeHref={clearAgendaHref}
        previousHref={monthAgendaPreviousHref}
        previousLabel="Previous month"
        nextHref={monthAgendaNextHref}
        nextLabel="Next month"
      />
    )}

    {agendaMode === 'year' && (
      <CalendarAgendaList
        title={`Year ${getYearViewYear(selectedDate)} agenda`}
        description="Month-by-month summary of notable dates across the active year."
        groups={yearAgendaGroups}
        emptyMessage="No projected lore events or eclipses fall within this year."
        closeHref={clearAgendaHref}
        previousHref={yearAgendaPreviousHref}
        previousLabel="Previous year"
        nextHref={yearAgendaNextHref}
        nextLabel="Next year"
      />
    )}
  </section>

  <script is:inline>
    (() => {
      const DISPLAY_KEY = 'aletheia-calendar-display-mode';
      const CALENDAR_VIEW_KEY = 'aletheia-calendar-view';
      const AGENDA_VIEW_KEY = 'aletheia-calendar-agenda-view';
      const allowedCalendarViews = ['month', 'week', 'year'];
      const allowedAgendaViews = ['day', 'week', 'month', 'year'];
      const path = window.location.pathname;

      if (path !== '/references/calendar') {
        return;
      }

      const url = new URL(window.location.href);
      const form = document.querySelector('.js-calendar-control-form');
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      const currentDisplayMode = form.dataset.displayMode === 'agenda' ? 'agenda' : 'calendar';
      const currentGranularity = form.dataset.activeGranularity || 'month';
      const granularitySelect = form.querySelector('.js-calendar-granularity');
      const hiddenViewInput = form.querySelector('.js-calendar-view-input');

      const savePreference = (displayMode, granularity) => {
        try {
          localStorage.setItem(DISPLAY_KEY, displayMode);
          if (displayMode === 'agenda' && allowedAgendaViews.includes(granularity)) {
            localStorage.setItem(AGENDA_VIEW_KEY, granularity);
          }
          if (displayMode === 'calendar' && allowedCalendarViews.includes(granularity)) {
            localStorage.setItem(CALENDAR_VIEW_KEY, granularity);
          }
        } catch {
          // Ignore storage access issues
        }
      };

      savePreference(currentDisplayMode, currentGranularity);

      if (!url.search) {
        try {
          const savedDisplay = localStorage.getItem(DISPLAY_KEY);
          const savedCalendarView = localStorage.getItem(CALENDAR_VIEW_KEY);
          const savedAgendaView = localStorage.getItem(AGENDA_VIEW_KEY);

          if (savedDisplay === 'agenda') {
            const agenda = allowedAgendaViews.includes(savedAgendaView || '') ? savedAgendaView : 'month';
            const view = agenda === 'day' ? 'month' : agenda;
            url.searchParams.set('view', view);
            url.searchParams.set('agenda', agenda);
            window.location.replace(url.toString());
            return;
          }

          if (savedDisplay === 'calendar' && allowedCalendarViews.includes(savedCalendarView || '') && savedCalendarView !== 'month') {
            url.searchParams.set('view', savedCalendarView);
            window.location.replace(url.toString());
            return;
          }
        } catch {
          // Ignore storage access issues
        }
      }

      document.querySelectorAll('.js-calendar-display-toggle').forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) {
          return;
        }

        link.addEventListener('click', () => {
          const displayMode = link.dataset.displayMode === 'agenda' ? 'agenda' : 'calendar';
          const granularity = displayMode === 'agenda'
            ? (allowedAgendaViews.includes(currentGranularity) ? currentGranularity : 'month')
            : (allowedCalendarViews.includes(currentGranularity) ? currentGranularity : 'month');
          savePreference(displayMode, granularity);
        });
      });

      form.addEventListener('submit', () => {
        if (!(granularitySelect instanceof HTMLSelectElement)) {
          return;
        }

        const mode = form.dataset.displayMode === 'agenda' ? 'agenda' : 'calendar';
        const granularity = granularitySelect.value;

        if (mode === 'agenda' && hiddenViewInput instanceof HTMLInputElement) {
          hiddenViewInput.value = granularity === 'day' ? 'month' : granularity;
        }

        savePreference(mode, granularity);
      });
    })();
  </script>
</ReferenceLayout>
