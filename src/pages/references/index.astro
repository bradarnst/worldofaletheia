---
import ReferenceLayout from '@layouts/ReferenceLayout.astro';

const referenceCards = [
  {
    href: '/references/calendar',
    title: 'Calendar',
    description: 'Civic dates, direct date lookup, date math, festivals, and lunar rhythm.',
    cta: 'Open calendar',
  },
  {
    href: '/references/timeline',
    title: 'Timeline',
    description: 'Chronological lore browsing built from dated events and shared calendar indexing.',
    cta: 'Open timeline',
  },
  {
    href: '/references/maps',
    title: 'Maps',
    description: 'World-scale map surfaces for terrain, rivers, and biomes, with richer regional viewers to come later.',
    cta: 'Open maps',
  },
];
---

<ReferenceLayout
  title="Reference - World of Aletheia"
  description="Shared world-reference surfaces for chronology, lookup, and map context."
>
  <section class="space-y-6">
    <div class="ui-surface p-5">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold text-ink-950">What lives in Reference</h2>
        <p class="text-sm text-ink-800 md:text-base">
          Use Reference when you need inspection, lookup, or visualization of shared world knowledge rather than browsing authored Canon or Using Aletheia collections.
        </p>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {referenceCards.map((card) => (
        <article class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100 p-5 shadow-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
          <div class="flex-1 space-y-4">
            <div class="space-y-2">
              <h2 class="text-2xl font-semibold text-ink-950 transition-colors group-hover:text-primary">{card.title}</h2>
              <p class="text-sm text-ink-800 md:text-base">{card.description}</p>
            </div>
            <div class="flex justify-end">
              <a href={card.href} class="ui-button ui-button--primary ui-button--sm">{card.cta}</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</ReferenceLayout>
