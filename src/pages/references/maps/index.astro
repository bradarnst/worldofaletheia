---
import { Image } from 'astro:assets';
import ReferenceLayout from '@layouts/ReferenceLayout.astro';
import biomeMap from '@images/Aletheia-biomes-2026-02-10-19-21.jpeg';
import heightAndRiversMap from '@images/Aletheia_height-rivers_2026-02-07-07-24.jpeg';

const mapCards = [
  {
    title: 'Biomes',
    image: biomeMap,
    alt: 'Biome map of Aletheia showing broad ecological regions across the world.',
    description: 'A broad ecological read of the world. Use this map to orient climate, vegetation, travel expectations, and the rough environmental character of a region.',
    uses: [
      'Compare ecological zones across distant regions',
      'Ground flora, fauna, and travel assumptions',
      'Support lore reading with environmental context',
    ],
  },
  {
    title: 'Height and rivers',
    image: heightAndRiversMap,
    alt: 'Terrain and river map of Aletheia showing elevation patterns and major waterways.',
    description: 'A terrain-first surface for reading elevation, watersheds, and the shape of movement across the world. This is the better map for understanding natural barriers and routes.',
    uses: [
      'Trace mountain ranges, lowlands, and drainage',
      'Understand likely travel corridors and obstacles',
      'Add physical geography context to places and campaigns',
    ],
  },
];
---

<ReferenceLayout
  title="Maps - Reference"
  description="Curated world map surfaces for terrain, rivers, and biomes across Aletheia."
>
  <section class="space-y-6">
    <div class="ui-surface p-6 md:p-8">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)] lg:items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-600">World maps</p>
          <h2 class="mt-3 text-3xl font-semibold text-ink-950">Cartographic reference for the world as a whole.</h2>
          <p class="mt-4 text-sm leading-8 text-ink-800 md:text-base">
            Maps now provides a usable world-reference surface rather than a placeholder route. Current coverage is intentionally narrow but practical: one map for ecological reading and one for terrain and river structure.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/places" class="ui-button ui-button--primary">Browse places</a>
            <a href="/lore" class="ui-button ui-button--secondary">Browse lore</a>
          </div>
        </div>

        <aside class="rounded-2xl border border-base-300/80 bg-base-100/80 p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-600">Coverage notes</p>
          <ul class="mt-3 space-y-2 text-sm leading-7 text-ink-700">
            <li>• Current maps are world-scale reference surfaces.</li>
            <li>• Political overlays, settlement labels, and region-by-region navigation are not published yet.</li>
            <li>• Use these alongside canon entries when you need spatial context rather than article-driven reading.</li>
          </ul>
        </aside>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-2">
      {mapCards.map((card) => (
        <article class="ui-surface overflow-hidden">
          <div class="border-b border-base-300/80 bg-base-100/80 p-5 md:p-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <h2 class="text-2xl font-semibold text-ink-950">{card.title}</h2>
                <p class="mt-2 text-sm leading-7 text-ink-700 md:text-base">{card.description}</p>
              </div>
              <a href={card.image.src} class="ui-button ui-button--secondary ui-button--sm" target="_blank" rel="noreferrer">Open full image</a>
            </div>
          </div>

          <div class="bg-base-200/35 p-4 md:p-5">
            <a href={card.image.src} target="_blank" rel="noreferrer" class="block overflow-hidden rounded-2xl border border-base-300/80 bg-base-100">
              <Image
                src={card.image}
                alt={card.alt}
                width={card.image.width}
                height={card.image.height}
                class="h-auto w-full object-cover"
              />
            </a>
          </div>

          <div class="p-5 md:p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-600">Useful for</p>
            <ul class="mt-3 space-y-2 text-sm leading-7 text-ink-700">
              {card.uses.map((use) => (
                <li>• {use}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="ui-surface ui-surface--muted p-6 md:p-8">
      <h2 class="text-xl font-semibold text-ink-950">How to use this route right now</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-3">
        <div class="rounded-xl border border-base-300/80 bg-base-100/70 p-4">
          <h3 class="font-semibold text-ink-950">Orient the world</h3>
          <p class="mt-2 text-sm leading-7 text-ink-700">Use the two published surfaces to understand environmental regions and physical geography before diving into individual entries.</p>
        </div>
        <div class="rounded-xl border border-base-300/80 bg-base-100/70 p-4">
          <h3 class="font-semibold text-ink-950">Cross-reference canon</h3>
          <p class="mt-2 text-sm leading-7 text-ink-700">When a place or lore article mentions terrain, watershed, distance, or biome, return here for quick spatial grounding.</p>
        </div>
        <div class="rounded-xl border border-base-300/80 bg-base-100/70 p-4">
          <h3 class="font-semibold text-ink-950">Expect more layers later</h3>
          <p class="mt-2 text-sm leading-7 text-ink-700">This is intentionally useful without pretending coverage is complete. Regional, labeled, and richer reference layers can land here later without another route change.</p>
        </div>
      </div>
    </div>
  </section>
</ReferenceLayout>
