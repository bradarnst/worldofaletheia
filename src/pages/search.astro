---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';
import SiteGlyph from '@components/site/SiteGlyph.astro';

interface SearchItem {
  id: string;
  collection: string;
  slug: string;
  href: string;
  title: string;
  summary: string | null;
  type: string | null;
  subtype: string | null;
  tags: string[];
  createdAt: string | null;
  updatedAt: string | null;
}

interface SearchPagination {
  page: number;
  pageSize: number;
  totalItems: number;
  totalPages: number;
  hasPreviousPage: boolean;
  hasNextPage: boolean;
}

type SearchScopeReason =
  | 'guest'
  | 'authenticated_no_memberships'
  | 'authenticated_member_access'
  | 'authenticated_gm_access'
  | 'authorization_unavailable';

interface SearchScope {
  isAuthenticated: boolean;
  visibility: 'public' | 'campaignMembers' | 'gm';
  reason: SearchScopeReason;
  campaignAccess: {
    membershipCount: number;
    gmCount: number;
  };
}

type SearchErrorCode = 'invalid_query' | 'unavailable';

interface SearchSuccessResponse {
  ok: true;
  query: string;
  scope: SearchScope;
  pagination: SearchPagination;
  items: SearchItem[];
}

interface SearchErrorResponse {
  ok: false;
  error: SearchErrorCode;
}

const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const pageParam = Number.parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const page = Number.isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;

let searchResponse: SearchSuccessResponse | SearchErrorResponse | null = null;
let loadError: SearchErrorCode | null = null;

if (query.length >= 2) {
  try {
    const cookie = Astro.request.headers.get('cookie');
    const response = await fetch(new URL(`/api/search?q=${encodeURIComponent(query)}&page=${page}`, Astro.url), {
      headers: cookie ? { cookie } : undefined,
    });
    const payload = await response.json() as SearchSuccessResponse | SearchErrorResponse;

    if (response.ok && payload.ok) {
      searchResponse = payload;
    } else if (!payload.ok) {
      loadError = payload.error;
    } else {
      loadError = 'unavailable';
    }
  } catch {
    loadError = 'unavailable';
  }
}

const pagination = searchResponse?.ok ? searchResponse.pagination : null;
const items = searchResponse?.ok ? searchResponse.items : [];
const hasQuery = query.length > 0;
const isInvalidQuery = hasQuery && query.length < 2;
const noResults = query.length >= 2 && !loadError && items.length === 0;
const title = query.length >= 2 ? `Search: ${query} - World of Aletheia` : 'Search - World of Aletheia';
const description = 'Search across public canon, reference, and campaign content in World of Aletheia.';

function formatCollectionLabel(collection: string): string {
  return collection
    .split('-')
    .join(' ')
    .replace(/\b\w/g, (character) => character.toUpperCase());
}

function buildSearchHref(targetPage: number): string {
  const params = new URLSearchParams();
  if (query) params.set('q', query);
  if (targetPage > 1) params.set('page', String(targetPage));
  const nextQuery = params.toString();
  return nextQuery ? `/search?${nextQuery}` : '/search';
}

function buildResultMeta(item: SearchItem): string[] {
  const parts = [formatCollectionLabel(item.collection)];
  if (item.type) parts.push(item.type);
  if (item.subtype) parts.push(item.subtype);
  return parts;
}

function getScopeNotice(scope: SearchScope): { title: string; body: string } {
  switch (scope.reason) {
    case 'authenticated_gm_access':
      return {
        title: 'Signed-in GM scope active',
        body: 'Results include public content plus campaign material your account can access, including GM-only entries where permitted.',
      };
    case 'authenticated_member_access':
      return {
        title: 'Signed-in member scope active',
        body: 'Results include public content plus campaign material available to your current memberships.',
      };
    case 'authorization_unavailable':
      return {
        title: 'Protected scope unavailable',
        body: 'Campaign access could not be confirmed for this request, so results currently fall back to public content only.',
      };
    case 'authenticated_no_memberships':
      return {
        title: 'Signed-in public scope',
        body: 'Your account is signed in, but no campaign memberships expanded this result set, so only public content is shown.',
      };
    case 'guest':
    default:
      return {
        title: 'Public scope active',
        body: 'Results currently include public canon, reference, and public campaign content only.',
      };
  }
}

const scopeNotice = searchResponse?.ok ? getScopeNotice(searchResponse.scope) : null;
---

<MainSiteLayout title={title} description={description} robots="noindex, nofollow">
  <section class="mx-auto max-w-5xl px-4 py-8 md:py-12">
    <div class="ui-surface p-6 md:p-8">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-600">Global search</p>
        <h1 class="mt-3 text-3xl font-semibold text-ink-950 md:text-4xl">Search the archive</h1>
        <p class="mt-4 text-base leading-8 text-ink-700 md:text-lg">
          Search always includes public content. When signed in, results can also include campaign material your account is allowed to access.
        </p>
      </div>

      <form method="get" action="/search" class="mt-8 grid gap-3 md:grid-cols-[minmax(0,1fr)_auto] md:items-end js-search-form">
        <label class="ui-field">
          <span class="ui-field-label">Search</span>
          <input
            id="search-query"
            name="q"
            type="search"
            value={query}
            placeholder="Search title, summary, type, or tag"
            class="ui-field-control js-search-query"
            minlength="2"
            autocomplete="off"
          />
        </label>

        <div class="flex gap-2 md:justify-end">
          <button type="submit" class="ui-button ui-button--primary js-search-submit">
            <SiteGlyph name="Search" class="h-4 w-4" />
            <span>Search</span>
          </button>
          <a href="/search" class="ui-button ui-button--secondary">Reset</a>
        </div>
      </form>

      <div class="mt-8 space-y-4" aria-live="polite">
        {!hasQuery && (
          <div class="rounded-2xl border border-base-300/80 bg-base-100/80 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-600">Start with a query</p>
            <p class="mt-2 text-base leading-7 text-ink-700">
              Enter at least two characters to search canon, reference material, and public campaign content.
            </p>
          </div>
        )}

        {isInvalidQuery && (
          <div class="rounded-2xl border border-warning/40 bg-warning-50/70 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-warning-800">Query too short</p>
            <p class="mt-2 text-base leading-7 text-warning-800">
              Search requires at least two characters before results can be returned.
            </p>
          </div>
        )}

        {loadError === 'unavailable' && (
          <div class="rounded-2xl border border-error/35 bg-base-100 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-error">Search unavailable</p>
            <p class="mt-2 text-base leading-7 text-ink-700">
              The search index is temporarily unavailable. Try again shortly.
            </p>
          </div>
        )}

        {query.length >= 2 && !loadError && (
          <>
            <div class="flex flex-wrap items-center justify-between gap-3">
              <p class="text-sm text-ink-700">
                <span class="font-semibold text-ink-950">{pagination?.totalItems ?? 0}</span>
                {' '}
                {(pagination?.totalItems ?? 0) === 1 ? 'result' : 'results'} for <span class="font-semibold text-ink-950">{query}</span>
              </p>

              {pagination && pagination.totalPages > 1 && (
                <p class="text-sm text-ink-700">
                  Page <span class="font-semibold text-ink-950">{pagination.page}</span> of <span class="font-semibold text-ink-950">{pagination.totalPages}</span>
                </p>
              )}
            </div>

            {scopeNotice && (
              <div class="rounded-2xl border border-base-300/80 bg-base-100/80 p-5">
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-600">{scopeNotice.title}</p>
                <p class="mt-2 text-base leading-7 text-ink-700">{scopeNotice.body}</p>
              </div>
            )}

            {noResults ? (
              <div class="rounded-2xl border border-base-300/80 bg-base-100/80 p-5">
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-600">No matches found</p>
                <p class="mt-2 text-base leading-7 text-ink-700">
                  Try a broader term, a different spelling, or fewer specific words.
                </p>
              </div>
            ) : (
              <div class="space-y-4">
                {items.map((item) => (
                  <article class="rounded-2xl border border-base-300/80 bg-base-100 p-5 shadow-sm transition hover:border-primary/35 hover:shadow-md">
                    <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-600">
                      {buildResultMeta(item).map((value) => (
                        <span class="ui-pill ui-pill--ghost">{value}</span>
                      ))}
                    </div>

                    <h2 class="mt-4 text-2xl font-semibold text-ink-950">
                      <a href={item.href} class="hover:text-primary">{item.title}</a>
                    </h2>

                    {item.summary && (
                      <p class="mt-3 text-sm leading-7 text-ink-700 md:text-base">{item.summary}</p>
                    )}

                    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
                      <div class="flex flex-wrap gap-2">
                        {item.tags.slice(0, 4).map((tag) => (
                          <span class="ui-pill">{tag}</span>
                        ))}
                      </div>

                      <a href={item.href} class="ui-button ui-button--secondary ui-button--sm">Open entry</a>
                    </div>
                  </article>
                ))}
              </div>
            )}

            {pagination && pagination.totalPages > 1 && (
              <nav class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-base-300/80 pt-4" aria-label="Search result pages">
                <a
                  href={buildSearchHref(pagination.page - 1)}
                  class="ui-button ui-button--secondary"
                  aria-disabled={pagination.hasPreviousPage ? undefined : 'true'}>
                  Previous
                </a>

                <p class="text-sm text-ink-700">
                  Showing page <span class="font-semibold text-ink-950">{pagination.page}</span> of <span class="font-semibold text-ink-950">{pagination.totalPages}</span>
                </p>

                <a
                  href={buildSearchHref(pagination.page + 1)}
                  class="ui-button ui-button--secondary"
                  aria-disabled={pagination.hasNextPage ? undefined : 'true'}>
                  Next
                </a>
              </nav>
            )}
          </>
        )}
      </div>
    </div>
  </section>

  <script>
    (() => {
      const path = window.location.pathname;
      if (path !== '/search') {
        return;
      }

      const form = document.querySelector('.js-search-form');
      const input = document.querySelector('.js-search-query');
      const submitButton = document.querySelector('.js-search-submit');

      if (!(form instanceof HTMLFormElement) || !(input instanceof HTMLInputElement) || !(submitButton instanceof HTMLButtonElement)) {
        return;
      }

      if (!input.value) {
        requestAnimationFrame(() => input.focus());
      }

      form.addEventListener('submit', (event) => {
        const trimmedQuery = input.value.trim();
        input.value = trimmedQuery;

        if (trimmedQuery.length < 2) {
          event.preventDefault();
          input.focus();
          input.reportValidity();
          return;
        }

        submitButton.disabled = true;
      });
    })();
  </script>
</MainSiteLayout>
