---
import { Picture } from 'astro:assets';
import { getCollection } from 'astro:content';
import Layout from '@layouts/MainSiteLayout.astro';

import boatInMangroves from '@images/boat-in-mangroves.png';
import desertTent from '@images/desert-tent.png';
import dwarvenMountainEntrance from '@images/dwarven-mountain-entrance.png';
import fertileLandsToCity from '@images/fertile-lands-to-city.png';
import forestRoad from '@images/forest-road.png';
import jungleRuin from '@images/jungle-ruin.png';
import lakePort from '@images/lake-port.png';
import rideOnTheBeach from '@images/ride-on-the-beach.png';
import savannaFarmland from '@images/savanna-farmland.png';
import wheatFields from '@images/wheat-fields.png';

const heroImages = [
  { image: boatInMangroves, alt: 'A small boat moving through dense mangrove waterways.' },
  { image: desertTent, alt: 'A tent settlement in a broad desert under clear sky.' },
  { image: dwarvenMountainEntrance, alt: 'A carved entrance set into a rugged mountain face.' },
  { image: fertileLandsToCity, alt: 'Fertile countryside leading toward a distant city.' },
  { image: forestRoad, alt: 'A winding road cutting through dense forest.' },
  { image: jungleRuin, alt: 'Dense jungle growth surrounding old stone structures.' },
  { image: lakePort, alt: 'A lakeside port with boats and low settlement buildings.' },
  { image: rideOnTheBeach, alt: 'Travelers riding along a wide coastline at low tide.' },
  { image: savannaFarmland, alt: 'Open savanna transitioning into cultivated farmlands.' },
  { image: wheatFields, alt: 'Golden wheat fields stretching toward distant hills.' },
];

// UTC daily rotation: one image for the whole day, changes at 00:00 UTC.
const utcDay = Math.floor(Date.now() / 86400000);
const heroImage = heroImages[utcDay % heroImages.length];

type DiscoveryItem = {
  id: string;
  title: string;
  excerpt?: string;
  created: Date;
  domain: string;
  url: string;
};

const pickCreated = (data: { created?: Date; ['created-date']?: Date }): Date =>
  data.created ?? data['created-date'] ?? new Date(0);

const [lore, places, sentients, bestiary, flora, factions, systems, campaigns, meta, sessions] = await Promise.all([
  getCollection('lore'),
  getCollection('places'),
  getCollection('sentients'),
  getCollection('bestiary'),
  getCollection('flora'),
  getCollection('factions'),
  getCollection('systems'),
  getCollection('campaigns'),
  getCollection('meta'),
  getCollection('sessions'),
]);

const discoveryPool: DiscoveryItem[] = [
  ...lore
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `lore:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Canon',
      url: `/lore/${item.id}`,
    })),
  ...places
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `places:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Canon',
      url: `/places/${item.id}`,
    })),
  ...sentients
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `sentients:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Canon',
      url: `/sentients/${item.id}`,
    })),
  ...bestiary
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `bestiary:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Canon',
      url: `/bestiary/${item.id}`,
    })),
  ...flora
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `flora:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Canon',
      url: `/flora/${item.id}`,
    })),
  ...factions
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `factions:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Canon',
      url: `/factions/${item.id}`,
    })),
  ...systems
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `systems:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Using',
      url: `/systems/${item.id}`,
    })),
  ...meta
    .filter((item) => item.data.status === 'publish')
    .map((item) => ({
      id: `meta:${item.id}`,
      title: item.data.title,
      excerpt: item.data.excerpt,
      created: pickCreated(item.data),
      domain: 'Using',
      url: `/meta/${item.id}`,
    })),
  ...campaigns
    .filter((item) => item.data.status === 'active' || item.data.status === 'completed')
    .map((item) => {
      const campaignSlug = item.id.replace(/\/index$/, '');
      return {
        id: `campaigns:${item.id}`,
        title: item.data.title,
        excerpt: item.data.excerpt,
        created: pickCreated(item.data),
        domain: 'Campaigns',
        url: `/campaigns/${campaignSlug}`,
      };
    }),
  ...sessions
    .filter((item) => item.data.status === 'publish')
    .map((item) => {
      const parts = item.id.split('/');
      const campaignSlug = parts[0];
      const sessionSlug = parts[parts.length - 1];
      return {
        id: `sessions:${item.id}`,
        title: item.data.title,
        excerpt: item.data.excerpt,
        created: pickCreated(item.data),
        domain: 'Campaigns',
        url: `/campaigns/${campaignSlug}/sessions/${sessionSlug}`,
      };
    }),
];

const sortedDiscovery = discoveryPool.sort((a, b) => b.created.getTime() - a.created.getTime());
const latestItem = sortedDiscovery[0] ?? null;

const randomPool = latestItem
  ? sortedDiscovery.filter((item) => item.id !== latestItem.id)
  : sortedDiscovery;
const randomIndex = randomPool.length > 0 ? utcDay % randomPool.length : 0;
const randomItem = randomPool.length > 0 ? randomPool[randomIndex] : null;
---

<Layout title="World of Aletheia" description="A grounded fantasy world shaped by history, consequence, and fragile renewal.">
  <section class="max-w-7xl mx-auto px-4 lg:px-0">
    <div class="hero min-h-[24rem] rounded-box overflow-hidden shadow-xl relative isolate">
      <Picture
        src={heroImage.image}
        alt={heroImage.alt}
        widths={[640, 960, 1280, 1600]}
        formats={['avif', 'webp']}
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="hero-overlay bg-black/45 absolute inset-0"></div>
      <div class="hero-content text-neutral-content text-center px-6 relative z-10">
        <div class="max-w-3xl">
          <h1 class="mb-4 text-4xl md:text-5xl font-bold font-lora">World of Aletheia</h1>
          <p class="mb-6 text-base md:text-lg opacity-95">
            A grounded fantasy setting where power has consequences, histories are contested,
            and life endures in the wake of catastrophe.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/lore" class="btn btn-primary">Start with Lore</a>
            <a href="/campaigns" class="btn btn-outline btn-neutral">Explore Campaigns</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 lg:px-0 py-8 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <article class="card bg-base-100 shadow-md border border-base-300">
        <div class="card-body">
          <h2 class="card-title font-lora">Canon</h2>
          <p>
            Discover the core truths of Aletheia: creation, peoples, places, and the long shadow of the Cataclysm.
          </p>
          <div class="card-actions justify-end">
            <a href="/aletheia-world-canon" class="btn btn-primary btn-sm">Read Canon</a>
          </div>
        </div>
      </article>

      <article class="card bg-base-100 shadow-md border border-base-300">
        <div class="card-body">
          <h2 class="card-title font-lora">Using Aletheia</h2>
          <p>
            Practical guidance, systems context, and support material for running stories in a gritty fantasy world.
          </p>
          <div class="card-actions justify-end">
            <a href="/using-aletheia" class="btn btn-primary btn-sm">Use the Setting</a>
          </div>
        </div>
      </article>

      <article class="card bg-base-100 shadow-md border border-base-300">
        <div class="card-body">
          <h2 class="card-title font-lora">Campaigns</h2>
          <p>
            Follow active campaigns, session records, and evolving stories that reveal the world through play.
          </p>
          <div class="card-actions justify-end">
            <a href="/campaigns" class="btn btn-primary btn-sm">Enter Campaigns</a>
          </div>
        </div>
      </article>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <article class="card bg-base-100 shadow-md border border-base-300">
        <div class="card-body">
          <div class="badge badge-outline">Latest Article</div>
          {latestItem ? (
            <>
              <h3 class="card-title font-lora">{latestItem.title}</h3>
              <p class="text-sm opacity-80">{latestItem.excerpt || 'Newly surfaced from the living record of Aletheia.'}</p>
              <div class="text-xs opacity-70">{latestItem.domain} • {latestItem.created.toLocaleDateString('en-GB')}</div>
              <div class="card-actions justify-end">
                <a href={latestItem.url} class="btn btn-primary btn-sm">Read Latest</a>
              </div>
            </>
          ) : (
            <>
              <h3 class="card-title font-lora">No published article yet</h3>
              <p class="text-sm opacity-80">Add your first published entry to populate this section.</p>
            </>
          )}
        </div>
      </article>

      <article class="card bg-base-100 shadow-md border border-base-300">
        <div class="card-body">
          <div class="badge badge-outline">From the Archives</div>
          {randomItem ? (
            <>
              <h3 class="card-title font-lora">{randomItem.title}</h3>
              <p class="text-sm opacity-80">{randomItem.excerpt || 'A rotating selection from the world records of Aletheia.'}</p>
              <div class="text-xs opacity-70">{randomItem.domain} • UTC daily rotation</div>
              <div class="card-actions justify-end">
                <a href={randomItem.url} class="btn btn-secondary btn-sm">Explore Random</a>
              </div>
            </>
          ) : (
            <>
              <h3 class="card-title font-lora">No archive entry yet</h3>
              <p class="text-sm opacity-80">Publish content to enable daily rotating discovery.</p>
            </>
          )}
        </div>
      </article>
    </div>
  </section>
</Layout>
