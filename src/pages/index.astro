---
import Layout from '../layouts/MainSiteLayout.astro';
---

<Layout title="World of Aletheia" description="An immersive tabletop RPG setting where magic, mystery, and adventure await in the Shattered Lands.">
	<div class="max-w-3xl mx-auto">
		<h1 class="text-6xl lg:text-7xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
			World of Aletheia
		</h1>
		<p class="text-xl lg:text-2xl text-ink-800 mb-8 drop-shadow-md">
			An immersive tabletop RPG setting where magic, mystery, and adventure await in the Shattered Lands.
		</p>
		<div class="flex flex-wrap gap-4">
			<a href="#explore" class="btn btn-primary btn-lg">Explore the World</a>
			<a href="#about" class="btn btn-outline btn-lg">Learn More</a>
		</div>
	</div>
	
	<!-- Quick links section -->
	<div class="py-16">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto">
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">Lore & History</h2>
					<p>Discover the rich history and legends of Aletheia.</p>
					<div class="card-actions justify-end">
						<a href="#lore" class="btn btn-primary btn-sm">Explore</a>
					</div>
				</div>
			</div>
			
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">Locations</h2>
					<p>Journey through cities, dungeons, and mysterious lands.</p>
					<div class="card-actions justify-end">
						<a href="#locations" class="btn btn-primary btn-sm">Explore</a>
					</div>
				</div>
			</div>
			
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">Characters</h2>
					<p>Meet the heroes, villains, and legends of the realm.</p>
					<div class="card-actions justify-end">
						<a href="#characters" class="btn btn-primary btn-sm">Explore</a>
					</div>
				</div>
			</div>
			
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">Magic & Spells</h2>
					<p>Delve into the arcane arts and mystical powers.</p>
					<div class="card-actions justify-end">
						<a href="https://spells.worldofaletheia.com" target="_blank" class="btn btn-primary btn-sm">Explore</a>
					</div>
				</div>
			</div>
			
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">GURPS Campaign</h2>
					<p>Tips, tricks, and resources for GURPS gameplay.</p>
					<div class="card-actions justify-end">
						<a href="/gurps" class="btn btn-primary btn-sm">Explore</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>
