---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';
---

<MainSiteLayout title="Contribute - World of Aletheia" description="Learn how to contribute to the living archive of Aletheia.">
  <section class="mx-auto max-w-3xl space-y-6 rounded-[2rem] border border-base-300/80 bg-base-100 px-6 py-8 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-ink-600">Contribute</p>
    <h1 class="text-4xl font-bold text-ink-950">Contribute to the archive</h1>
    <p class="text-base leading-8 text-ink-700">
      This page will grow into the public contribution guide for World of Aletheia. For now, it marks the approved destination for future collaboration, edits, and participation pathways.
    </p>
  </section>
</MainSiteLayout>
