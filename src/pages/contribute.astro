---
import InquiryForm from '@components/forms/InquiryForm.astro';
import MainSiteLayout from '@layouts/MainSiteLayout.astro';

export const prerender = false;
---

<MainSiteLayout title="Contribute - World of Aletheia" description="Share corrections, ideas, and collaboration interest with the World of Aletheia archive.">
  <section class="mx-auto max-w-5xl px-4 py-8 md:py-12">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)]">
      <div class="space-y-6">
        <InquiryForm
          kind="contribute"
          title="Contribute"
          heading="Contribute to the archive"
          description="Corrections, continuity notes, typo reports, and thoughtful collaboration ideas are welcome. This form sends a contribution inquiry directly to the project mailbox."
          submitLabel="Send contribution inquiry"
          helperText="Use this form for archive collaboration and contribution requests. Replies come from the project email workflow when configured."
          aboutHrefLabel="About the project"
          alternateHref="/contact"
          alternateLabel="General contact"
          messagePlaceholder="Tell us what you want to contribute, correct, or discuss."
          messageMinHeightClass="min-h-44"
          successMessage="Contribution inquiry sent. If mail delivery is configured, it has been routed to the project inbox."
          unavailableMessage="The contribution relay is temporarily unavailable. Try again later or use the email listed on About."
        />

        <div class="ui-surface rounded-2xl border border-base-300/80 bg-base-100/80 p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-600">Good fit for this form</p>
          <ul class="mt-3 space-y-2 text-sm leading-7 text-ink-700">
            <li>• Canon corrections or continuity issues</li>
            <li>• Typos, broken links, or unclear page wording</li>
            <li>• Interest in contributing notes, ideas, or campaign-adjacent material</li>
            <li>• Questions about how the archive is organized and maintained</li>
          </ul>
        </div>
      </div>

      <aside class="ui-surface ui-surface--muted p-6 md:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-ink-600">Before you send</p>
        <div class="mt-4 space-y-4 text-sm leading-7 text-ink-700">
          <p>
            This archive is curated rather than open-edit. Submissions are reviewed for fit, continuity, and maintenance cost.
          </p>
          <p>
            If you are reporting a site issue, include the page URL and what you expected to happen.
          </p>
          <p>
            If you are proposing a content contribution, describe the scope, relevant part of the setting, and whether it comes from campaign play, canon notes, or interpretation.
          </p>
        </div>
      </aside>
    </div>
  </section>
</MainSiteLayout>
