---
import DiscoveryCollectionView from '@components/DiscoveryCollectionView.astro';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import dwarvenMountainEntrance from '@images/dwarven-mountain-entrance.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'factions',
  searchParams: Astro.url.searchParams,
  locals: Astro.locals,
});
---

<WorldAletheiaLayout title="Factions - World of Aletheia" description="Discover guilds, kingdoms, cults, and other organizations of Aletheia">
  <DiscoveryCollectionView
    basePath="/factions"
    collectionLabel="Factions"
    image={dwarvenMountainEntrance}
    emptyMessage="No published faction entries found."
    {...discoveryPage}
  />
</WorldAletheiaLayout>
