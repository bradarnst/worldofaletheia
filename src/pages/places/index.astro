---
import PaginationNav from '@components/PaginationNav.astro';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';
import lakePort from '@images/lake-port.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'places',
  pageParam: Astro.url.searchParams.get('page'),
  locals: Astro.locals,
});

const { cards, tags: allTags, pagination, mode, errorMessage } = discoveryPage;
---

<WorldAletheiaLayout title="Places - World of Aletheia" description="Discover locations, landmarks, and settlements across Aletheia">
  <div class="mb-8 rounded-xl border border-base-300 bg-base-200/60 p-4 text-sm text-ink-700">
    <div class="font-semibold mb-1">Future-ready discovery</div>
    <p class="meta-muted">Prepared for future filters by place type, subtype, and tags with alphabetical and grouped views in later phases.</p>
  </div>

  {mode === 'error' && errorMessage && (
    <div class="mb-8 rounded-xl border border-warning/40 bg-warning/10 p-4 text-sm text-ink-800">
      <div class="font-semibold mb-1">Index unavailable</div>
      <p>{errorMessage}</p>
    </div>
  )}

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-ink-950 mb-6">Latest Places</h2>
      
      {cards.length === 0 ? (
        <p class="meta-muted">No places found.</p>
      ) : (
        <>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {cards.map((item, index) => (
            <ContentCard content={item} image={index % 2 === 0 ? lakePort : undefined} />
            ))}
          </div>

          <PaginationNav currentPage={pagination.page} totalPages={pagination.totalPages} basePath="/places" />
        </>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-ink-950 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</WorldAletheiaLayout>
