---
import { getCollection } from 'astro:content';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';

const places = await getCollection('places');
const publishedPlaces = places.filter((item) => item.data.status === 'publish');

const allTags = [...new Set(publishedPlaces.flatMap(item => item.data.tags))];
---

<WorldAletheiaLayout title="Places - World of Aletheia" description="Discover locations, landmarks, and settlements across Aletheia">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Places</h2>
      
      {publishedPlaces.length === 0 ? (
        <p class="text-gray-600">No places found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedPlaces.map((item) => (
            <ContentCard content={item} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</WorldAletheiaLayout>
