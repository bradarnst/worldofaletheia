---
import DiscoveryCollectionView from '@components/DiscoveryCollectionView.astro';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import lakePort from '@images/lake-port.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'places',
  searchParams: Astro.url.searchParams,
  locals: Astro.locals,
});
---

<WorldAletheiaLayout title="Places - World of Aletheia" description="Discover locations, landmarks, and settlements across Aletheia">
  <DiscoveryCollectionView basePath="/places" collectionLabel="Places" image={lakePort} emptyMessage="No places found." {...discoveryPage} />
</WorldAletheiaLayout>
