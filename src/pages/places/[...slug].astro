---
import { getCollection, getEntry, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const placesCollection = await getCollection('places');
  return placesCollection.map((item) => ({
    params: { slug: item.id },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry('places', slug as string);

if (!entry) {
  throw new Error(`Place with slug '${slug}' not found`);
}

const { Content } = await render(entry);
---

<ContentLayout content={entry}>
  <article class="prose max-w-none">
    <Content />
  </article>
</ContentLayout>
