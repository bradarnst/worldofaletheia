---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';
---

<MainSiteLayout title="Contact - World of Aletheia" description="Contact details for the World of Aletheia project.">
  <section class="mx-auto max-w-3xl space-y-6 rounded-[2rem] border border-base-300/80 bg-base-100 px-6 py-8 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-ink-600">Contact</p>
    <h1 class="text-4xl font-bold text-ink-950">Contact</h1>
    <p class="text-base leading-8 text-ink-700">
      This placeholder page reserves the approved contact destination for the new UI shell. Final contact details can be added once the preferred public contact method is decided.
    </p>
  </section>
</MainSiteLayout>
