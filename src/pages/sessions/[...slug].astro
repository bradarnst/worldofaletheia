---
import { getCollection, getEntry, render } from 'astro:content';
import UsingAletheiaContentLayout from '@layouts/UsingAletheiaContentLayout.astro';

export async function getStaticPaths() {
  const sessionsCollection = await getCollection('sessions');
  return sessionsCollection.map((item) => ({
    params: { slug: item.id },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry('sessions', slug as string);

if (!entry) {
  throw new Error(`Session with slug '${slug}' not found`);
}

const { Content } = await render(entry);
---

<UsingAletheiaContentLayout content={entry}>
  <article class="prose max-w-none">
    <Content />
  </article>
</ContentLayout>
