---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';

const sessions = await getCollection('sessions');
const publishedSessions = sessions.filter((item) => item.data.status === 'published');

// Get all unique tags
const allTags = [...new Set(publishedSessions.flatMap(item => item.data.tags))];
---

<BaseLayout title="Sessions - World of Aletheia" description="Review session notes and encounter details from Aletheia campaigns">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Sessions</h1>
      <p class="text-xl text-gray-600">Review session notes and encounter details from Aletheia campaigns</p>
    </header>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Sessions</h2>
      
      {publishedSessions.length === 0 ? (
        <p class="text-gray-600">No published session entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedSessions.map((item) => (
            <ContentCard content={item.data} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</BaseLayout>