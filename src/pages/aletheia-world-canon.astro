
---
import Layout from '@layouts/MainSiteLayout.astro';
---

<Layout title="World of Aletheia" description="An immersive tabletop RPG setting where magic, mystery, and adventure await in the Shattered Lands.">
	<div class="max-w-7xl mx-auto px-4 lg:px-0">
		<h1 class="text-6xl lg:text-7xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
			World of Aletheia
		</h1>
		<p class="text-xl lg:text-2xl text-ink-800 mb-8 drop-shadow-md">
			An immersive tabletop RPG setting where magic, mystery, and adventure await in the Shattered Lands.
		</p>
		<div class="flex flex-wrap gap-4">
			<a href="#explore" class="btn btn-primary btn-lg">Explore the World</a>
			<a href="#about" class="btn btn-outline btn-lg">Learn More</a>
		</div>
	</div>
	
	<!-- Quick links section -->
	<div class="py-16 space-y-12">
		<section class="max-w-7xl mx-auto space-y-6 px-4 lg:px-0">
			<h2 class="text-3xl font-semibold font-lora text-ink-900">World of Aletheia (Canon)</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h2 class="card-title font-lora">Lore</h2>
						<p>Discover the rich history and legends of Aletheia.</p>
						<div class="card-actions justify-end">
							<a href="/lore" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h2 class="card-title font-lora">Sentients</h2>
						<p>Meet the heroes, villains, and legends of the realm.</p>
						<div class="card-actions justify-end">
							<a href="/sentients" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h2 class="card-title font-lora">Places</h2>
						<p>Journey through cities, dungeons, and mysterious lands.</p>
						<div class="card-actions justify-end">
							<a href="/places" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h2 class="card-title font-lora">Factions</h2>
						<p>Learn about the powers and organizations shaping Aletheia.</p>
						<div class="card-actions justify-end">
							<a href="/factions" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h2 class="card-title font-lora">Creatures</h2>
						<p>Encounter beasts, monsters, and magical entities.</p>
						<div class="card-actions justify-end">
							<a href="/creatures" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h2 class="card-title font-lora">Meta</h2>
						<p>Find meta discussion, project notes, and behind-the-scenes updates.</p>
						<div class="card-actions justify-end">
							<a href="/meta" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
			</div>
			</div>
		</section>
		
	</div>
</Layout>
