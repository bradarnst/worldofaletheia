---
import Layout from '@layouts/MainSiteLayout.astro';
---

<Layout title="World of Aletheia" description="An immersive tabletop RPG setting where magic, mystery, and adventure await in the Shattered Lands.">
	<div class="max-w-7xl mx-auto px-4 lg:px-0">
		<h1 class="text-5xl lg:text-6xl font-bold font-lora text-ink-950 mb-4 drop-shadow-lg">
			World of Aletheia
		</h1>
		<p class="text-lg lg:text-xl text-ink-800 mb-6 drop-shadow-md">
			An immersive tabletop RPG setting where magic, mystery, and adventure await in the Shattered Lands.
		</p>
		<div class="flex flex-wrap gap-3">
			<a href="#explore" class="btn btn-primary">Explore the World</a>
			<a href="#about" class="btn btn-outline">Learn More</a>
		</div>
	</div>
	
	<!-- Quick links section -->
	<div class="py-8 space-y-8">
		<!-- Canon: World of Aletheia -->
		<section class="max-w-7xl mx-auto space-y-4 px-4 lg:px-0">
			<h2 class="text-2xl font-semibold font-lora text-ink-900">World of Aletheia (Canon)</h2>
			<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Lore</h3>
						<p class="text-sm text-gray-600">Discover the rich history and legends.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/lore" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Sentients</h3>
						<p class="text-sm text-gray-600">Meet heroes, villains, and legends.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/sentients" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Places</h3>
						<p class="text-sm text-gray-600">Journey through cities and lands.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/places" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Factions</h3>
						<p class="text-sm text-gray-600">Learn about powers and organizations.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/factions" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
				
				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Creatures</h3>
						<p class="text-sm text-gray-600">Encounter beasts and monsters.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/creatures" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Using Aletheia -->
		<section class="max-w-7xl mx-auto space-y-4 px-4 lg:px-0">
			<h2 class="text-2xl font-semibold font-lora text-ink-900">Using Aletheia (Systems and Play)</h2>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Systems</h3>
						<p class="text-sm text-gray-600">Rules, mechanics, and systems.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/systems" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>

				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Meta</h3>
						<p class="text-sm text-gray-600">Project notes and updates.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/meta" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Campaigns -->
		<section class="max-w-7xl mx-auto space-y-4 px-4 lg:px-0">
			<h2 class="text-2xl font-semibold font-lora text-ink-900">Campaigns</h2>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
				<div class="card bg-base-100/90 backdrop-blur-sm shadow hover:shadow-md transition-shadow">
					<div class="card-body p-4">
						<h3 class="card-title text-base font-lora">Active Campaigns</h3>
						<p class="text-sm text-gray-600">Ongoing campaigns and session notes.</p>
						<div class="card-actions justify-end mt-2">
							<a href="/campaigns" class="btn btn-primary btn-sm">Explore</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
</Layout>
