---
import '../../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;600;700&display=swap" rel="stylesheet" />
		<title>GURPS - World of Aletheia</title>
	</head>
	<body class="min-h-screen">
		<!-- Full-screen background with map image -->
		<div class="relative min-h-screen bg-cover bg-center bg-fixed" style="background-image: url(/Shattered_Lands_Landscape01.png);">
			<!-- Gradient overlay for text readability -->
			<div class="absolute inset-0 bg-gradient-to-b from-base-100/30 via-base-100/50 to-base-100/70"></div>
			
			<!-- Content layer -->
			<div class="relative z-10">
				<!-- Navigation bar -->
				<div class="navbar bg-base-100/80 backdrop-blur-sm">
					<div class="navbar-start">
						<div class="dropdown">
							<div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
								</svg>
							</div>
							<ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 shadow">
								<li><a href="/gurps/character-creation">Character Creation</a></li>
								<li><a href="/gurps/house-rules">House Rules</a></li>
								<li><a href="/gurps/resources">Resources</a></li>
								<li><a href="/gurps/external-links">External Links</a></li>
								<li><hr class="my-2" /></li>
								<li><a href="/">← Back to Main Site</a></li>
							</ul>
						</div>
						<a href="/" class="btn btn-ghost text-xl font-lora">World of Aletheia</a>
					</div>
					<div class="navbar-center hidden lg:flex">
						<ul class="menu menu-horizontal px-1">
							<li><a href="/gurps/character-creation">Character Creation</a></li>
							<li><a href="/gurps/house-rules">House Rules</a></li>
							<li><a href="/gurps/resources">Resources</a></li>
							<li><a href="/gurps/external-links">External Links</a></li>
						</ul>
					</div>
					<div class="navbar-end gap-2">
						<a href="/" class="btn btn-outline btn-sm">← Main Site</a>
					</div>
				</div>
				
				<!-- Hero content -->
				<div class="container mx-auto px-4 pt-32 pb-16">
					<div class="max-w-3xl">
						<h1 class="text-6xl lg:text-7xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
							GURPS Campaign Guide
						</h1>
						<p class="text-xl lg:text-2xl text-ink-800 mb-8 drop-shadow-md">
							Tips, tricks, and resources for playing in the World of Aletheia using the GURPS system.
						</p>
						<div class="flex flex-wrap gap-4">
							<a href="/gurps/character-creation" class="btn btn-primary btn-lg">Character Creation</a>
							<a href="/gurps/resources" class="btn btn-outline btn-lg">Resources</a>
						</div>
					</div>
				</div>
				
				<!-- Quick links section -->
				<div class="container mx-auto px-4 py-16">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
						<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
							<div class="card-body">
								<h2 class="card-title font-lora">Character Creation</h2>
								<p>Tips and tricks for creating characters with house rules and campaign-specific guidance.</p>
								<div class="card-actions justify-end">
									<a href="/gurps/character-creation" class="btn btn-primary btn-sm">Learn More</a>
								</div>
							</div>
						</div>
						
						<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
							<div class="card-body">
								<h2 class="card-title font-lora">House Rules</h2>
								<p>Campaign-specific modifications and house rules for GURPS gameplay.</p>
								<div class="card-actions justify-end">
									<a href="/gurps/house-rules" class="btn btn-primary btn-sm">View Rules</a>
								</div>
							</div>
						</div>
						
						<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
							<div class="card-body">
								<h2 class="card-title font-lora">Resources</h2>
								<p>Helpful lists of spells, skills, equipment, and other game resources.</p>
								<div class="card-actions justify-end">
									<a href="/gurps/resources" class="btn btn-primary btn-sm">Browse</a>
								</div>
							</div>
						</div>
						
						<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
							<div class="card-body">
								<h2 class="card-title font-lora">External Links</h2>
								<p>Curated collection of external GURPS resources and references.</p>
								<div class="card-actions justify-end">
									<a href="/gurps/external-links" class="btn btn-primary btn-sm">Explore</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
