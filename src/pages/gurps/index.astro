---
import Layout from '../../layouts/GurpsLayout.astro';

const title = 'GURPS Campaign Guide - World of Aletheia';
const description = 'Tips, tricks, and resources for playing in the World of Aletheia using the GURPS system.';
---

<Layout title={title} description={description}>
	<!-- Hero content -->
	<div class="container mx-auto px-4 pt-32 pb-16">
		<div class="max-w-3xl">
			<h1 class="text-6xl lg:text-7xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
				GURPS Campaign Guide
			</h1>
			<p class="text-xl lg:text-2xl text-ink-800 mb-8 drop-shadow-md">
				Tips, tricks, and resources for playing in the World of Aletheia using the GURPS system.
			</p>
			<div class="flex flex-wrap gap-4">
				<a href="/gurps/character-creation" class="btn btn-primary btn-lg">Character Creation</a>
				<a href="/gurps/resources" class="btn btn-outline btn-lg">Resources</a>
			</div>
		</div>
	</div>
	
	<!-- Quick links section -->
	<div class="container mx-auto px-4 py-16">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">Character Creation</h2>
					<p>Tips and tricks for creating characters with house rules and campaign-specific guidance.</p>
					<div class="card-actions justify-end">
						<a href="/gurps/character-creation" class="btn btn-primary btn-sm">Learn More</a>
					</div>
				</div>
			</div>
			
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">House Rules</h2>
					<p>Campaign-specific modifications and house rules for GURPS gameplay.</p>
					<div class="card-actions justify-end">
						<a href="/gurps/house-rules" class="btn btn-primary btn-sm">View Rules</a>
					</div>
				</div>
			</div>
			
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">Resources</h2>
					<p>Helpful lists of spells, skills, equipment, and other game resources.</p>
					<div class="card-actions justify-end">
						<a href="/gurps/resources" class="btn btn-primary btn-sm">Browse</a>
					</div>
				</div>
			</div>
			
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
				<div class="card-body">
					<h2 class="card-title font-lora">External Links</h2>
					<p>Curated collection of external GURPS resources and references.</p>
					<div class="card-actions justify-end">
						<a href="/gurps/external-links" class="btn btn-primary btn-sm">Explore</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>
