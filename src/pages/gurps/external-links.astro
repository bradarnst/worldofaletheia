---
import Layout from '../../layouts/GurpsLayout.astro';

const title = 'External Links - GURPS - World of Aletheia';
const description = 'Curated collection of external GURPS resources and references for World of Aletheia campaigns.';
---

<Layout title={title} description={description}>
	<!-- Main content -->
	<div class="container mx-auto px-4 py-16">
		<div class="max-w-4xl">
			<h1 class="text-5xl lg:text-6xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
				External Links
			</h1>
			<p class="text-lg text-ink-800 mb-8 drop-shadow-md">
				Curated collection of external GURPS resources and references.
			</p>
			
			<!-- Links section -->
			<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl mb-8">
				<div class="card-body">
					<h2 class="card-title font-lora text-2xl mb-4">Recommended Resources</h2>
					<p class="mb-6">
						Below is a curated collection of external resources that are useful for GURPS gameplay 
						and world-building in the World of Aletheia. These links are organized by category for easy reference.
					</p>
					
					<div class="space-y-6">
						<div>
							<h3 class="text-lg font-semibold font-lora mb-3">Official GURPS Resources</h3>
							<ul class="space-y-2">
								<li>
									<a href="https://www.sjgames.com/gurps/" target="_blank" class="link link-primary">
										Steve Jackson Games - GURPS Official Site
									</a>
								</li>
								<li>
									<a href="https://forums.sjgames.com/" target="_blank" class="link link-primary">
										GURPS Forums
									</a>
								</li>
							</ul>
						</div>
						
						<div>
							<h3 class="text-lg font-semibold font-lora mb-3">Community Tools & Calculators</h3>
							<ul class="space-y-2">
								<li>
									<a href="#" class="link link-primary">
										Character Sheet Tools (Coming Soon)
									</a>
								</li>
								<li>
									<a href="#" class="link link-primary">
										Campaign Management Tools (Coming Soon)
									</a>
								</li>
							</ul>
						</div>
						
						<div>
							<h3 class="text-lg font-semibold font-lora mb-3">World-Building Resources</h3>
							<ul class="space-y-2">
								<li>
									<a href="#" class="link link-primary">
										Fantasy World-Building Guides (Coming Soon)
									</a>
								</li>
								<li>
									<a href="#" class="link link-primary">
										Campaign Setting Resources (Coming Soon)
									</a>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
			
			<!-- Navigation cards -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<a href="/gurps/resources" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h3 class="card-title font-lora">Resources</h3>
						<p>Spells, skills, equipment, and more.</p>
						<div class="card-actions justify-end">
							<div class="btn btn-primary btn-sm">Browse</div>
						</div>
					</div>
				</a>
				
				<a href="/gurps" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
					<div class="card-body">
						<h3 class="card-title font-lora">GURPS Home</h3>
						<p>Back to the GURPS campaign guide.</p>
						<div class="card-actions justify-end">
							<div class="btn btn-primary btn-sm">Home</div>
						</div>
					</div>
				</a>
			</div>
		</div>
	</div>
</Layout>
