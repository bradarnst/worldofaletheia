---
import '../../../../styles/global.css';
import spellsData from '../../../../data/spells/spells-raw.json';
import spellTypes from '../../../../data/spells/spell-types.json';

// Get the spell type from the URL
const { type } = Astro.params;

// Convert URL slug back to spell type name
const spellTypeName = spellTypes.find(st => 
  st.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') === type
);

// Filter spells by type
const spells = spellsData.spells
  .filter(spell => spell.spell_type === spellTypeName)
  .sort((a, b) => a.spell_name.localeCompare(b.spell_name));

// Generate static paths for all spell types
export async function getStaticPaths() {
  return spellTypes.map(spellType => ({
    params: { 
      type: spellType.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
    }
  }));
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;600;700&display=swap" rel="stylesheet" />
		<title>{spellTypeName} - Sorcerer Spells - GURPS - World of Aletheia</title>
	</head>
	<body class="min-h-screen">
		<!-- Full-screen background with map image -->
		<div class="relative min-h-screen bg-cover bg-center bg-fixed" style="background-image: url(/Shattered_Lands_Landscape01.png);">
			<!-- Gradient overlay for text readability -->
			<div class="absolute inset-0 bg-gradient-to-b from-base-100/30 via-base-100/50 to-base-100/70"></div>
			
			<!-- Content layer -->
			<div class="relative z-10">
				<!-- Navigation bar -->
				<div class="navbar bg-base-100/80 backdrop-blur-sm">
					<div class="navbar-start">
						<div class="dropdown">
							<div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
								</svg>
							</div>
							<ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 shadow">
								<li><a href="/gurps">GURPS Home</a></li>
								<li><a href="/gurps/character-creation">Character Creation</a></li>
								<li><a href="/gurps/house-rules">House Rules</a></li>
								<li><a href="/gurps/resources">Resources</a></li>
								<li><a href="/gurps/resources/sorcerer-spells">Sorcerer Spells</a></li>
								<li><a href="/gurps/external-links">External Links</a></li>
								<li><hr class="my-2" /></li>
								<li><a href="/">← Back to Main Site</a></li>
							</ul>
						</div>
						<a href="/gurps" class="btn btn-ghost text-xl font-lora">GURPS Guide</a>
					</div>
					<div class="navbar-center hidden lg:flex">
						<ul class="menu menu-horizontal px-1">
							<li><a href="/gurps">GURPS Home</a></li>
							<li><a href="/gurps/character-creation">Character Creation</a></li>
							<li><a href="/gurps/house-rules">House Rules</a></li>
							<li><a href="/gurps/resources">Resources</a></li>
							<li><a href="/gurps/resources/sorcerer-spells">Sorcerer Spells</a></li>
							<li><a href="/gurps/external-links">External Links</a></li>
						</ul>
					</div>
					<div class="navbar-end gap-2">
						<a href="/" class="btn btn-outline btn-sm">← Main Site</a>
					</div>
				</div>
				
				<!-- Main content -->
				<div class="container mx-auto px-4 py-16">
					<div class="max-w-6xl">
						<h1 class="text-5xl lg:text-6xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
							{spellTypeName}
						</h1>
						<p class="text-lg text-ink-800 mb-8 drop-shadow-md">
							{spells.length} spell{spells.length !== 1 ? 's' : ''} in this category.
						</p>
						
						<!-- Spell Cards Grid -->
						{spells.length > 0 ? (
							<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
								{spells.map((spell) => {
									// Truncate description to first 150 characters
									const descriptionBlurb = spell.description.length > 150 
										? spell.description.substring(0, 150) + '...' 
										: spell.description;
									
									// Truncate statistics to first 120 characters
									const statisticsBlurb = spell.statistics.length > 120 
										? spell.statistics.substring(0, 120) + '...' 
										: spell.statistics;
									
									return (
										<div class="card bg-base-100/90 backdrop-blur-sm shadow-lg hover:shadow-xl transition-shadow h-full flex flex-col">
											<div class="card-body flex flex-col h-full">
												{/* Spell Title - Prominent */}
												<h2 class="card-title font-lora text-xl text-ink-950 mb-2">
													{spell.spell_name}
												</h2>
												
												{/* Cost - Prominent */}
												<div class="mb-3 pb-3 border-b border-base-300">
													<p class="text-sm font-semibold text-primary">
														💰 {spell.full_cost}
													</p>
												</div>
												
												{/* Keywords - Slightly Prominent */}
												{spell.keywords && spell.keywords !== 'None' && (
													<div class="mb-3">
														<p class="text-xs font-semibold text-ink-700 uppercase tracking-wide">
															Keywords
														</p>
														<p class="text-sm text-ink-800">
															{spell.keywords}
														</p>
													</div>
												)}
												
												{/* Casting Roll */}
												<div class="mb-3 text-xs">
													<span class="font-semibold text-ink-700">Casting:</span>
													<span class="text-ink-800 ml-1">{spell.casting_roll}</span>
												</div>
												
												{/* Range and Duration */}
												<div class="mb-3 text-xs space-y-1">
													<div>
														<span class="font-semibold text-ink-700">Range:</span>
														<span class="text-ink-800 ml-1">{spell.range}</span>
													</div>
													<div>
														<span class="font-semibold text-ink-700">Duration:</span>
														<span class="text-ink-800 ml-1">{spell.duration}</span>
													</div>
												</div>
												
												{/* Description Blurb */}
												<div class="mb-3 flex-grow">
													<p class="text-xs font-semibold text-ink-700 uppercase tracking-wide mb-1">
														Description
													</p>
													<p class="text-sm text-ink-800 line-clamp-3">
														{descriptionBlurb}
													</p>
												</div>
												
												{/* Statistics Blurb */}
												<div class="mb-4">
													<p class="text-xs font-semibold text-ink-700 uppercase tracking-wide mb-1">
														Statistics
													</p>
													<p class="text-xs text-ink-700 line-clamp-2 font-mono">
														{statisticsBlurb}
													</p>
												</div>
												
												{/* View Details Button */}
												<div class="card-actions justify-end mt-auto">
													<button class="btn btn-primary btn-sm">
														View Details
													</button>
												</div>
											</div>
										</div>
									);
								})}
							</div>
						) : (
							<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl">
								<div class="card-body">
									<p>No spells found in this category.</p>
								</div>
							</div>
						)}
						
						<!-- Navigation cards -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<a href="/gurps/resources/sorcerer-spells" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
								<div class="card-body">
									<h3 class="card-title font-lora">← Back to Sorcerer Spells</h3>
									<p>Browse other spell types.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">Back</div>
									</div>
								</div>
							</a>
							
							<a href="/gurps/resources/sorcerer-spells/all" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
								<div class="card-body">
									<h3 class="card-title font-lora">All Spells</h3>
									<p>View alphabetical spell index.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">View</div>
									</div>
								</div>
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
