---
import '../../../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;600;700&display=swap" rel="stylesheet" />
		<title>Resources - GURPS - World of Aletheia</title>
	</head>
	<body class="min-h-screen">
		<!-- Full-screen background with map image -->
		<div class="relative min-h-screen bg-cover bg-center bg-fixed" style="background-image: url(/Shattered_Lands_Landscape01.png);">
			<!-- Gradient overlay for text readability -->
			<div class="absolute inset-0 bg-gradient-to-b from-base-100/30 via-base-100/50 to-base-100/70"></div>
			
			<!-- Content layer -->
			<div class="relative z-10">
				<!-- Navigation bar -->
				<div class="navbar bg-base-100/80 backdrop-blur-sm">
					<div class="navbar-start">
						<div class="dropdown">
							<div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
								</svg>
							</div>
							<ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-[1] mt-3 w-52 p-2 shadow">
								<li><a href="/gurps">GURPS Home</a></li>
								<li><a href="/gurps/character-creation">Character Creation</a></li>
								<li><a href="/gurps/house-rules">House Rules</a></li>
								<li><a href="/gurps/resources">Resources</a></li>
								<li><a href="/gurps/external-links">External Links</a></li>
								<li><hr class="my-2" /></li>
								<li><a href="/">← Back to Main Site</a></li>
							</ul>
						</div>
						<a href="/gurps" class="btn btn-ghost text-xl font-lora">GURPS Guide</a>
					</div>
					<div class="navbar-center hidden lg:flex">
						<ul class="menu menu-horizontal px-1">
							<li><a href="/gurps">GURPS Home</a></li>
							<li><a href="/gurps/character-creation">Character Creation</a></li>
							<li><a href="/gurps/house-rules">House Rules</a></li>
							<li><a href="/gurps/resources">Resources</a></li>
							<li><a href="/gurps/external-links">External Links</a></li>
						</ul>
					</div>
					<div class="navbar-end gap-2">
						<a href="/" class="btn btn-outline btn-sm">← Main Site</a>
					</div>
				</div>
				
				<!-- Main content -->
				<div class="container mx-auto px-4 py-16">
					<div class="max-w-4xl">
						<h1 class="text-5xl lg:text-6xl font-bold font-lora text-ink-950 mb-6 drop-shadow-lg">
							Resources
						</h1>
						<p class="text-lg text-ink-800 mb-8 drop-shadow-md">
							Helpful lists and references for GURPS gameplay in the World of Aletheia.
						</p>
						
						<!-- Resource categories -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
							<a href="/gurps/resources/sorcerer-spells" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
								<div class="card-body">
									<h2 class="card-title font-lora">Sorcerer Spells</h2>
									<p>Comprehensive list of sorcerer spells for the World of Aletheia.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">Browse</div>
									</div>
								</div>
							</a>
							
							<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl">
								<div class="card-body">
									<h2 class="card-title font-lora">Skills</h2>
									<p>Recommended skills and skill combinations for character development.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">Coming Soon</div>
									</div>
								</div>
							</div>
							
							<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl">
								<div class="card-body">
									<h2 class="card-title font-lora">Equipment</h2>
									<p>Campaign-appropriate equipment and gear for various character types.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">Coming Soon</div>
									</div>
								</div>
							</div>
							
							<div class="card bg-base-100/90 backdrop-blur-sm shadow-xl">
								<div class="card-body">
									<h2 class="card-title font-lora">Reference Tables</h2>
									<p>Quick reference tables and charts for common game mechanics.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">Coming Soon</div>
									</div>
								</div>
							</div>
						</div>
						
						<!-- Navigation cards -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<a href="/gurps/character-creation" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
								<div class="card-body">
									<h3 class="card-title font-lora">Character Creation</h3>
									<p>Tips for creating characters with house rules.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">Learn More</div>
									</div>
								</div>
							</a>
							
							<a href="/gurps/external-links" class="card bg-base-100/90 backdrop-blur-sm shadow-xl hover:shadow-2xl transition-shadow">
								<div class="card-body">
									<h3 class="card-title font-lora">External Links</h3>
									<p>Curated GURPS resources and references.</p>
									<div class="card-actions justify-end">
										<div class="btn btn-primary btn-sm">Explore</div>
									</div>
								</div>
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
