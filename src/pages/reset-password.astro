---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';
import { getD1BindingFromLocals } from '~/lib/d1';
import {
  PASSWORD_RESET_COMPLETE_MESSAGE,
  PASSWORD_RESET_EXPIRED_MESSAGE,
  isPasswordResetTokenCurrentlyValid,
} from '~/lib/password-reset';

const token = Astro.url.searchParams.get('token') ?? '';
const status = Astro.url.searchParams.get('status');
const isComplete = status === 'complete';
let isTokenValid = false;

if (!isComplete && status !== 'invalid') {
  try {
    const db = await getD1BindingFromLocals(Astro.locals);
    isTokenValid = await isPasswordResetTokenCurrentlyValid(db, token);
  } catch {
    isTokenValid = false;
  }
}

const isInvalid = status === 'invalid' || (!isComplete && !isTokenValid);
---

<MainSiteLayout
  title="Reset password - World of Aletheia"
  description="Set a new World of Aletheia password."
  robots="noindex,nofollow"
>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div class="ui-surface p-6 md:p-8">
      <h1 class="mb-4 text-3xl font-bold text-ink-950 md:text-4xl">Reset password</h1>

      {isComplete ? (
        <div class="space-y-4">
          <p class="alert alert-success text-sm" role="status">{PASSWORD_RESET_COMPLETE_MESSAGE}</p>
          <p><a href="/login" class="ui-button ui-button--primary">Sign in</a></p>
        </div>
      ) : isInvalid ? (
        <div class="space-y-4">
          <p class="alert alert-warning text-sm" role="alert">{PASSWORD_RESET_EXPIRED_MESSAGE}</p>
          <p><a href="/forgot-password" class="ui-button ui-button--primary">Request a new reset link</a></p>
        </div>
      ) : (
        <form action="/api/auth/complete-password-reset" method="POST" class="space-y-4">
          <input type="hidden" name="token" value={token} />
          <label class="ui-field w-full">
            <span class="ui-field-label">New password</span>
            <input
              type="password"
              name="newPassword"
              required
              class="ui-field-control"
              minlength="8"
              autocomplete="new-password"
            />
          </label>
          <label class="ui-field w-full">
            <span class="ui-field-label">Confirm new password</span>
            <input
              type="password"
              name="confirmPassword"
              required
              class="ui-field-control"
              minlength="8"
              autocomplete="new-password"
            />
          </label>
          <button type="submit" class="ui-button ui-button--primary">Reset password</button>
        </form>
      )}
    </div>
  </section>
</MainSiteLayout>
