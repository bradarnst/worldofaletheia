---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';

const token = Astro.url.searchParams.get('token') ?? '';
const status = Astro.url.searchParams.get('status');
const isComplete = status === 'complete';
const betterAuthError = Astro.url.searchParams.get('error');
const isInvalid = status === 'invalid' || betterAuthError !== null || (!isComplete && token.length === 0);
---

<MainSiteLayout
  title="Reset password - World of Aletheia"
  description="Set a new World of Aletheia password."
  robots="noindex,nofollow"
>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div class="ui-surface p-6 md:p-8">
      <h1 class="mb-4 text-3xl font-bold text-ink-950 md:text-4xl">Reset password</h1>

      {isComplete ? (
        <div class="space-y-4">
          <p class="alert alert-success text-sm" role="status">Password reset complete. Sign in with your new password.</p>
          <p><a href="/login" class="ui-button ui-button--primary">Sign in</a></p>
        </div>
      ) : isInvalid ? (
        <div class="space-y-4">
          <p class="alert alert-warning text-sm" role="alert">This reset link is invalid or expired. Request a new password reset link.</p>
          <p><a href="/forgot-password" class="ui-button ui-button--primary">Request a new reset link</a></p>
        </div>
      ) : (
        <form id="reset-password-form" class="space-y-4">
          <input type="hidden" name="token" value={token} />
          <label class="ui-field w-full">
            <span class="ui-field-label">New password</span>
            <input
              type="password"
              name="newPassword"
              required
              class="ui-field-control"
              minlength="8"
              autocomplete="new-password"
            />
          </label>
          <label class="ui-field w-full">
            <span class="ui-field-label">Confirm new password</span>
            <input
              type="password"
              name="confirmPassword"
              required
              class="ui-field-control"
              minlength="8"
              autocomplete="new-password"
            />
          </label>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button type="submit" class="ui-button ui-button--primary">Reset password</button>
            <p id="reset-password-status" class="text-sm" aria-live="polite"></p>
          </div>
        </form>
      )}
    </div>
  </section>
</MainSiteLayout>

<script>
  const form = document.getElementById('reset-password-form') as HTMLFormElement | null;
  const status = document.getElementById('reset-password-status');

  function setStatus(message: string, tone: 'ok' | 'error' = 'ok') {
    if (!status) return;
    status.textContent = message;
    status.className = tone === 'ok' ? 'text-sm text-success' : 'text-sm text-error';
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const formData = new FormData(form);
    const token = String(formData.get('token') ?? '');
    const newPassword = String(formData.get('newPassword') ?? '');
    const confirmPassword = String(formData.get('confirmPassword') ?? '');

    if (newPassword !== confirmPassword) {
      setStatus('New password and confirmation must match.', 'error');
      return;
    }

    if (newPassword.length < 8) {
      setStatus('New password must be at least 8 characters.', 'error');
      return;
    }

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Resetting...';
    }
    setStatus('Resetting password...');

    try {
      const response = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, newPassword }),
      });

      if (response.ok) {
        window.location.href = '/reset-password?status=complete';
        return;
      }

      setStatus('Reset link is invalid or expired. Request a new reset link.', 'error');
    } catch {
      setStatus('Password reset failed. Try again later.', 'error');
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = 'Reset password';
      }
    }
  });
</script>
