---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import TagCloud from '../../components/TagCloud.astro';

const creatures = await getCollection('creatures');
const publishedCreatures = creatures.filter((item) => item.data.status === 'published');

// Get all unique tags
const allTags = [...new Set(publishedCreatures.flatMap(item => item.data.tags))];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Creatures - World of Aletheia</title>
</head>
<body>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Creatures</h1>
      <p class="text-xl text-gray-600">Explore monsters, beasts, and other creatures of Aletheia</p>
    </header>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Creatures</h2>
      
      {publishedCreatures.length === 0 ? (
        <p class="text-gray-600">No published creature entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedCreatures.map((item) => (
            <ContentCard content={item.data} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</body>
</html>