---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';

const nextRaw = Astro.url.searchParams.get('next') ?? '/campaigns';
const isSafeInternalPath = nextRaw.startsWith('/') && !nextRaw.startsWith('//');
const next = isSafeInternalPath ? nextRaw : '/campaigns';
const callbackURL = new URL(next, Astro.url.origin).toString();
---

<MainSiteLayout title="Login - World of Aletheia" description="Sign in to access campaign member content.">
  <section class="max-w-xl mx-auto py-12 space-y-8">
    <div>
      <h1 class="text-3xl font-bold mb-4">Sign in</h1>
      <p class="mb-6">
        Campaign member-only content requires an authenticated account with campaign membership in the access table.
      </p>

      <!-- Social sign-in: submit via fetch as JSON (better-auth requires application/json) -->
      <form id="social-signin-form" class="space-y-3">
        <input type="hidden" name="provider" value="google" />
        <input type="hidden" name="callbackURL" value={callbackURL} />
        <button type="submit" class="btn btn-primary w-full">Continue with Google</button>
      </form>
    </div>

    <div class="divider">or</div>

    <div class="space-y-6">
      <form action="/api/auth/sign-in/email" method="POST" class="space-y-3">
        <h2 class="text-xl font-semibold">Sign in with email</h2>
        <label class="form-control w-full">
          <span class="label-text">Email</span>
          <input type="email" name="email" required class="input input-bordered w-full" autocomplete="email" />
        </label>
        <label class="form-control w-full">
          <span class="label-text">Password</span>
          <input
            type="password"
            name="password"
            required
            class="input input-bordered w-full"
            minlength="8"
            autocomplete="current-password"
          />
        </label>
        <input type="hidden" name="callbackURL" value={callbackURL} />
        <button type="submit" class="btn btn-outline w-full">Sign in with email</button>
      </form>

      <form action="/api/auth/sign-up/email" method="POST" class="space-y-3">
        <h2 class="text-xl font-semibold">Create account with email</h2>
        <label class="form-control w-full">
          <span class="label-text">Name</span>
          <input type="text" name="name" required class="input input-bordered w-full" autocomplete="name" />
        </label>
        <label class="form-control w-full">
          <span class="label-text">Email</span>
          <input type="email" name="email" required class="input input-bordered w-full" autocomplete="email" />
        </label>
        <label class="form-control w-full">
          <span class="label-text">Password</span>
          <input
            type="password"
            name="password"
            required
            class="input input-bordered w-full"
            minlength="8"
            autocomplete="new-password"
          />
        </label>
        <input type="hidden" name="callbackURL" value={callbackURL} />
        <button type="submit" class="btn btn-secondary w-full">Create account</button>
      </form>
    </div>
  </section>
</MainSiteLayout>

<script>
  document.getElementById('social-signin-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Redirecting...';

    const formData = new FormData(form);
    const body = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/auth/sign-in/social', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
        redirect: 'manual',
      });

      if (response.status === 302 || response.status === 303) {
        const location = response.headers.get('Location');
        if (location) {
          window.location.href = location;
          return;
        }
      }

      if (response.ok) {
        const data = await response.json();
        if (data.url) {
          window.location.href = data.url;
          return;
        }
      }

      // Fallback: follow redirect if the handler redirected automatically
      if (response.url && response.url !== window.location.href) {
        window.location.href = response.url;
        return;
      }

      const error = data?.error ?? 'sign_in_failed';
      alert(`Sign-in failed: ${error}. Please try again.`);
    } catch {
      alert('Sign-in failed. Please try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>

