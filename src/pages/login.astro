---
import MainSiteLayout from '@layouts/MainSiteLayout.astro';

const nextRaw = Astro.url.searchParams.get('next') ?? '/campaigns';
const isSafeInternalPath = nextRaw.startsWith('/') && !nextRaw.startsWith('//');
const next = isSafeInternalPath ? nextRaw : '/campaigns';
const callbackURL = new URL(next, Astro.url.origin).toString();
---

<MainSiteLayout title="Login - World of Aletheia" description="Sign in to access campaign member content.">
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div class="ui-surface p-6 md:p-8">
      <div class="max-w-2xl">
        <h1 class="mb-4 text-3xl font-bold text-ink-950 md:text-4xl">Sign in</h1>
        <p class="mb-6 text-ink-800">
          Campaign member-only content requires an authenticated account with campaign membership in the access table.
        </p>

        <form id="social-signin-form" class="space-y-3">
        <input type="hidden" name="provider" value="google" />
        <input type="hidden" name="callbackURL" value={callbackURL} />
          <button type="submit" class="ui-button ui-button--primary ui-button--block">Continue with Google</button>
      </form>

        <div class="ui-divider my-8">or</div>

        <div class="grid gap-6 md:grid-cols-2">
          <form action="/api/auth/sign-in/email" method="POST" class="space-y-3">
            <h2 class="text-xl font-semibold text-ink-950">Sign in with email</h2>
            <label class="ui-field w-full">
              <span class="ui-field-label">Email</span>
              <input type="email" name="email" required class="ui-field-control" autocomplete="email" />
        </label>
            <label class="ui-field w-full">
              <span class="ui-field-label">Password</span>
              <input
                type="password"
                name="password"
                required
                class="ui-field-control"
                minlength="8"
                autocomplete="current-password"
              />
            </label>
            <input type="hidden" name="callbackURL" value={callbackURL} />
            <button type="submit" class="ui-button ui-button--secondary ui-button--block">Sign in with email</button>
          </form>

          <form action="/api/auth/sign-up/email" method="POST" class="space-y-3">
            <h2 class="text-xl font-semibold text-ink-950">Create account with email</h2>
            <label class="ui-field w-full">
              <span class="ui-field-label">Name</span>
              <input type="text" name="name" required class="ui-field-control" autocomplete="name" />
        </label>
            <label class="ui-field w-full">
              <span class="ui-field-label">Email</span>
              <input type="email" name="email" required class="ui-field-control" autocomplete="email" />
        </label>
            <label class="ui-field w-full">
              <span class="ui-field-label">Password</span>
              <input
                type="password"
                name="password"
                required
                class="ui-field-control"
                minlength="8"
                autocomplete="new-password"
              />
            </label>
            <input type="hidden" name="callbackURL" value={callbackURL} />
            <button type="submit" class="ui-button ui-button--primary ui-button--block">Create account</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</MainSiteLayout>

<script>
  document.getElementById('social-signin-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Redirecting...';

    const formData = new FormData(form);
    const body = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/auth/sign-in/social', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
        redirect: 'manual',
      });
      const isJsonResponse = response.headers.get('content-type')?.includes('application/json');
      const data = isJsonResponse
        ? await response.json() as { url?: string; error?: string }
        : null;

      if (response.status === 302 || response.status === 303) {
        const location = response.headers.get('Location');
        if (location) {
          window.location.href = location;
          return;
        }
      }

      if (response.ok) {
        if (data?.url) {
          window.location.href = data.url;
          return;
        }
      }

      // Fallback: follow redirect if the handler redirected automatically
      if (response.url && response.url !== window.location.href) {
        window.location.href = response.url;
        return;
      }

      const error = data?.error ?? 'sign_in_failed';
      alert(`Sign-in failed: ${error}. Please try again.`);
    } catch {
      alert('Sign-in failed. Please try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
