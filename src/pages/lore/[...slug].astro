---
import { getCollection, getEntry, render } from 'astro:content';
import WorldAletheiaContentLayout from '@layouts/WorldAletheiaContentLayout.astro';

export async function getStaticPaths() {
  const loreCollection = await getCollection('lore');
  return loreCollection.map((item) => ({
    params: { slug: item.id },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry('lore', slug as string);

if (!entry) {
  throw new Error(`Lore entry with slug '${slug}' not found`);
}

const { Content } = await render(entry);
---

<WorldAletheiaContentLayout content={entry}>
  <article class="prose max-w-none">
    <Content />
  </article>
</ContentLayout>
