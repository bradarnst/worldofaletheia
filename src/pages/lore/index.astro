---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import TagCloud from '../../components/TagCloud.astro';

const lore = await getCollection('lore');
const publishedLore = lore.filter((item) => item.data.status === 'published');

// Get all unique tags
const allTags = [...new Set(publishedLore.flatMap(item => item.data.tags))];
---

<BaseLayout title="Lore - World of Aletheia" description="Explore the rich history, mythology, and world-building of Aletheia">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Lore</h1>
      <p class="text-xl text-gray-600">Explore the rich history, mythology, and world-building of Aletheia</p>
    </header>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Lore</h2>
      
      {publishedLore.length === 0 ? (
        <p class="text-gray-600">No published lore entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedLore.map((item) => (
            <ContentCard content={item} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</BaseLayout>