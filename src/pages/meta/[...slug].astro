---
import { getCollection, getEntry, render } from 'astro:content';
import UsingAletheiaContentLayout from '@layouts/UsingAletheiaContentLayout.astro';

export async function getStaticPaths() {
  const metaCollection = await getCollection('meta');
  return metaCollection.map((item) => ({
    params: { slug: item.id },
  }));
}

const { slug } = Astro.params;
const entry = await getEntry('meta', slug as string);

if (!entry) {
  throw new Error(`Meta entry with slug '${slug}' not found`);
}

const { Content } = await render(entry);
---

<UsingAletheiaContentLayout content={entry}>
  <article class="reading-prose">
    <Content />
  </article>
</UsingAletheiaContentLayout>
