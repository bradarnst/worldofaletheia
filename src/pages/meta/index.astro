---
import DiscoveryCollectionView from '@components/DiscoveryCollectionView.astro';
import UsingAletheiaLayout from '@layouts/UsingAletheiaLayout.astro';
import fertileLandsToCity from '@images/fertile-lands-to-city.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'meta',
  searchParams: Astro.url.searchParams,
  locals: Astro.locals,
});
---

<UsingAletheiaLayout title="Meta - Using Aletheia" description="Behind-the-scenes writing, planning, and notes for the World of Aletheia project">
  <DiscoveryCollectionView
    basePath="/meta"
    collectionLabel="Meta"
    image={fertileLandsToCity}
    emptyMessage="No meta entries found."
    {...discoveryPage}
  />
</UsingAletheiaLayout>
