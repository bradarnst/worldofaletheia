---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CampaignsContentLayout from '@layouts/CampaignsContentLayout.astro';
import {
  canViewCampaignContentAsync,
  resolveCampaignContentVisibility,
} from '@utils/campaign-access';
import {
  CAMPAIGN_FAMILY_SEGMENTS,
  extractCampaignSlugFromEntryId,
  getCampaignFamilyBySegment,
  pickCampaignEntryDate,
} from '@utils/campaign-collections';
import { getAllCampaignFamilyEntries } from '@utils/campaign-content';
import { getFilteredCollection } from '@utils/content-filter';
import { createCampaignRequestAccessResolver } from '~/lib/campaign-request-access';

interface CampaignSectionCard {
  segment: string;
  label: string;
  description: string;
  href: string;
  count: number;
  totalCount: number;
  restrictedCount: number;
  latestUpdated: Date | null;
}

const { slug } = Astro.params;
let entry: CollectionEntry<'campaigns'> | null = null;
let familyEntries: Awaited<ReturnType<typeof getAllCampaignFamilyEntries>> = [];
let contentUnavailable = false;

try {
  const [campaigns, allFamilyEntries] = await Promise.all([
    getCollection('campaigns'),
    getAllCampaignFamilyEntries(),
  ]);
  entry = getFilteredCollection(campaigns).find((item) => extractCampaignSlugFromEntryId(item.id) === slug) ?? null;
  familyEntries = allFamilyEntries;
} catch (error) {
  console.error('campaign.route.content_unavailable', {
    campaignSlug: slug,
    message: error instanceof Error ? error.message : 'unknown error',
  });
  contentUnavailable = true;
}

if (!entry && !contentUnavailable) {
  return Astro.redirect('/campaigns');
}

let Content = null;
if (entry && !contentUnavailable) {
  try {
    ({ Content } = await render(entry));
  } catch (error) {
    console.error('campaign.route.render_unavailable', {
      campaignSlug: slug,
      message: error instanceof Error ? error.message : 'unknown error',
    });
    contentUnavailable = true;
  }
}

const campaignSlug = entry ? extractCampaignSlugFromEntryId(entry.id) : slug ?? '';
const accessResolver = await createCampaignRequestAccessResolver({
  request: Astro.request,
  locals: Astro.locals,
  hostname: Astro.url.hostname,
});
const canView =
  entry && !contentUnavailable
    ? await canViewCampaignContentAsync({
        visibility: entry.data.visibility,
        campaignSlug,
        access: accessResolver,
      })
    : false;
const campaignAccess = entry && !contentUnavailable
  ? await accessResolver.hasCampaignAccess(campaignSlug)
  : { isMember: false, isGm: false };
const canAdministerCampaign = campaignAccess.isGm;

const sectionCards: CampaignSectionCard[] = [];
if (entry && canView && !contentUnavailable) {
  const sectionDefinitions = CAMPAIGN_FAMILY_SEGMENTS.map((segment) => {
    const family = getCampaignFamilyBySegment(segment);
    return {
      segment,
      label: family?.label ?? segment,
      description: family?.description ?? 'Campaign content.',
      href: `/campaigns/${campaignSlug}/${segment}`,
      entries: familyEntries.filter(
        (familyEntry) => familyEntry.collection === family?.collection && familyEntry.data.campaign === campaignSlug,
      ),
    };
  });

  for (const section of sectionDefinitions) {
    let visibleCount = 0;
    let latestUpdated: Date | null = null;
    const totalCount = section.entries.length;

    for (const sectionEntry of section.entries) {
      const effectiveVisibility = resolveCampaignContentVisibility({
        campaignSlug,
        contentVisibility: sectionEntry.data.visibility,
        campaignVisibility: entry.data.visibility,
      });
      const canViewSectionEntry = await canViewCampaignContentAsync({
        visibility: effectiveVisibility,
        campaignSlug,
        access: accessResolver,
      });

      if (!canViewSectionEntry) {
        continue;
      }

      visibleCount += 1;
      const candidateDate = pickCampaignEntryDate(sectionEntry.data);
      if (!latestUpdated || candidateDate.getTime() > latestUpdated.getTime()) {
        latestUpdated = candidateDate;
      }
    }

    sectionCards.push({
      segment: section.segment,
      label: section.label,
      description: section.description,
      href: section.href,
      count: visibleCount,
      totalCount,
      restrictedCount: Math.max(totalCount - visibleCount, 0),
      latestUpdated,
    });
  }
}

const layoutContent =
  entry ??
  {
    title: 'Restricted campaign content',
    excerpt: 'Campaign content is temporarily unavailable or restricted.',
    authors: ['World of Aletheia'],
    visibility: 'gm',
    tags: [],
  };
const robots = entry && entry.data.visibility === 'public' && canView && !contentUnavailable
  ? undefined
  : 'noindex, nofollow';
const hasRestrictedSectionRecords = sectionCards.some((section) => section.restrictedCount > 0);
const loginHref = `/login?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`;
---

<CampaignsContentLayout content={layoutContent} robots={robots} showContextMetadata={canView && !contentUnavailable}>
  {canView && Content && !contentUnavailable ? (
    <article class="reading-prose">
      <Content />

      <section class="not-prose mt-12 border-t border-base-300 pt-8">
        <div class="mb-6 flex flex-col gap-3">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <h2 class="text-2xl font-bold text-ink-950">Campaign Records</h2>
              <p class="meta-muted max-w-3xl">
                Browse family-specific campaign records. Protected records are counted without exposing their titles.
              </p>
            </div>
            {canAdministerCampaign && (
              <a href={`/campaigns/${campaignSlug}/admin`} class="ui-button ui-button--primary ui-button--sm">
                Manage members
              </a>
            )}
          </div>
          {hasRestrictedSectionRecords && (
            <div class="inline-flex w-fit items-center gap-3 rounded-xl border border-base-300 bg-base-200/70 px-3 py-2 text-sm text-ink-800">
              <span>Some records are hidden until you sign in.</span>
              <a href={loginHref} class="ui-button ui-button--primary ui-button--xs">Sign in</a>
            </div>
          )}
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {sectionCards.map((section) => (
            <a href={section.href} class="group flex h-full flex-col rounded-[1.45rem] border border-base-300/80 bg-base-100 p-5 shadow-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
              <div class="flex-1 space-y-3">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">{section.label}</h3>
                  <span class="ui-pill ui-pill--outline">{section.count} / {section.totalCount}</span>
                </div>
                <p class="text-sm text-ink-800">{section.description}</p>
                <div class="flex flex-wrap items-center justify-between gap-2 text-sm meta-muted">
                  <span>{section.count === 1 ? '1 visible entry' : `${section.count} visible entries`}</span>
                  {section.restrictedCount > 0 && (
                    <span>{section.restrictedCount} protected</span>
                  )}
                  <span>
                    {section.latestUpdated
                      ? `Updated ${section.latestUpdated.toLocaleDateString('en-GB')}`
                      : section.restrictedCount > 0
                        ? 'Sign in to reveal entries'
                        : 'No visible entries yet'}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    </article>
  ) : (
    <article class="reading-prose">
      <h2>Restricted campaign content</h2>
      <p>
        This campaign entry is restricted or temporarily unavailable. Sign in with your account and ensure you have the
        required campaign access level.
      </p>
      <p><a href={loginHref} class="ui-button ui-button--primary ui-button--sm">Sign in to continue</a></p>
    </article>
  )}
</CampaignsContentLayout>
