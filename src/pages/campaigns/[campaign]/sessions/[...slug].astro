---
import { getCollection, getEntry, render } from 'astro:content';
import CampaignsContentLayout from '@layouts/CampaignsContentLayout.astro';
import {
  canViewCampaignContentAsync,
  createCampaignAccessResolverFromRequest,
  resolveCampaignContentVisibility,
} from '@utils/campaign-access';
import { getCampaignGmAssignmentsForEnv, getCampaignMembershipConfigForEnv } from '@utils/campaign-membership-config';

interface RuntimeLocals {
  runtime?: {
    env?: Record<string, unknown>;
  };
}

export async function getStaticPaths() {
  const sessionsCollection = await getCollection('sessions');
  const uniqueParams = new Set<string>();
  const paths: Array<{ params: { campaign: string; slug: string } }> = [];

  for (const item of sessionsCollection) {
    const parts = item.id.split('/');
    const campaign = item.data.campaign;
    const slug = parts[parts.length - 1];
    const key = `${campaign}:${slug}`;

    if (uniqueParams.has(key)) {
      continue;
    }

    uniqueParams.add(key);
    paths.push({ params: { campaign, slug } });
  }

  return paths;
}

// Get params from URL
const { campaign, slug } = Astro.params;

const campaignEntry = (await getCollection('campaigns')).find((entry) => {
  const campaignSlug = entry.id.split('/')[0];
  return campaignSlug === campaign || entry.data.campaign === campaign;
});

if (!campaignEntry) {
  throw new Error(`Campaign not found for slug "${campaign}"`);
}

const sessionEntry = (await getCollection('sessions')).find((entry) => {
  const parts = entry.id.split('/');
  const sessionSlug = parts[parts.length - 1];
  return entry.data.campaign === campaign && sessionSlug === slug;
});
if (!sessionEntry) {
  throw new Error(`Session not found for campaign "${campaign}" and slug "${slug}"`);
}

const session = {
  id: sessionEntry.id,
  slug,
  campaignSlug: sessionEntry.data.campaign,
  title: sessionEntry.data.title,
  date: sessionEntry.data.date,
  duration: sessionEntry.data.duration,
  type: sessionEntry.data.type,
  visibility: sessionEntry.data.visibility,
  excerpt: sessionEntry.data.excerpt,
  tags: sessionEntry.data.tags,
  author: sessionEntry.data.author,
  createdAt: sessionEntry.data.created,
};

const campaignDetail = {
  slug: campaignEntry.id.split('/')[0],
  title: campaignEntry.data.title,
};

// Get all sessions for navigation
const allSessionEntries = await getCollection('sessions', (entry) => entry.data.campaign === campaign);
const uniqueSessionsBySlug = new Map<string, (typeof allSessionEntries)[number]>();
for (const entry of allSessionEntries) {
  const parts = entry.id.split('/');
  const sessionSlug = parts[parts.length - 1];
  if (!uniqueSessionsBySlug.has(sessionSlug)) {
    uniqueSessionsBySlug.set(sessionSlug, entry);
  }
}

const sortedSessions = Array.from(uniqueSessionsBySlug.values())
  .map((entry) => {
    const parts = entry.id.split('/');
    return {
      id: entry.id,
      slug: parts[parts.length - 1],
      title: entry.data.title,
      date: entry.data.date,
    };
  })
  .sort((a, b) => {
    if (!a.date || !b.date) return 0;
    return a.date.getTime() - b.date.getTime();
  });

// Find current index for prev/next navigation
const currentIndex = sortedSessions.findIndex(s => s.slug === slug);
const previousSession = currentIndex > 0 ? sortedSessions[currentIndex - 1] : null;
const nextSession = currentIndex < sortedSessions.length - 1 ? sortedSessions[currentIndex + 1] : null;

const { Content } = await render(sessionEntry);

const runtimeEnv = (Astro.locals as RuntimeLocals).runtime?.env;
const membershipConfigRaw =
  typeof runtimeEnv?.CAMPAIGN_MEMBERSHIPS === 'string' && runtimeEnv.CAMPAIGN_MEMBERSHIPS.length > 0
    ? runtimeEnv.CAMPAIGN_MEMBERSHIPS
    : getCampaignMembershipConfigForEnv();
const gmAssignmentsConfigRaw =
  typeof runtimeEnv?.CAMPAIGN_GM_ASSIGNMENTS === 'string' && runtimeEnv.CAMPAIGN_GM_ASSIGNMENTS.length > 0
    ? runtimeEnv.CAMPAIGN_GM_ASSIGNMENTS
    : getCampaignGmAssignmentsForEnv();
const allowLegacyEnvFallback = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
const accessResolver = createCampaignAccessResolverFromRequest({
  request: Astro.request,
  locals: Astro.locals,
  membershipConfigRaw,
  gmAssignmentsConfigRaw,
  allowLegacyEnvFallback,
});
const effectiveVisibility = resolveCampaignContentVisibility({
  campaignSlug: campaign!,
  contentVisibility: sessionEntry.data.visibility,
  campaignVisibility: campaignEntry.data.visibility,
});
const canViewSession = await canViewCampaignContentAsync({
  visibility: effectiveVisibility,
  campaignSlug: campaign!,
  access: accessResolver,
});

const title = `${session.title} - ${campaignDetail?.title || campaign}`;
---

<CampaignsContentLayout content={sessionEntry} title={title}>
  <article class="reading-prose">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm meta-muted not-prose">
      <a href="/campaigns" class="hover:text-primary-700">Campaigns</a>
      <span class="mx-2">/</span>
      {campaignDetail ? (
        <a href={`/campaigns/${campaign}`} class="hover:text-primary-700">{campaignDetail.title}</a>
      ) : (
        <span>{campaign}</span>
      )}
      <span class="mx-2">/</span>
      <a href={`/campaigns/${campaign}/sessions`} class="hover:text-primary-700">Sessions</a>
      <span class="mx-2">/</span>
      <span class="text-ink-900 font-medium">{session.title}</span>
    </nav>

    <!-- Session Header -->
    <header class="mb-8 not-prose">
      <div class="flex items-center gap-2 mb-2">
        <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm uppercase">{session.type}</span>
        {session.visibility && (
          <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded text-sm">{session.visibility}</span>
        )}
      </div>
      
      <h1 class="text-3xl font-bold text-ink-950 mb-4">{session.title}</h1>
      
      <div class="flex flex-wrap items-center gap-4 text-sm meta-muted">
        {session.date && (
          <div class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {session.date.toLocaleDateString('en-US', { 
              weekday: 'long', 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </div>
        )}
        {session.duration && (
          <div class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {Math.floor(session.duration / 60)}h {session.duration % 60}m
          </div>
        )}
      </div>
    </header>

    {canViewSession ? (
      <Content />
    ) : (
      <section>
        <h2>Restricted campaign session</h2>
        <p>
          This session is restricted. Sign in with your account and ensure you have the required campaign access
          level.
        </p>
        <p><a href={`/login?next=${encodeURIComponent(Astro.url.pathname)}`}>Sign in to continue</a></p>
      </section>
    )}

    <!-- Session Navigation -->
    <nav class="mt-12 pt-6 border-t not-prose">
      <div class="flex justify-between items-center">
        {previousSession ? (
          <a 
            href={`/campaigns/${campaign}/sessions/${previousSession.slug}`}
            class="flex items-center text-primary-700 hover:text-primary-800"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <div class="text-left">
              <div class="text-xs meta-muted">Previous Session</div>
              <div class="font-medium">{previousSession.title}</div>
            </div>
          </a>
        ) : (
          <div />
        )}
        
        <a 
          href={`/campaigns/${campaign}/sessions`}
          class="meta-muted hover:text-ink-900 text-sm"
        >
          All Sessions
        </a>
        
        {nextSession ? (
          <a 
            href={`/campaigns/${campaign}/sessions/${nextSession.slug}`}
            class="flex items-center text-primary-700 hover:text-primary-800"
          >
            <div class="text-right">
              <div class="text-xs meta-muted">Next Session</div>
              <div class="font-medium">{nextSession.title}</div>
            </div>
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : (
          <div />
        )}
      </div>
    </nav>
  </article>
</CampaignsContentLayout>
