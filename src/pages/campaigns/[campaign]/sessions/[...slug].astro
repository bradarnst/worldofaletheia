---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CampaignsContentLayout from '@layouts/CampaignsContentLayout.astro';
import {
  canViewCampaignContentAsync,
  resolveCampaignContentVisibility,
} from '@utils/campaign-access';
import { extractCampaignSlugFromEntryId } from '@utils/campaign-collections';
import { createCampaignRequestAccessResolver } from '~/lib/campaign-request-access';

export async function getStaticPaths() {
  const sessionsCollection = await getCollection('sessions');
  const uniqueParams = new Set<string>();
  const paths: Array<{ params: { campaign: string; slug: string } }> = [];

  for (const item of sessionsCollection) {
    const parts = item.id.split('/');
    const campaign = item.data.campaign;
    const slug = parts[parts.length - 1];
    const key = `${campaign}:${slug}`;

    if (uniqueParams.has(key)) {
      continue;
    }

    uniqueParams.add(key);
    paths.push({ params: { campaign, slug } });
  }

  return paths;
}

// Get params from URL
const { campaign, slug } = Astro.params;

let campaignEntry: CollectionEntry<'campaigns'> | null = null;
let sessionEntry: CollectionEntry<'sessions'> | null = null;
let allSessionEntries: CollectionEntry<'sessions'>[] = [];
let contentUnavailable = false;

try {
  const [campaignsCollection, sessionsCollection] = await Promise.all([
    getCollection('campaigns'),
    getCollection('sessions'),
  ]);

  campaignEntry = campaignsCollection.find((entry) => {
    const campaignSlug = extractCampaignSlugFromEntryId(entry.id);
    return campaignSlug === campaign || entry.data.campaign === campaign;
  }) ?? null;

  sessionEntry = sessionsCollection.find((entry) => {
    const parts = entry.id.split('/');
    const sessionSlug = parts[parts.length - 1];
    return entry.data.campaign === campaign && sessionSlug === slug;
  }) ?? null;

  allSessionEntries = sessionsCollection.filter((entry) => entry.data.campaign === campaign);
} catch (error) {
  console.error('campaign.session.detail_unavailable', {
    campaignSlug: campaign,
    sessionSlug: slug,
    message: error instanceof Error ? error.message : 'unknown error',
  });
  contentUnavailable = true;
}

if (!campaignEntry && !contentUnavailable) {
  throw new Error(`Campaign not found for slug "${campaign}"`);
}

if (!sessionEntry && !contentUnavailable) {
  throw new Error(`Session not found for campaign "${campaign}" and slug "${slug}"`);
}

const session = {
  id: sessionEntry?.id ?? `${campaign ?? 'campaign'}/${slug ?? 'session'}`,
  slug,
  campaignSlug: sessionEntry?.data.campaign ?? campaign,
  title: sessionEntry?.data.title ?? 'Restricted campaign session',
  date: sessionEntry?.data.date,
  duration: sessionEntry?.data.duration,
  type: sessionEntry?.data.type ?? 'session',
  visibility: sessionEntry?.data.visibility ?? 'gm',
  excerpt: sessionEntry?.data.excerpt ?? 'Campaign session content is temporarily unavailable or restricted.',
  tags: sessionEntry?.data.tags ?? [],
  author: sessionEntry?.data.author ?? 'World of Aletheia',
  createdAt: sessionEntry?.data.created,
};

const campaignDetail = {
  slug: campaignEntry ? extractCampaignSlugFromEntryId(campaignEntry.id) : campaign ?? '',
  title: campaignEntry?.data.title ?? 'Campaign',
};

const uniqueSessionsBySlug = new Map<string, (typeof allSessionEntries)[number]>();
for (const entry of contentUnavailable ? [] : allSessionEntries) {
  const parts = entry.id.split('/');
  const sessionSlug = parts[parts.length - 1];
  if (!uniqueSessionsBySlug.has(sessionSlug)) {
    uniqueSessionsBySlug.set(sessionSlug, entry);
  }
}

const sortedSessions = Array.from(uniqueSessionsBySlug.values())
  .map((entry) => {
    const parts = entry.id.split('/');
    return {
      id: entry.id,
      slug: parts[parts.length - 1],
      title: entry.data.title,
      date: entry.data.date,
    };
  })
  .sort((a, b) => {
    if (!a.date || !b.date) return 0;
    return a.date.getTime() - b.date.getTime();
  });

// Find current index for prev/next navigation
const currentIndex = sortedSessions.findIndex(s => s.slug === slug);
const previousSession = currentIndex > 0 ? sortedSessions[currentIndex - 1] : null;
const nextSession = currentIndex < sortedSessions.length - 1 ? sortedSessions[currentIndex + 1] : null;

let Content = null;
if (sessionEntry && !contentUnavailable) {
  try {
    ({ Content } = await render(sessionEntry));
  } catch (error) {
    console.error('campaign.session.render_unavailable', {
      campaignSlug: campaign,
      sessionSlug: slug,
      message: error instanceof Error ? error.message : 'unknown error',
    });
    contentUnavailable = true;
  }
}

const accessResolver = await createCampaignRequestAccessResolver({
  request: Astro.request,
  locals: Astro.locals,
  hostname: Astro.url.hostname,
});
const effectiveVisibility =
  sessionEntry && campaignEntry
    ? resolveCampaignContentVisibility({
        campaignSlug: campaign ?? '',
        contentVisibility: sessionEntry.data.visibility,
        campaignVisibility: campaignEntry.data.visibility,
      })
    : 'gm';
const canViewSession =
  sessionEntry && campaignEntry && !contentUnavailable
    ? await canViewCampaignContentAsync({
        visibility: effectiveVisibility,
        campaignSlug: campaign ?? '',
        access: accessResolver,
      })
    : false;

const title = `${session.title} - ${campaignDetail?.title || campaign}`;
const layoutContent =
  sessionEntry ??
  {
    title: session.title,
    excerpt: session.excerpt,
    author: session.author,
    visibility: session.visibility,
    tags: session.tags,
    campaign: campaign ?? '',
    created: session.createdAt,
  };
const loginHref = `/login?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`;
const robots = effectiveVisibility === 'public' && canViewSession && !contentUnavailable
  ? undefined
  : 'noindex, nofollow';
---

<CampaignsContentLayout content={layoutContent} title={title} robots={robots}>
  <article class="reading-prose">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm meta-muted not-prose">
      <a href="/campaigns" class="hover:text-primary">Campaigns</a>
      <span class="mx-2">/</span>
      {campaignDetail ? (
        <a href={`/campaigns/${campaign}`} class="hover:text-primary">{campaignDetail.title}</a>
      ) : (
        <span>{campaign}</span>
      )}
      <span class="mx-2">/</span>
      <a href={`/campaigns/${campaign}/sessions`} class="hover:text-primary">Sessions</a>
      <span class="mx-2">/</span>
      <span class="text-ink-900 font-medium">{session.title}</span>
    </nav>

    <header class="mb-8 not-prose">
      <div class="flex items-center gap-2 mb-2">
        <span class="ui-pill ui-pill--outline uppercase">{session.type}</span>
        {session.visibility && (
          <span class="ui-pill ui-pill--ghost">{session.visibility}</span>
        )}
      </div>
      
      <h1 class="text-3xl font-bold text-ink-950 mb-4">{session.title}</h1>
      
      <div class="flex flex-wrap items-center gap-4 text-sm meta-muted">
        {session.date && (
          <div class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {session.date.toLocaleDateString('en-US', { 
              weekday: 'long', 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </div>
        )}
        {session.duration && (
          <div class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {Math.floor(session.duration / 60)}h {session.duration % 60}m
          </div>
        )}
      </div>
    </header>

    {canViewSession && Content && !contentUnavailable ? (
      <Content />
    ) : (
      <section>
        <h2>Restricted campaign session</h2>
        <p>
          This session is restricted or temporarily unavailable. Sign in with your account and ensure you have the
          required campaign access level.
        </p>
        <p><a href={loginHref} class="ui-button ui-button--primary ui-button--sm">Sign in to continue</a></p>
      </section>
    )}

    <nav class="mt-12 pt-6 border-t not-prose">
      <div class="flex justify-between items-center">
        {previousSession ? (
          <a 
            href={`/campaigns/${campaign}/sessions/${previousSession.slug}`}
            class="flex items-center text-primary transition-colors hover:text-secondary"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <div class="text-left">
              <div class="text-xs meta-muted">Previous Session</div>
              <div class="font-medium">{previousSession.title}</div>
            </div>
          </a>
        ) : (
          <div />
        )}
        
        <a 
          href={`/campaigns/${campaign}/sessions`}
          class="meta-muted hover:text-ink-900 text-sm"
        >
          All Sessions
        </a>
        
        {nextSession ? (
          <a 
            href={`/campaigns/${campaign}/sessions/${nextSession.slug}`}
            class="flex items-center text-primary transition-colors hover:text-secondary"
          >
            <div class="text-right">
              <div class="text-xs meta-muted">Next Session</div>
              <div class="font-medium">{nextSession.title}</div>
            </div>
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : (
          <div />
        )}
      </div>
    </nav>
  </article>
</CampaignsContentLayout>
