---
import { getCollection, getEntry } from 'astro:content';
import CampaignsLayout from '@layouts/CampaignsLayout.astro';
import {
  canViewCampaignContentAsync,
  createCampaignAccessResolverFromRequest,
  resolveCampaignContentVisibility,
} from '@utils/campaign-access';
import { getCampaignGmAssignmentsForEnv, getCampaignMembershipConfigForEnv } from '@utils/campaign-membership-config';

interface RuntimeLocals {
  runtime?: {
    env?: Record<string, unknown>;
  };
}

export async function getStaticPaths() {
  const campaignsCollection = await getCollection('campaigns');

  return campaignsCollection.map((item) => ({
    params: { campaign: item.id.split('/')[0] },
  }));
}

// Get the campaign slug from the URL
const { campaign } = Astro.params;

const campaignEntry =
  (await getCollection('campaigns')).find((entry) => entry.id.split('/')[0] === campaign);

if (!campaignEntry) {
  throw new Error(`Campaign not found for slug "${campaign}"`);
}

const campaignDetail = {
  slug: campaignEntry.id.split('/')[0],
  title: campaignEntry.data.title,
  excerpt: campaignEntry.data.excerpt,
};

const allSessions = await getCollection('sessions');
const runtimeEnv = (Astro.locals as RuntimeLocals).runtime?.env;
const membershipConfigRaw =
  typeof runtimeEnv?.CAMPAIGN_MEMBERSHIPS === 'string' && runtimeEnv.CAMPAIGN_MEMBERSHIPS.length > 0
    ? runtimeEnv.CAMPAIGN_MEMBERSHIPS
    : getCampaignMembershipConfigForEnv();
const gmAssignmentsConfigRaw =
  typeof runtimeEnv?.CAMPAIGN_GM_ASSIGNMENTS === 'string' && runtimeEnv.CAMPAIGN_GM_ASSIGNMENTS.length > 0
    ? runtimeEnv.CAMPAIGN_GM_ASSIGNMENTS
    : getCampaignGmAssignmentsForEnv();
const allowLegacyEnvFallback = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
const accessResolver = createCampaignAccessResolverFromRequest({
  request: Astro.request,
  locals: Astro.locals,
  membershipConfigRaw,
  gmAssignmentsConfigRaw,
  allowLegacyEnvFallback,
});

const campaignSessions = allSessions.filter((entry) => entry.data.campaign === campaign);
const sessionsWithVisibility = await Promise.all(
  campaignSessions.map(async (entry) => {
    const effectiveVisibility = resolveCampaignContentVisibility({
      campaignSlug: campaign!,
      contentVisibility: entry.data.visibility,
      campaignVisibility: campaignEntry.data.visibility,
    });
    const canView = await canViewCampaignContentAsync({
      visibility: effectiveVisibility,
      campaignSlug: campaign!,
      access: accessResolver,
    });
    return { entry, canView };
  }),
);

const sessions = sessionsWithVisibility
  .filter((item) => item.canView)
  .map((item) => item.entry)
  .map((entry) => {
    const parts = entry.id.split('/');
    const sessionSlug = parts[parts.length - 1];

    return {
      id: entry.id,
      slug: sessionSlug,
      title: entry.data.title,
      date: entry.data.date,
      duration: entry.data.duration,
      type: entry.data.type,
      visibility: entry.data.visibility,
      excerpt: entry.data.excerpt,
      tags: entry.data.tags,
      campaignSlug: entry.data.campaign,
    };
  });

// Sort sessions by date (newest first)
const sortedSessions = sessions.sort((a, b) => {
  if (!a.date || !b.date) return 0;
  return b.date.getTime() - a.date.getTime();
});

const title = campaignDetail ? `${campaignDetail.title} - Sessions` : 'Campaign Sessions';
---

<CampaignsLayout title={title} description={`Session notes for ${campaignDetail?.title || campaign}`}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-gray-600">
      <a href="/campaigns" class="hover:text-blue-600">Campaigns</a>
      <span class="mx-2">/</span>
      {campaignDetail ? (
        <a href={`/campaigns/${campaign}`} class="hover:text-blue-600">{campaignDetail.title}</a>
      ) : (
        <span>{campaign}</span>
      )}
      <span class="mx-2">/</span>
      <span class="text-gray-900 font-medium">Sessions</span>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">
        {campaignDetail?.title || campaign}
      </h1>
      <h2 class="text-xl text-gray-600">Session Notes</h2>
      {campaignDetail?.excerpt && (
        <p class="mt-4 text-gray-700 max-w-3xl">{campaignDetail.excerpt}</p>
      )}
    </div>

    <!-- Sessions List -->
    <div class="mb-12">
      <h3 class="text-2xl font-bold text-gray-900 mb-6">
        Sessions ({sortedSessions.length})
      </h3>
      
      {sortedSessions.length === 0 ? (
        <div class="bg-gray-50 rounded-lg p-8 text-center">
          <p class="text-gray-600">No sessions found for this campaign yet.</p>
        </div>
      ) : (
        <div class="space-y-4">
          {sortedSessions.map((session) => (
            <a 
              href={`/campaigns/${campaign}/sessions/${session.slug}`}
              class="block bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md hover:border-blue-300 transition-all"
            >
              <div class="flex items-start justify-between">
                <div>
                  <h4 class="text-lg font-semibold text-gray-900 mb-1">{session.title}</h4>
                  {session.excerpt && (
                    <p class="text-gray-600 text-sm mb-2">{session.excerpt}</p>
                  )}
                  <div class="flex items-center gap-4 text-sm text-gray-500">
                    {session.date && (
                      <span>
                        {session.date.toLocaleDateString('en-US', { 
                          weekday: 'long', 
                          year: 'numeric', 
                          month: 'long', 
                          day: 'numeric' 
                        })}
                      </span>
                    )}
                    {session.duration && (
                      <span>{Math.floor(session.duration / 60)}h {session.duration % 60}m</span>
                    )}
                    <span class="px-2 py-0.5 bg-gray-100 rounded text-xs uppercase">{session.type}</span>
                    {session.visibility && (
                      <span class="px-2 py-0.5 bg-blue-100 text-blue-700 rounded text-xs">{session.visibility}</span>
                    )}
                  </div>
                </div>
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Back to Campaign -->
    <div class="border-t pt-6">
      <a 
        href={`/campaigns/${campaign}`}
        class="inline-flex items-center text-blue-600 hover:text-blue-800"
      >
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Campaign
      </a>
    </div>
  </div>
</CampaignsLayout>

