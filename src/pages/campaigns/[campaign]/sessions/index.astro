---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CampaignsLayout from '@layouts/CampaignsLayout.astro';
import {
  canViewCampaignContentAsync,
  resolveCampaignContentVisibility,
} from '@utils/campaign-access';
import { extractCampaignSlugFromEntryId } from '@utils/campaign-collections';
import { createCampaignRequestAccessResolver } from '~/lib/campaign-request-access';

export async function getStaticPaths() {
  const campaignsCollection = await getCollection('campaigns');

  return campaignsCollection.map((item) => ({
    params: { campaign: extractCampaignSlugFromEntryId(item.id) || item.id },
  }));
}

// Get the campaign slug from the URL
const { campaign } = Astro.params;

let campaignEntry: CollectionEntry<'campaigns'> | null = null;
let allSessions: CollectionEntry<'sessions'>[] = [];
let contentUnavailable = false;

try {
  const [campaignsCollection, sessionsCollection] = await Promise.all([
    getCollection('campaigns'),
    getCollection('sessions'),
  ]);
  campaignEntry = campaignsCollection.find((entry) => extractCampaignSlugFromEntryId(entry.id) === campaign) ?? null;
  allSessions = sessionsCollection;
} catch (error) {
  console.error('campaign.sessions.index_unavailable', {
    campaignSlug: campaign,
    message: error instanceof Error ? error.message : 'unknown error',
  });
  contentUnavailable = true;
}

if (!campaignEntry && !contentUnavailable) {
  throw new Error(`Campaign not found for slug "${campaign}"`);
}

const campaignDetail = {
  slug: campaignEntry ? extractCampaignSlugFromEntryId(campaignEntry.id) : campaign ?? '',
  title: campaignEntry?.data.title ?? 'Campaign Sessions',
  excerpt: campaignEntry?.data.excerpt,
};

const accessResolver = await createCampaignRequestAccessResolver({
  request: Astro.request,
  locals: Astro.locals,
  hostname: Astro.url.hostname,
});

const sessionsForCampaign = allSessions.filter((entry) => entry.data.campaign === campaign);

const sessions = campaignEntry && !contentUnavailable
  ? (
      await Promise.all(
        sessionsForCampaign.map(async (entry) => {
            const effectiveVisibility = resolveCampaignContentVisibility({
              campaignSlug: campaign ?? '',
              contentVisibility: entry.data.visibility,
              campaignVisibility: campaignEntry.data.visibility,
            });
            const canView = await canViewCampaignContentAsync({
              visibility: effectiveVisibility,
              campaignSlug: campaign ?? '',
              access: accessResolver,
            });

            if (!canView) {
              return null;
            }

            const parts = entry.id.split('/');
            return {
              id: entry.id,
              slug: parts[parts.length - 1],
              title: entry.data.title,
              date: entry.data.date,
              duration: entry.data.duration,
              type: entry.data.type,
              visibility: entry.data.visibility,
              excerpt: entry.data.excerpt,
              tags: entry.data.tags,
              campaignSlug: entry.data.campaign,
            };
          }),
      )
    ).filter((entry) => entry !== null)
  : [];

// Sort sessions by date (newest first)
const sortedSessions = sessions.sort((a, b) => {
  if (!a.date || !b.date) return 0;
  return b.date.getTime() - a.date.getTime();
});

const title = campaignDetail ? `${campaignDetail.title} - Sessions` : 'Campaign Sessions';
const totalSessionsCount = sessionsForCampaign.length;
const restrictedSessionsCount = Math.max(totalSessionsCount - sortedSessions.length, 0);
const robots = campaignEntry && campaignEntry.data.visibility === 'public' && !contentUnavailable
  ? undefined
  : 'noindex, nofollow';
const loginHref = `/login?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`;
---

<CampaignsLayout title={title} description={`Session notes for ${campaignDetail?.title || campaign}`} robots={robots}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <nav class="mb-6 text-sm meta-muted">
      <a href="/campaigns" class="hover:text-primary">Campaigns</a>
      <span class="mx-2">/</span>
      {campaignDetail ? (
        <a href={`/campaigns/${campaign}`} class="hover:text-primary">{campaignDetail.title}</a>
      ) : (
        <span>{campaign}</span>
      )}
      <span class="mx-2">/</span>
      <span class="font-medium text-ink-900">Sessions</span>
    </nav>

    <div class="mb-12">
      <h1 class="text-3xl font-bold text-ink-950 mb-2 md:text-4xl">
        {campaignDetail?.title || campaign}
      </h1>
      <h2 class="text-xl text-ink-700">Session Notes</h2>
      {campaignDetail?.excerpt && (
        <p class="mt-4 max-w-3xl text-ink-800">{campaignDetail.excerpt}</p>
      )}
      {contentUnavailable && (
        <div class="mt-4 rounded-xl border border-warning/40 bg-warning/10 p-4 text-sm text-ink-800">
          Session discovery is temporarily unavailable. Protected campaign content stays fail-closed until the cloud
          source and index are healthy again.
        </div>
      )}

      {restrictedSessionsCount > 0 && (
        <div class="mt-4 ui-surface ui-surface--muted p-4 text-sm text-ink-800">
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <p>
              {restrictedSessionsCount}
              {' '}
              protected {restrictedSessionsCount === 1 ? 'session is' : 'sessions are'} hidden in this list.
            </p>
            <a href={loginHref} class="ui-button ui-button--primary ui-button--sm">Sign in to reveal</a>
          </div>
        </div>
      )}
    </div>

    <div class="mb-12">
      <h3 class="text-2xl font-bold text-ink-950 mb-6">
        Sessions ({sortedSessions.length} / {totalSessionsCount} visible)
      </h3>
      
      {sortedSessions.length === 0 ? (
        <div class="rounded-[1.4rem] border border-base-300 bg-base-200/50 p-8 text-center">
          <p class="text-ink-700">
            {restrictedSessionsCount > 0
              ? 'No visible sessions found. Sign in to reveal protected sessions.'
              : 'No sessions found for this campaign yet.'}
          </p>
        </div>
      ) : (
        <div class="space-y-4">
          {sortedSessions.map((session) => (
            <a 
              href={`/campaigns/${campaign}/sessions/${session.slug}`}
              class="group block rounded-[1.45rem] border border-base-300/80 bg-base-100 p-6 shadow-sm transition duration-200 hover:border-primary/35 hover:shadow-lg"
            >
              <div class="flex items-start justify-between">
                <div>
                  <h4 class="mb-1 text-lg font-semibold text-ink-950 transition-colors group-hover:text-primary">{session.title}</h4>
                  {session.excerpt && (
                    <p class="mb-2 text-sm text-ink-700">{session.excerpt}</p>
                  )}
                  <div class="flex flex-wrap items-center gap-2 text-sm meta-muted">
                    {session.date && (
                      <span class="ui-pill ui-pill--ghost">
                        {session.date.toLocaleDateString('en-US', { 
                          weekday: 'long', 
                          year: 'numeric', 
                          month: 'long', 
                          day: 'numeric' 
                        })}
                      </span>
                    )}
                    {session.duration && (
                      <span class="ui-pill ui-pill--ghost">{Math.floor(session.duration / 60)}h {session.duration % 60}m</span>
                    )}
                    <span class="ui-pill ui-pill--outline uppercase">{session.type}</span>
                    {session.visibility && (
                      <span class="ui-pill ui-pill--primary">{session.visibility}</span>
                    )}
                  </div>
                </div>
                <svg class="mt-1 h-5 w-5 text-ink-500 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <div class="border-t border-base-300 pt-6">
      <a 
        href={`/campaigns/${campaign}`}
        class="inline-flex items-center gap-2 text-primary transition-colors hover:text-secondary"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Campaign
      </a>
    </div>
  </div>
</CampaignsLayout>
