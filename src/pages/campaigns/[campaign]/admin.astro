---
import { getCollection } from 'astro:content';
import CampaignsLayout from '@layouts/CampaignsLayout.astro';
import { getRequestSession } from '~/lib/auth-session';
import { createCampaignMembershipRepoFromLocals } from '~/lib/campaign-membership-repo';
import { extractCampaignSlugFromEntryId } from '@utils/campaign-collections';

export const prerender = false;

interface DashboardMember {
  userId: string;
  displayName: string | null;
  email: string;
  role: 'member' | 'gm';
  joinedAt: string | null;
  updatedAt: string | null;
}

const { campaign } = Astro.params;
const campaignSlug = campaign ?? '';
const loginHref = `/login?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`;

let campaignTitle = campaignSlug;
let campaignExcerpt: string | undefined;
let contentUnavailable = false;
let campaignFound = false;

try {
  const campaigns = await getCollection('campaigns');
  const campaignEntry = campaigns.find((entry) => extractCampaignSlugFromEntryId(entry.id) === campaignSlug) ?? null;

  if (campaignEntry) {
    campaignFound = true;
    campaignTitle = campaignEntry.data.title;
    campaignExcerpt = campaignEntry.data.excerpt;
  }
} catch (error) {
  console.error('campaign.admin.content_unavailable', {
    campaignSlug,
    message: error instanceof Error ? error.message : 'unknown error',
  });
  contentUnavailable = true;
}

const session = await getRequestSession(Astro.request, Astro.locals);
let canAdministerUsers = false;
let members: DashboardMember[] = [];
let memberCount = 0;
let gmCount = 0;
let dataUnavailable = false;

if (session && campaignFound && !contentUnavailable) {
  try {
    const repo = await createCampaignMembershipRepoFromLocals(Astro.locals);
    canAdministerUsers = await repo.isUserGmOfCampaign(session.user.id, campaignSlug);

    if (canAdministerUsers) {
      const [memberPage, campaignGmCount] = await Promise.all([
        repo.listCampaignMembers({ campaignSlug, limit: 100 }),
        repo.countCampaignGms(campaignSlug),
      ]);
      members = memberPage.items;
      memberCount = members.length;
      gmCount = campaignGmCount;
    }
  } catch (error) {
    console.error('campaign.admin.membership_lookup_failed', {
      campaignSlug,
      actorUserId: session.user.id,
      message: error instanceof Error ? error.message : 'unknown error',
    });
    dataUnavailable = true;
  }
}

const title = campaignFound ? `${campaignTitle} - Campaign Administration` : 'Campaign Administration';
const status = !session
  ? 'unauthenticated'
  : contentUnavailable || dataUnavailable
    ? 'unavailable'
    : !campaignFound
      ? 'not-found'
      : canAdministerUsers
        ? 'authorized'
        : 'forbidden';

function formatTimestamp(value: string | null): string {
  if (!value) {
    return 'Unknown';
  }

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return date.toLocaleString('en-GB', {
    dateStyle: 'medium',
    timeStyle: 'short',
  });
}
---

<CampaignsLayout title={title} description={`Campaign administration for ${campaignTitle}`} robots="noindex,nofollow">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <nav class="mb-6 text-sm meta-muted">
      <a href="/campaigns" class="hover:text-primary">Campaigns</a>
      <span class="mx-2">/</span>
      {campaignFound ? (
        <a href={`/campaigns/${campaignSlug}`} class="hover:text-primary">{campaignTitle}</a>
      ) : (
        <span>{campaignSlug || 'Unknown campaign'}</span>
      )}
      <span class="mx-2">/</span>
      <span class="font-medium text-ink-900">Administration</span>
    </nav>

    <header class="mb-8">
      <div class="mb-3 flex flex-wrap items-center gap-3">
        <span class="ui-pill ui-pill--outline">Campaign tools</span>
        {status === 'authorized' && <span class="badge badge-primary">GM access</span>}
      </div>
      <h1 class="mb-3 text-3xl font-bold text-ink-950 md:text-4xl">{campaignTitle}</h1>
      <p class="max-w-3xl text-ink-800">
        {campaignExcerpt ?? 'Review campaign-scoped membership and GM capability for this campaign.'}
      </p>
    </header>

    {status === 'unauthenticated' && (
      <section class="ui-surface p-6">
        <h2 class="mb-2 text-xl font-semibold text-ink-950">Sign in required</h2>
        <p class="mb-4 text-ink-800">Campaign administration is available only to signed-in campaign GMs.</p>
        <a href={loginHref} class="ui-button ui-button--primary">Sign in to continue</a>
      </section>
    )}

    {status === 'forbidden' && (
      <section class="ui-surface p-6">
        <h2 class="mb-2 text-xl font-semibold text-ink-950">Campaign permission required</h2>
        <p class="text-ink-800">
          Your account is signed in, but it does not have campaign GM authority for {campaignTitle}. Member and
          non-member accounts cannot administer campaign users.
        </p>
      </section>
    )}

    {status === 'not-found' && (
      <section class="ui-surface p-6">
        <h2 class="mb-2 text-xl font-semibold text-ink-950">Campaign not found</h2>
        <p class="text-ink-800">The requested campaign could not be found.</p>
      </section>
    )}

    {status === 'unavailable' && (
      <section class="ui-surface p-6">
        <h2 class="mb-2 text-xl font-semibold text-ink-950">Campaign administration unavailable</h2>
        <p class="text-ink-800">
          Campaign administration is temporarily unavailable. Protected campaign user data remains closed until the
          content and D1 membership sources are available.
        </p>
      </section>
    )}

    {status === 'authorized' && (
      <div class="space-y-8" data-campaign-admin data-campaign-slug={campaignSlug}>
        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          <div class="ui-surface p-5">
            <p class="meta-muted text-sm">Actor</p>
            <p class="mt-1 font-semibold text-ink-950">{session?.user.name || session?.user.email}</p>
          </div>
          <div class="ui-surface p-5">
            <p class="meta-muted text-sm">Capability source</p>
            <p class="mt-1 font-semibold text-ink-950">campaign-gm</p>
          </div>
          <div class="ui-surface p-5">
            <p class="meta-muted text-sm">Members shown</p>
            <p class="mt-1 font-semibold text-ink-950" data-member-count>{memberCount}</p>
          </div>
          <div class="ui-surface p-5">
            <p class="meta-muted text-sm">Campaign GMs</p>
            <p class="mt-1 font-semibold text-ink-950" data-gm-count>{gmCount}</p>
          </div>
        </section>

        <section class="ui-surface p-6">
          <div class="mb-5">
            <h2 class="text-2xl font-bold text-ink-950">Add existing account</h2>
            <p class="mt-2 text-sm text-ink-800">
              Add an existing World of Aletheia account by exact email address. This does not invite new users or
              search all users. If the person has not created an account yet, have them sign up first.
            </p>
          </div>

          <form class="grid gap-4 md:grid-cols-[minmax(0,1fr)_12rem_auto]" data-add-member-form>
            <label class="form-control">
              <span class="label-text font-medium text-ink-900">Email address</span>
              <input
                class="input input-bordered w-full"
                type="email"
                name="email"
                autocomplete="email"
                maxlength="254"
                required
                placeholder="player@example.com"
              />
            </label>

            <label class="form-control">
              <span class="label-text font-medium text-ink-900">Role</span>
              <select class="select select-bordered w-full" name="role" required>
                <option value="member" selected>Member</option>
                <option value="gm">GM</option>
              </select>
            </label>

            <div class="flex items-end">
              <button class="btn btn-primary w-full" type="submit" data-add-member-submit>Add member</button>
            </div>
          </form>

          <div class="alert mt-4 hidden" role="status" aria-live="polite" data-add-member-message></div>
        </section>

        <section class="ui-surface overflow-hidden p-0">
          <div class="border-b border-base-300 p-6">
            <h2 class="text-2xl font-bold text-ink-950">Campaign members</h2>
            <p class="mt-2 text-sm text-ink-800">
              Members are campaign-scoped only. Revocation, demotion, invitations, access requests, and global user
              search are intentionally not exposed here.
            </p>
          </div>

          <div class:list={["p-6 text-ink-800", members.length > 0 && "hidden"]} data-empty-members>
            No campaign members were found.
          </div>
          <div class:list={["overflow-x-auto", members.length === 0 && "hidden"]} data-members-table-wrapper>
            <table class="table w-full">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Joined</th>
                  <th>Updated</th>
                </tr>
              </thead>
              <tbody data-members-table-body>
                {members.map((member) => (
                  <tr data-member-row data-user-id={member.userId} data-role={member.role}>
                    <td>
                      <div class="font-medium text-ink-950">{member.displayName ?? 'Unnamed user'}</div>
                      <div class="text-xs meta-muted">{member.userId}</div>
                    </td>
                    <td>{member.email}</td>
                    <td>
                      <span class={member.role === 'gm' ? 'badge badge-primary' : 'badge badge-outline'}>
                        {member.role === 'gm' ? 'GM' : 'Member'}
                      </span>
                    </td>
                    <td>{formatTimestamp(member.joinedAt)}</td>
                    <td>{formatTimestamp(member.updatedAt)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </div>
    )}
  </div>
</CampaignsLayout>

<script>
  type CampaignRole = 'member' | 'gm';

  interface CampaignMemberDto {
    userId: string;
    displayName: string | null;
    email: string;
    role: CampaignRole;
    joinedAt: string | null;
    updatedAt: string | null;
  }

  interface CampaignMemberCreateResponseDto {
    member: CampaignMemberDto;
    outcome: 'created';
    confirmationMessage: string;
  }

  interface ErrorResponseBody {
    message?: string;
  }

  const root = document.querySelector<HTMLElement>('[data-campaign-admin]');
  const form = document.querySelector<HTMLFormElement>('[data-add-member-form]');
  const submitButton = document.querySelector<HTMLButtonElement>('[data-add-member-submit]');
  const message = document.querySelector<HTMLElement>('[data-add-member-message]');
  const tableBody = document.querySelector<HTMLTableSectionElement>('[data-members-table-body]');
  const tableWrapper = document.querySelector<HTMLElement>('[data-members-table-wrapper]');
  const emptyMembers = document.querySelector<HTMLElement>('[data-empty-members]');
  const memberCount = document.querySelector<HTMLElement>('[data-member-count]');
  const gmCount = document.querySelector<HTMLElement>('[data-gm-count]');

  function formatTimestampClient(value: string | null): string {
    if (!value) {
      return 'Unknown';
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return value;
    }

    return new Intl.DateTimeFormat('en-GB', {
      dateStyle: 'medium',
      timeStyle: 'short',
    }).format(date);
  }

  function setMessage(kind: 'success' | 'error', text: string): void {
    if (!message) {
      return;
    }

    message.textContent = text;
    message.classList.remove('hidden', 'alert-success', 'alert-error');
    message.classList.add(kind === 'success' ? 'alert-success' : 'alert-error');
  }

  function setPending(isPending: boolean): void {
    if (!form || !submitButton) {
      return;
    }

    for (const element of form.elements) {
      if (element instanceof HTMLInputElement || element instanceof HTMLSelectElement || element instanceof HTMLButtonElement) {
        element.disabled = isPending;
      }
    }
    submitButton.textContent = isPending ? 'Adding…' : 'Add member';
  }

  function renderRoleBadge(role: CampaignRole): HTMLSpanElement {
    const badge = document.createElement('span');
    badge.className = role === 'gm' ? 'badge badge-primary' : 'badge badge-outline';
    badge.textContent = role === 'gm' ? 'GM' : 'Member';
    return badge;
  }

  function renderMemberRow(member: CampaignMemberDto): HTMLTableRowElement {
    const row = document.createElement('tr');
    row.dataset.memberRow = '';
    row.dataset.userId = member.userId;
    row.dataset.role = member.role;

    const nameCell = document.createElement('td');
    const name = document.createElement('div');
    name.className = 'font-medium text-ink-950';
    name.textContent = member.displayName ?? 'Unnamed user';
    const userId = document.createElement('div');
    userId.className = 'text-xs meta-muted';
    userId.textContent = member.userId;
    nameCell.append(name, userId);

    const emailCell = document.createElement('td');
    emailCell.textContent = member.email;

    const roleCell = document.createElement('td');
    roleCell.append(renderRoleBadge(member.role));

    const joinedCell = document.createElement('td');
    joinedCell.textContent = formatTimestampClient(member.joinedAt);

    const updatedCell = document.createElement('td');
    updatedCell.textContent = formatTimestampClient(member.updatedAt);

    row.append(nameCell, emailCell, roleCell, joinedCell, updatedCell);
    return row;
  }

  function incrementCount(element: HTMLElement | null, delta: number): void {
    if (!element || delta === 0) {
      return;
    }

    const current = Number.parseInt(element.textContent ?? '0', 10);
    element.textContent = String((Number.isNaN(current) ? 0 : current) + delta);
  }

  function upsertMemberRow(member: CampaignMemberDto): void {
    if (!tableBody) {
      return;
    }

    const existingRow = tableBody.querySelector<HTMLTableRowElement>(`[data-member-row][data-user-id="${CSS.escape(member.userId)}"]`);
    const previousRole = existingRow?.dataset.role as CampaignRole | undefined;
    const nextRow = renderMemberRow(member);

    if (existingRow) {
      existingRow.replaceWith(nextRow);
      if (previousRole !== member.role) {
        incrementCount(gmCount, member.role === 'gm' ? 1 : -1);
      }
    } else {
      tableBody.append(nextRow);
      incrementCount(memberCount, 1);
      incrementCount(gmCount, member.role === 'gm' ? 1 : 0);
    }

    tableWrapper?.classList.remove('hidden');
    emptyMembers?.classList.add('hidden');
  }

  async function readErrorMessage(response: Response): Promise<string> {
    try {
      const body = (await response.json()) as ErrorResponseBody;
      return body.message || 'Campaign membership could not be updated.';
    } catch {
      return 'Campaign membership could not be updated.';
    }
  }

  if (root && form) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const campaignSlug = root.dataset.campaignSlug;
      if (!campaignSlug) {
        setMessage('error', 'Campaign membership could not be updated.');
        return;
      }

      const formData = new FormData(form);
      const email = String(formData.get('email') ?? '').trim();
      const role = formData.get('role');
      if (role !== 'member' && role !== 'gm') {
        setMessage('error', 'role must be one of member or gm.');
        return;
      }

      setPending(true);
      try {
        const response = await fetch(`/api/v1/campaigns/${encodeURIComponent(campaignSlug)}/members`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, role }),
        });

        if (!response.ok) {
          setMessage('error', await readErrorMessage(response));
          return;
        }

        const body = (await response.json()) as CampaignMemberCreateResponseDto;
        upsertMemberRow(body.member);
        form.reset();
        setMessage('success', body.confirmationMessage);
      } catch {
        setMessage('error', 'Campaign administration is temporarily unavailable.');
      } finally {
        setPending(false);
      }
    });
  }
</script>
