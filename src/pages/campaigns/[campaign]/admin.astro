---
import { getCollection } from 'astro:content';
import CampaignsLayout from '@layouts/CampaignsLayout.astro';
import { extractCampaignSlugFromEntryId } from '@utils/campaign-collections';

export const prerender = false;

const { campaign } = Astro.params;
const campaignSlug = campaign ?? '';
const loginHref = `/login?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`;

let campaignTitle = campaignSlug;
let campaignExcerpt: string | undefined;
let contentUnavailable = false;
let campaignFound = false;

try {
  const campaigns = await getCollection('campaigns');
  const campaignEntry = campaigns.find((entry) => extractCampaignSlugFromEntryId(entry.id) === campaignSlug) ?? null;

  if (campaignEntry) {
    campaignFound = true;
    campaignTitle = campaignEntry.data.title;
    campaignExcerpt = campaignEntry.data.excerpt;
  }
} catch (error) {
  console.error('campaign.admin.content_unavailable', {
    campaignSlug,
    message: error instanceof Error ? error.message : 'unknown error',
  });
  contentUnavailable = true;
}

const title = campaignFound ? `${campaignTitle} - Campaign Administration` : 'Campaign Administration';
---

<CampaignsLayout title={title} description={`Campaign administration for ${campaignTitle}`} robots="noindex,nofollow">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <nav class="mb-6 text-sm meta-muted">
      <a href="/campaigns" class="hover:text-primary">Campaigns</a>
      <span class="mx-2">/</span>
      {campaignFound ? (
        <a href={`/campaigns/${campaignSlug}`} class="hover:text-primary">{campaignTitle}</a>
      ) : (
        <span>{campaignSlug || 'Unknown campaign'}</span>
      )}
      <span class="mx-2">/</span>
      <span class="font-medium text-ink-900">Administration</span>
    </nav>

    <header class="mb-8">
      <div class="mb-3 flex flex-wrap items-center gap-3">
        <span class="ui-pill ui-pill--outline">Campaign tools</span>
        <span class="badge badge-primary hidden" data-capability-badge>GM access</span>
      </div>
      <h1 class="mb-3 text-3xl font-bold text-ink-950 md:text-4xl">{campaignTitle}</h1>
      <p class="max-w-3xl text-ink-800">
        {campaignExcerpt ?? 'Review campaign-scoped membership and GM capability for this campaign.'}
      </p>
    </header>

    {contentUnavailable && (
      <section class="ui-surface p-6">
        <h2 class="mb-2 text-xl font-semibold text-ink-950">Campaign administration unavailable</h2>
        <p class="text-ink-800">
          Campaign administration is temporarily unavailable. Protected campaign user data remains closed until the
          content source is available.
        </p>
      </section>
    )}

    {!contentUnavailable && !campaignFound && (
      <section class="ui-surface p-6">
        <h2 class="mb-2 text-xl font-semibold text-ink-950">Campaign not found</h2>
        <p class="text-ink-800">The requested campaign could not be found.</p>
      </section>
    )}

    {!contentUnavailable && campaignFound && (
      <div
        class="space-y-8"
        data-campaign-admin
        data-campaign-slug={campaignSlug}
        data-login-href={loginHref}
      >
        <section class="ui-surface p-6" data-admin-loading>
          <h2 class="mb-2 text-xl font-semibold text-ink-950">Checking campaign permissions</h2>
          <p class="text-ink-800">Campaign management controls load after your Better Auth session is verified.</p>
        </section>

        <section class="ui-surface hidden p-6" data-admin-auth-required>
          <h2 class="mb-2 text-xl font-semibold text-ink-950">Sign in required</h2>
          <p class="mb-4 text-ink-800">Campaign administration is available only to signed-in campaign GMs.</p>
          <a href={loginHref} class="ui-button ui-button--primary">Sign in to continue</a>
        </section>

        <section class="ui-surface hidden p-6" data-admin-forbidden>
          <h2 class="mb-2 text-xl font-semibold text-ink-950">Campaign permission required</h2>
          <p class="text-ink-800">
            Your account does not have campaign user-admin capability for {campaignTitle}. Member and non-member
            accounts cannot administer campaign users.
          </p>
        </section>

        <section class="ui-surface hidden p-6" data-admin-unavailable>
          <h2 class="mb-2 text-xl font-semibold text-ink-950">Campaign administration unavailable</h2>
          <p class="text-ink-800" data-admin-unavailable-message>
            Campaign administration is temporarily unavailable. Please retry later.
          </p>
        </section>

        <div class="hidden space-y-8" data-admin-controls>
          <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="ui-surface p-5">
              <p class="meta-muted text-sm">Actor</p>
              <p class="mt-1 font-semibold text-ink-950" data-actor-name>Unknown user</p>
            </div>
            <div class="ui-surface p-5">
              <p class="meta-muted text-sm">Capability source</p>
              <p class="mt-1 font-semibold text-ink-950" data-capability-source>campaign-gm</p>
            </div>
            <div class="ui-surface p-5">
              <p class="meta-muted text-sm">Members shown</p>
              <p class="mt-1 font-semibold text-ink-950" data-member-count>0</p>
            </div>
            <div class="ui-surface p-5">
              <p class="meta-muted text-sm">Campaign GMs</p>
              <p class="mt-1 font-semibold text-ink-950" data-gm-count>0</p>
            </div>
          </section>

          <section class="ui-surface p-6">
            <div class="mb-5">
              <h2 class="text-2xl font-bold text-ink-950">Add existing account</h2>
              <p class="mt-2 text-sm text-ink-800">
                Add an existing World of Aletheia account by exact email address. This does not invite new users or
                search all users. If the person has not created an account yet, have them sign up first.
              </p>
            </div>

            <form class="grid gap-4 md:grid-cols-[minmax(0,1fr)_12rem_auto]" data-add-member-form>
              <label class="form-control">
                <span class="label-text font-medium text-ink-900">Email address</span>
                <input
                  class="input input-bordered w-full"
                  type="email"
                  name="email"
                  autocomplete="email"
                  maxlength="254"
                  required
                  placeholder="player@example.com"
                />
              </label>

              <label class="form-control">
                <span class="label-text font-medium text-ink-900">Role</span>
                <select class="select select-bordered w-full" name="role" required>
                  <option value="member" selected>Member</option>
                  <option value="gm">GM</option>
                </select>
              </label>

              <div class="flex items-end">
                <button class="btn btn-primary w-full" type="submit" data-add-member-submit>Add member</button>
              </div>
            </form>

            <div class="alert mt-4 hidden" role="status" aria-live="polite" data-admin-message></div>
          </section>

          <section class="ui-surface overflow-hidden p-0">
            <div class="border-b border-base-300 p-6">
              <h2 class="text-2xl font-bold text-ink-950">Campaign members</h2>
              <p class="mt-2 text-sm text-ink-800">
                Members are campaign-scoped only. Invitations, access requests, and global user search are intentionally
                not exposed here.
              </p>
            </div>

            <div class="p-6 text-ink-800" data-empty-members>No campaign members were found.</div>
            <div class="hidden overflow-x-auto" data-members-table-wrapper>
              <table class="table w-full">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Updated</th>
                    <th class="text-right">Actions</th>
                  </tr>
                </thead>
                <tbody data-members-table-body></tbody>
              </table>
            </div>
          </section>
        </div>
      </div>
    )}
  </div>
</CampaignsLayout>

<script>
  import {
    CampaignApiError,
    addCampaignMember,
    getCampaignAdminCapability,
    listCampaignMembers,
    revokeCampaignMember,
    updateCampaignMember,
    type CampaignMember,
    type CampaignRole,
  } from '@utils/campaign-management-api-client';

  const root = document.querySelector<HTMLElement>('[data-campaign-admin]');
  const capabilityBadge = document.querySelector<HTMLElement>('[data-capability-badge]');
  const loadingPanel = document.querySelector<HTMLElement>('[data-admin-loading]');
  const authRequiredPanel = document.querySelector<HTMLElement>('[data-admin-auth-required]');
  const forbiddenPanel = document.querySelector<HTMLElement>('[data-admin-forbidden]');
  const unavailablePanel = document.querySelector<HTMLElement>('[data-admin-unavailable]');
  const unavailableMessage = document.querySelector<HTMLElement>('[data-admin-unavailable-message]');
  const controls = document.querySelector<HTMLElement>('[data-admin-controls]');
  const form = document.querySelector<HTMLFormElement>('[data-add-member-form]');
  const submitButton = document.querySelector<HTMLButtonElement>('[data-add-member-submit]');
  const message = document.querySelector<HTMLElement>('[data-admin-message]');
  const tableBody = document.querySelector<HTMLTableSectionElement>('[data-members-table-body]');
  const tableWrapper = document.querySelector<HTMLElement>('[data-members-table-wrapper]');
  const emptyMembers = document.querySelector<HTMLElement>('[data-empty-members]');
  const memberCount = document.querySelector<HTMLElement>('[data-member-count]');
  const gmCount = document.querySelector<HTMLElement>('[data-gm-count]');
  const actorName = document.querySelector<HTMLElement>('[data-actor-name]');
  const capabilitySource = document.querySelector<HTMLElement>('[data-capability-source]');

  const membersByUserId = new Map<string, CampaignMember>();

  function hide(element: HTMLElement | null): void {
    element?.classList.add('hidden');
  }

  function show(element: HTMLElement | null): void {
    element?.classList.remove('hidden');
  }

  function formatTimestampClient(value: string | null | undefined): string {
    if (!value) {
      return 'Unknown';
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return value;
    }

    return new Intl.DateTimeFormat('en-GB', {
      dateStyle: 'medium',
      timeStyle: 'short',
    }).format(date);
  }

  function setMessage(kind: 'success' | 'error', text: string): void {
    if (!message) {
      return;
    }

    message.textContent = text;
    message.classList.remove('hidden', 'alert-success', 'alert-error', 'alert-warning');
    message.classList.add(kind === 'success' ? 'alert-success' : 'alert-error');
  }

  function setUnavailable(text: string): void {
    hide(loadingPanel);
    hide(authRequiredPanel);
    hide(forbiddenPanel);
    hide(controls);
    hide(capabilityBadge);
    if (unavailableMessage) {
      unavailableMessage.textContent = text;
    }
    show(unavailablePanel);
  }

  function messageForError(error: unknown, action: 'add' | 'update' | 'revoke' | 'load'): string {
    if (!(error instanceof CampaignApiError)) {
      return 'Campaign administration is temporarily unavailable.';
    }

    if (error.status === 401) {
      return 'Sign in is required to administer this campaign.';
    }

    if (error.status === 403) {
      return 'You cannot administer users for this campaign.';
    }

    if (error.status === 404 && action === 'add') {
      return 'No existing account found for that email.';
    }

    if (error.status === 404 && action !== 'load') {
      return 'Campaign membership was not found. Refreshing the member list.';
    }

    if (error.status === 409 && action === 'add') {
      return 'This user is already a campaign member.';
    }

    if (error.status === 409) {
      return error.message || 'The requested change conflicts with the current campaign state.';
    }

    if (error.status === 429) {
      return error.message || 'Too many requests. Please wait before trying again.';
    }

    if (error.status === 503) {
      return error.message || 'Campaign administration is temporarily unavailable.';
    }

    return error.message || 'Campaign membership could not be updated.';
  }

  function setFormPending(isPending: boolean): void {
    if (!form || !submitButton) {
      return;
    }

    for (const element of form.elements) {
      if (element instanceof HTMLInputElement || element instanceof HTMLSelectElement || element instanceof HTMLButtonElement) {
        element.disabled = isPending;
      }
    }
    submitButton.textContent = isPending ? 'Adding…' : 'Add member';
  }

  function renderRoleBadge(role: CampaignRole): HTMLSpanElement {
    const badge = document.createElement('span');
    badge.className = role === 'gm' ? 'badge badge-primary' : 'badge badge-outline';
    badge.textContent = role === 'gm' ? 'GM' : 'Member';
    return badge;
  }

  function renderRoleSelect(member: CampaignMember): HTMLSelectElement {
    const select = document.createElement('select');
    select.className = 'select select-bordered select-sm';
    select.dataset.roleSelect = '';
    select.dataset.userId = member.userId;

    for (const role of ['member', 'gm'] as const) {
      const option = document.createElement('option');
      option.value = role;
      option.textContent = role === 'gm' ? 'GM' : 'Member';
      option.selected = member.role === role;
      select.append(option);
    }

    return select;
  }

  function renderMemberRow(member: CampaignMember): HTMLTableRowElement {
    const row = document.createElement('tr');
    row.dataset.memberRow = '';
    row.dataset.userId = member.userId;
    row.dataset.role = member.role;

    const nameCell = document.createElement('td');
    const name = document.createElement('div');
    name.className = 'font-medium text-ink-950';
    name.textContent = member.displayName ?? 'Unnamed user';
    const userId = document.createElement('div');
    userId.className = 'text-xs meta-muted';
    userId.textContent = member.userId;
    nameCell.append(name, userId);

    const emailCell = document.createElement('td');
    emailCell.textContent = member.email;

    const roleCell = document.createElement('td');
    roleCell.append(renderRoleBadge(member.role));

    const joinedCell = document.createElement('td');
    joinedCell.textContent = formatTimestampClient(member.joinedAt);

    const updatedCell = document.createElement('td');
    updatedCell.textContent = formatTimestampClient(member.updatedAt);

    const actionsCell = document.createElement('td');
    actionsCell.className = 'text-right';
    const actions = document.createElement('div');
    actions.className = 'flex flex-wrap justify-end gap-2';
    const roleSelect = renderRoleSelect(member);
    const revokeButton = document.createElement('button');
    revokeButton.className = 'btn btn-outline btn-sm';
    revokeButton.type = 'button';
    revokeButton.dataset.revokeMember = '';
    revokeButton.dataset.userId = member.userId;
    revokeButton.textContent = 'Revoke';
    actions.append(roleSelect, revokeButton);
    actionsCell.append(actions);

    row.append(nameCell, emailCell, roleCell, joinedCell, updatedCell, actionsCell);
    return row;
  }

  function refreshCounts(): void {
    const members = Array.from(membersByUserId.values());
    if (memberCount) {
      memberCount.textContent = String(members.length);
    }
    if (gmCount) {
      gmCount.textContent = String(members.filter((member) => member.role === 'gm').length);
    }
  }

  function renderMembers(): void {
    if (!tableBody) {
      return;
    }

    tableBody.replaceChildren(...Array.from(membersByUserId.values()).map(renderMemberRow));
    refreshCounts();

    if (membersByUserId.size > 0) {
      show(tableWrapper);
      hide(emptyMembers);
    } else {
      hide(tableWrapper);
      show(emptyMembers);
    }
  }

  async function loadMembers(campaignSlug: string): Promise<void> {
    const page = await listCampaignMembers({ campaignSlug, limit: 100 });
    membersByUserId.clear();
    for (const member of page.items) {
      membersByUserId.set(member.userId, member);
    }
    renderMembers();
  }

  async function refetchAfterConflict(campaignSlug: string): Promise<void> {
    try {
      await loadMembers(campaignSlug);
    } catch {
      // Keep the user's original error visible; a later manual retry can reload state.
    }
  }

  async function bootstrap(): Promise<void> {
    if (!root) {
      return;
    }

    const campaignSlug = root.dataset.campaignSlug;
    if (!campaignSlug) {
      setUnavailable('Campaign administration is temporarily unavailable.');
      return;
    }

    try {
      const capability = await getCampaignAdminCapability(campaignSlug);
      hide(loadingPanel);

      if (!capability.canAdministerUsers) {
        hide(controls);
        hide(capabilityBadge);
        show(forbiddenPanel);
        return;
      }

      if (actorName) {
        actorName.textContent = capability.actor.displayName ?? capability.actor.userId;
      }
      if (capabilitySource) {
        capabilitySource.textContent = capability.source;
      }

      show(capabilityBadge);
      show(controls);
      await loadMembers(campaignSlug);
    } catch (error) {
      if (error instanceof CampaignApiError && error.status === 401) {
        hide(loadingPanel);
        hide(controls);
        show(authRequiredPanel);
        return;
      }

      if (error instanceof CampaignApiError && error.status === 403) {
        hide(loadingPanel);
        hide(controls);
        hide(capabilityBadge);
        show(forbiddenPanel);
        return;
      }

      setUnavailable(messageForError(error, 'load'));
    }
  }

  if (root && form) {
    void bootstrap();

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const campaignSlug = root.dataset.campaignSlug;
      if (!campaignSlug) {
        setMessage('error', 'Campaign membership could not be updated.');
        return;
      }

      const formData = new FormData(form);
      const email = String(formData.get('email') ?? '').trim();
      const role = formData.get('role');
      if (role !== 'member' && role !== 'gm') {
        setMessage('error', 'role must be one of member or gm.');
        return;
      }

      setFormPending(true);
      try {
        const body = await addCampaignMember({ campaignSlug, email, role });
        membersByUserId.set(body.member.userId, body.member);
        renderMembers();
        form.reset();
        setMessage('success', body.confirmationMessage);
      } catch (error) {
        setMessage('error', messageForError(error, 'add'));
        if (error instanceof CampaignApiError && error.status === 409) {
          await refetchAfterConflict(campaignSlug);
        }
      } finally {
        setFormPending(false);
      }
    });

    tableBody?.addEventListener('change', async (event) => {
      const select = event.target instanceof HTMLSelectElement ? event.target : null;
      const campaignSlug = root.dataset.campaignSlug;
      const userId = select?.dataset.userId;
      const role = select?.value;

      if (!select || !campaignSlug || !userId || (role !== 'member' && role !== 'gm')) {
        return;
      }

      const currentMember = membersByUserId.get(userId);
      if (currentMember?.role === role) {
        return;
      }

      select.disabled = true;
      try {
        const body = await updateCampaignMember({ campaignSlug, userId, role, reason: 'Updated from campaign admin UI.' });
        membersByUserId.set(body.member.userId, body.member);
        renderMembers();
        setMessage('success', body.confirmationMessage);
      } catch (error) {
        setMessage('error', messageForError(error, 'update'));
        if (error instanceof CampaignApiError && (error.status === 404 || error.status === 409)) {
          await refetchAfterConflict(campaignSlug);
        } else if (currentMember) {
          select.value = currentMember.role;
        }
      } finally {
        select.disabled = false;
      }
    });

    tableBody?.addEventListener('click', async (event) => {
      const button = event.target instanceof HTMLElement ? event.target.closest<HTMLButtonElement>('[data-revoke-member]') : null;
      const campaignSlug = root.dataset.campaignSlug;
      const userId = button?.dataset.userId;

      if (!button || !campaignSlug || !userId) {
        return;
      }

      button.disabled = true;
      try {
        const body = await revokeCampaignMember({
          campaignSlug,
          userId,
          reason: 'Revoked from campaign admin UI.',
        });
        membersByUserId.delete(body.revokedMembership.userId);
        renderMembers();
        setMessage('success', body.confirmationMessage);
      } catch (error) {
        setMessage('error', messageForError(error, 'revoke'));
        if (error instanceof CampaignApiError && (error.status === 404 || error.status === 409)) {
          await refetchAfterConflict(campaignSlug);
        }
      } finally {
        button.disabled = false;
      }
    });
  }
</script>
