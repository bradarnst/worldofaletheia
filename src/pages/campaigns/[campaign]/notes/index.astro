---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import CampaignsLayout from '@layouts/CampaignsLayout.astro';
import {
  isCampaignNotesApiError,
  listCampaignNotes,
  normalizeCampaignNoteType,
  type CampaignNoteMetadata,
} from '@adapters/campaign-notes-api';
import { extractCampaignSlugFromEntryId } from '@utils/campaign-collections';
import { getFilteredCollection } from '@utils/content-filter';
import { createCampaignRequestAccessResolver } from '~/lib/campaign-request-access';
import { getRequestSession } from '~/lib/auth-session';
import {
  createCampaignNotesRuntimeActorAssertion,
  resolveCampaignNotesRuntimeRole,
} from '~/lib/campaign-notes-runtime-assertion';

export const prerender = false;

function formatDate(value: string | null | undefined): string | null {
  if (!value) {
    return null;
  }

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
}

function labelNoteType(value: string): string {
  return value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

const { campaign } = Astro.params;
if (!campaign) {
  return new Response('Not Found', { status: 404 });
}

let campaignEntry: CollectionEntry<'campaigns'> | null = null;
try {
  const campaigns = getFilteredCollection(await getCollection('campaigns'));
  campaignEntry = campaigns.find((entry) => extractCampaignSlugFromEntryId(entry.id) === campaign) ?? null;
} catch (error) {
  console.error('campaign.notes.campaign_lookup_failed', {
    campaignSlug: campaign,
    message: error instanceof Error ? error.message : 'unknown error',
  });
}

if (!campaignEntry) {
  return new Response('Not Found', { status: 404 });
}

const accessResolver = await createCampaignRequestAccessResolver({
  request: Astro.request,
  locals: Astro.locals,
  hostname: Astro.url.hostname,
});
const [session, campaignAccess] = await Promise.all([
  getRequestSession(Astro.request, Astro.locals),
  accessResolver.hasCampaignAccess(campaign),
]);
const hasAuthenticatedCampaignAccess = Boolean(session && (campaignAccess.isMember || campaignAccess.isGm));
const runtimeRole = resolveCampaignNotesRuntimeRole(campaignAccess);
const assertion = session && runtimeRole
  ? await createCampaignNotesRuntimeActorAssertion({
      userId: session.user.id,
      campaignSlug: campaign,
      role: runtimeRole,
    })
  : null;

const url = new URL(Astro.request.url);
const noteType = normalizeCampaignNoteType(url.searchParams.get('noteType'));
const cursor = url.searchParams.get('cursor')?.trim() || undefined;
const sessionSlug = url.searchParams.get('sessionSlug')?.trim() || undefined;
const sessionDate = url.searchParams.get('sessionDate')?.trim() || undefined;

let notes: CampaignNoteMetadata[] = [];
let nextCursor: string | null = null;
let apiUnavailable = false;
let restrictedOrMissing = false;

try {
  const page = await listCampaignNotes({
    campaignSlug: campaign,
    limit: 50,
    cursor,
    noteType,
    sessionSlug,
    sessionDate,
  }, assertion);
  notes = page.items;
  nextCursor = page.nextCursor;
} catch (error) {
  if (isCampaignNotesApiError(error) && (error.status === 401 || error.status === 403 || error.status === 404)) {
    restrictedOrMissing = true;
  } else {
    apiUnavailable = true;
    console.error('campaign.notes.list_failed', {
      campaignSlug: campaign,
      message: error instanceof Error ? error.message : 'unknown error',
    });
  }
}

const title = `${campaignEntry.data.title} - Notes`;
const robots = campaignEntry.data.visibility === 'public' && !restrictedOrMissing && !apiUnavailable ? undefined : 'noindex, nofollow';
const loginHref = `/login?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`;
const nextCursorSearchParams = new URLSearchParams(url.searchParams);
if (nextCursor) {
  nextCursorSearchParams.set('cursor', nextCursor);
}
const nextCursorHref = nextCursor
  ? `/campaigns/${campaign}/notes?${nextCursorSearchParams.toString()}`
  : null;
---

<CampaignsLayout title={title} description={`Campaign Notes for ${campaignEntry.data.title}`} robots={robots}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <nav class="mb-6 text-sm meta-muted">
      <a href="/campaigns" class="hover:text-primary">Campaigns</a>
      <span class="mx-2">/</span>
      <a href={`/campaigns/${campaign}`} class="hover:text-primary">{campaignEntry.data.title}</a>
      <span class="mx-2">/</span>
      <span class="font-medium text-ink-900">Notes</span>
    </nav>

    <header class="mb-10 space-y-3">
      <h1 class="text-3xl font-bold text-ink-950 md:text-4xl">Campaign Notes</h1>
      <p class="max-w-3xl text-ink-800">
        API-backed campaign note documents from the campaign notes service. This surface replaces the old published
        session-note path and shows only notes visible to the current caller.
      </p>
      {hasAuthenticatedCampaignAccess && !assertion && (
        <p class="meta-muted text-sm">
          Signed campaign-note access is temporarily unavailable, so this list is using public-note access only.
        </p>
      )}
    </header>

    {apiUnavailable ? (
      <div class="rounded-xl border border-warning/40 bg-warning/10 p-4 text-sm text-ink-800">
        Campaign Notes are temporarily unavailable. Please try again later.
      </div>
    ) : restrictedOrMissing ? (
      <div class="rounded-xl border border-base-300 bg-base-200/50 p-8 text-center">
        <h2 class="mb-2 text-xl font-semibold text-ink-950">Notes are not available</h2>
        <p class="text-ink-800">No readable campaign notes were found for this campaign.</p>
        <p class="mt-4"><a href={loginHref} class="ui-button ui-button--primary ui-button--sm">Sign in to continue</a></p>
      </div>
    ) : notes.length === 0 ? (
      <div class="rounded-xl border border-base-300 bg-base-200/50 p-8 text-center">
        <p class="text-ink-800">No visible campaign notes found yet.</p>
      </div>
    ) : (
      <div class="space-y-4">
        {notes.map((note) => (
          <a href={`/campaigns/${campaign}/notes/${note.documentId}`} class="group block rounded-[1.45rem] border border-base-300/80 bg-base-100 p-6 shadow-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
            <div class="flex items-start justify-between gap-4">
              <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="ui-pill ui-pill--outline">{labelNoteType(note.noteType)}</span>
                  <span class="ui-pill ui-pill--ghost">{note.visibility === 'campaignMembers' ? 'Campaign members' : 'Public'}</span>
                  {note.sessionDate && <span class="ui-pill ui-pill--ghost">{formatDate(note.sessionDate)}</span>}
                </div>
                <h2 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">{note.title}</h2>
                <p class="meta-muted text-sm">
                  Updated {formatDate(note.updatedAt) ?? note.updatedAt}
                  {note.sessionSlug ? ` · Session ${note.sessionSlug}` : ''}
                </p>
              </div>
              <svg class="mt-1 h-5 w-5 text-ink-500 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    )}

    {nextCursorHref && (
      <div class="mt-8">
        <a href={nextCursorHref} class="ui-button ui-button--secondary">Next page</a>
      </div>
    )}
  </div>
</CampaignsLayout>
