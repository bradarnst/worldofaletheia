---
import { getCollection } from 'astro:content';
import CampaignsLayout from '@layouts/CampaignsLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';

const campaigns = await getCollection('campaigns');
const sessions = await getCollection('sessions');

const sessionCounts = new Map<string, number>();
for (const session of sessions) {
  const campaignSlug = session.data.campaign;
  sessionCounts.set(campaignSlug, (sessionCounts.get(campaignSlug) || 0) + 1);
}

const campaignSummaries = campaigns.map((entry) => {
  const slug = entry.id.replace(/\/index$/, '');

  return {
    id: slug,
    slug,
    title: entry.data.title,
    status: entry.data.status,
    excerpt: entry.data.excerpt,
    tags: entry.data.tags,
    sessionCount: sessionCounts.get(slug) || 0,
  };
});

const publishedCampaigns = campaignSummaries.filter(
  (item) => item.status === 'active' || item.status === 'completed'
);

const allTags = [...new Set(publishedCampaigns.flatMap(item => item.tags))];
---

<CampaignsLayout title="Campaigns - World of Aletheia" description="Explore ongoing and completed campaigns in Aletheia">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Campaigns</h2>
      
      {publishedCampaigns.length === 0 ? (
        <p class="text-gray-600">No published campaign entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedCampaigns.map((item) => (
            <a href={`/campaigns/${item.slug}`} class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
              <div class="card-body">
                <h3 class="card-title font-lora">{item.title}</h3>
                <p class="text-gray-600">{item.excerpt || 'No description available'}</p>
                <div class="flex flex-wrap gap-2 mt-2">
                  <span class="badge badge-primary">{item.status}</span>
                  <span class="badge badge-ghost">{item.sessionCount} sessions</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</CampaignsLayout>

