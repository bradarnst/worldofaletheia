---
import { getLiveCollection } from 'astro:content';
import CampaignsLayout from '@layouts/CampaignsLayout.astro';
import CollectionHeroShell from '@components/site/CollectionHeroShell.astro';
import rideOnTheBeach from '@images/ride-on-the-beach.png';
import {
  buildCampaignIndexModel,
  type CampaignIndexViewer,
  type CampaignIndexMetadataLoader,
} from '~/lib/campaign-index';
import { getRequestSession } from '~/lib/auth-session';

const loadCampaignMetadata: CampaignIndexMetadataLoader = async ({ campaignSlug, accessScope }) => {
  try {
    const result = await getLiveCollection('campaignContent', {
      campaignSlug,
      collectionKey: 'pages',
      accessScope,
      type: 'campaign',
      limit: 10,
    });

    if (!Array.isArray(result.entries)) {
      const liveError = result.error;
      const reason = liveError && typeof liveError === 'object' && 'code' in liveError
        ? String(liveError.code)
        : 'liveCollectionError';

      return { ok: false, reason };
    }

    const rootEntry =
      result.entries.find((entry) => entry.data.documentId === 'index')
      ?? result.entries.find((entry) => entry.data.type === 'campaign');

    return rootEntry
      ? { ok: true, title: rootEntry.data.title }
      : { ok: false, reason: 'missingCampaignRoot' };
  } catch (error) {
    console.error('campaign.index.live_collection_failed', {
      campaignSlug,
      message: error instanceof Error ? error.message : 'unknown error',
    });
    return { ok: false, reason: 'liveCollectionFailed' };
  }
};

const session = await getRequestSession(Astro.request, Astro.locals);
const viewer: CampaignIndexViewer = session
  ? { kind: 'authenticated', userId: session.user.id, traceId: session.session.id }
  : { kind: 'anonymous' };

const campaignIndex = await buildCampaignIndexModel({
  viewer,
  loadCampaignMetadata,
});

const next = encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`);
const loginHref = `/login?next=${next}`;
---

<CampaignsLayout title="Campaigns - World of Aletheia" description="Explore public campaign listings in Aletheia">
  <CollectionHeroShell
    title="Campaigns"
    description="Public campaign listings and campaign-gated play archives that reveal Aletheia through actual table history."
    image={rideOnTheBeach}
    icon="Campaigns"
    eyebrow="Campaigns"
  />

  <div class="max-w-6xl mx-auto px-4 py-8 space-y-12">
    <section class="ui-surface ui-surface--muted p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div class="space-y-2">
          <h2 class="text-2xl font-bold text-ink-950">Campaign Access</h2>
          <p class="text-ink-800 max-w-3xl">
            Campaign titles are public discovery information. Individual campaign areas may require Campaign Membership,
            and this index intentionally omits protected item titles, counts, excerpts, tags, and other details.
          </p>
          {campaignIndex.unavailableCampaignCount > 0 && (
            <p class="meta-muted text-sm">
              {campaignIndex.unavailableCampaignCount}
              {' '}
              {campaignIndex.unavailableCampaignCount === 1 ? 'campaign title is' : 'campaign titles are'} temporarily unavailable.
            </p>
          )}
        </div>
        <div class="flex items-center gap-3">
          <a href={loginHref} class="ui-button ui-button--primary">Sign in for campaign access</a>
          <a href="/account" class="ui-button ui-button--secondary">Account</a>
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold text-ink-950 mb-6">Available Campaigns</h2>

      {campaignIndex.campaigns.length === 0 ? (
        <p class="text-ink-800">No campaign listings are available right now.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {campaignIndex.campaigns.map((item) => (
            <a href={item.href} class="group flex h-full flex-col rounded-[1.5rem] border border-base-300/80 bg-base-100 p-5 shadow-sm transition duration-200 hover:border-primary/35 hover:shadow-lg">
              <div class="flex-1 space-y-3">
                <h3 class="text-xl font-semibold text-ink-950 transition-colors group-hover:text-primary">{item.title}</h3>
                {!item.isAvailable && <span class="ui-pill ui-pill--outline">Temporarily unavailable</span>}
                {item.unavailableMessage && <p class="text-sm meta-muted">{item.unavailableMessage}</p>}
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</CampaignsLayout>
