---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ContentCard from '@components/ContentCard.astro';
import TagCloud from '@components/TagCloud.astro';

const campaigns = await getCollection('campaigns');
const publishedCampaigns = campaigns.filter((item) => item.data.status === 'published');

// Get all unique tags
const allTags = [...new Set(publishedCampaigns.flatMap(item => item.data.tags))];
---

<BaseLayout title="Campaigns - World of Aletheia" description="Explore ongoing and completed campaigns in Aletheia">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Campaigns</h1>
      <p class="text-xl text-gray-600">Explore ongoing and completed campaigns in Aletheia</p>
    </header>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Latest Campaigns</h2>
      
      {publishedCampaigns.length === 0 ? (
        <p class="text-gray-600">No published campaign entries found.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publishedCampaigns.map((item) => (
            <ContentCard content={item.data} />
          ))}
        </div>
      )}
    </div>
    
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Popular Tags</h2>
      <TagCloud tags={allTags} />
    </div>
  </div>
</BaseLayout>