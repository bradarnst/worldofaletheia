---
import DiscoveryCollectionView from '@components/DiscoveryCollectionView.astro';
import WorldAletheiaLayout from '@layouts/WorldAletheiaLayout.astro';
import forestRoad from '@images/forest-road.png';
import { loadIndexBackedCollectionPage } from '~/lib/content-index-page';

const discoveryPage = await loadIndexBackedCollectionPage({
  collection: 'sentients',
  searchParams: Astro.url.searchParams,
  locals: Astro.locals,
});
---

<WorldAletheiaLayout title="Sentients - World of Aletheia" description="Learn about races, species, cultures, and organizations of Aletheia">
  <DiscoveryCollectionView
    basePath="/sentients"
    collectionLabel="Sentients"
    image={forestRoad}
    emptyMessage="No published sentient entries found."
    {...discoveryPage}
  />
</WorldAletheiaLayout>
