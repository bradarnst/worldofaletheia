---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import CampaignsNav from '@components/CampaignsNav.astro';
import CampaignsHeader from '@components/CampaignsHeader.astro';

export interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const { title, description, robots } = Astro.props;
---

<BaseLayout title={title} description={description} robots={robots}>
  <GlobalNavigation />
  <CampaignsNav />
  <CampaignsHeader title={title || 'Campaigns'} description={description} />
  <main class="min-h-screen bg-base-100">
    <div class="container mx-auto px-4 py-16">
      <slot />
    </div>
  </main>
</BaseLayout>
