---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import CampaignsNav from '@components/CampaignsNav.astro';

export interface Props {
  title?: string;
  description?: string;
  robots?: string;
}

const { title, description, robots } = Astro.props;
---

<BaseLayout title={title} description={description} robots={robots}>
  <GlobalNavigation />
  <CampaignsNav />
  <main class="min-h-screen bg-base-100">
    <slot />
  </main>
</BaseLayout>
