---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';

export interface Props {
  title?: string;
  description?: string;
  fullBleed?: boolean;
  robots?: string;
}

const { title, description, fullBleed = false, robots } = Astro.props;
---

<BaseLayout title={title} description={description} robots={robots}>
  <GlobalNavigation />
  <main class="min-h-screen bg-base-100">
    {fullBleed ? (
      <slot />
    ) : (
      <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8 lg:py-16">
        <slot />
      </div>
    )}
  </main>
</BaseLayout>
