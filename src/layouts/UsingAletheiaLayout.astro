---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import UsingAletheiaNav from '@components/UsingAletheiaNav.astro';
import UsingAletheiaHeader from '@components/UsingAletheiaHeader.astro';
import SystemsNavigation from '@components/SystemsNavigation.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const isSystemsPage = Astro.url.pathname.startsWith('/systems');
---

<BaseLayout title={title} description={description}>
  <GlobalNavigation />
  <UsingAletheiaNav />
  {isSystemsPage && <SystemsNavigation />}
  <UsingAletheiaHeader title={title || 'Using Aletheia'} description={description} />
  <main class="min-h-screen bg-base-100">
    <div class="container mx-auto px-4 py-16">
      <slot />
    </div>
  </main>
</BaseLayout>
