---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import WorldAletheiaNav from '@components/WorldAletheiaNav.astro';
import WorldAletheiaContentHeader from '@components/WorldAletheiaContentHeader.astro';
import Footer from '@components/Footer.astro';

interface Props {
  content: any;
  title?: string;
  description?: string;
  children: any;
}

const { content, title, description, children } = Astro.props;

const data = content.data || content;
const contentTitle = title || data.title || content.title;
const contentExcerpt = data.excerpt || content.excerpt;
const parentChain = Array.isArray(data.parentChain) ? data.parentChain : [];
const relationships = Array.isArray(data.relationships) ? data.relationships : [];
---

<BaseLayout title={contentTitle} description={description}>
  <GlobalNavigation />
  <WorldAletheiaNav />
  <WorldAletheiaContentHeader
    title={contentTitle}
    author={data.author || content.author}
    created={data.created || content.created}
    secret={data.secret || content.secret}
    excerpt={contentExcerpt}
    tags={data.tags || content.tags}
    parentChain={parentChain}
    relationships={relationships}
  />
  <div class="min-h-screen bg-gradient-to-br from-base-100 to-base-200">
    <article class="reading-prose py-8 md:py-12">
      <main class="content-container">
        <slot />
      </main>
      
      <Footer>
        <span slot="left">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
      </Footer>
    </article>
  </div>
</BaseLayout>
