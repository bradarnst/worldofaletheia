---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import ArticleContextHeader from '@components/site/ArticleContextHeader.astro';

interface SimpleContentData {
  title?: string;
  description?: string;
  excerpt?: string;
  tldr?: string;
}

interface SimpleContentEntry {
  data?: SimpleContentData;
  title?: string;
  excerpt?: string;
  tldr?: string;
}

interface Props {
  content: SimpleContentEntry;
  title?: string;
  description?: string;
}

const { content, title, description } = Astro.props;

const data = content.data || content;
const contentTitle = title || data.title || content.title;
const contentDescription = description || data.description || data.excerpt || content.excerpt;
const tldr = data.tldr || content.tldr;
---

<BaseLayout title={contentTitle} description={contentDescription}>
  <GlobalNavigation />
  <ArticleContextHeader title={contentTitle} summary={contentDescription} />
  <div class="min-h-screen bg-linear-to-br from-base-100 to-base-200">
    <article class="reading-prose py-8 md:py-12">
      <main class="content-container">
        {tldr && (
          <div class="mb-8 border-l-4 border-warning-400 bg-warning-50 p-4">
            <p class="text-sm font-medium text-warning-800">TL;DR</p>
            <p class="text-warning-700">{tldr}</p>
          </div>
        )}
        <slot />
      </main>
    </article>
  </div>
</BaseLayout>
