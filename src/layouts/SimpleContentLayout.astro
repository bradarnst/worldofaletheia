---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import Footer from '@components/Footer.astro';

interface Props {
  content: any;
  title?: string;
  description?: string;
  children: any;
}

const { content, title, description, children } = Astro.props;

const data = content.data || content;
const contentTitle = title || data.title || content.title;
const contentDescription = description || data.description || data.excerpt || content.excerpt;
const tldr = data.tldr || content.tldr;
---

<BaseLayout title={contentTitle} description={contentDescription}>
  <GlobalNavigation />
  <div class="min-h-screen bg-linear-to-br from-base-100 to-base-200">
    <article class="prose prose-sm md:prose-base max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <header class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">{contentTitle}</h1>
        
        {contentDescription && <p class="text-lg text-gray-600 mb-6">{contentDescription}</p>}
        
        {tldr && (
          <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
            <p class="text-sm font-medium text-yellow-800">TL;DR</p>
            <p class="text-yellow-700">{tldr}</p>
          </div>
        )}
      </header>
      
      <main class="content-container">
        <slot />
      </main>
      
      <Footer>
        <span slot="left">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
      </Footer>
    </article>
  </div>
</BaseLayout>
