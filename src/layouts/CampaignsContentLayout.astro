---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import CampaignsContentHeader from '@components/CampaignsContentHeader.astro';

interface Props {
  content: any;
  title?: string;
  description?: string;
  robots?: string;
  showContextMetadata?: boolean;
  children: any;
}

const { content, title, description, robots, showContextMetadata = true } = Astro.props;

const data = content.data || content;
const contentTitle = title || data.title || content.title;
const contentExcerpt = data.summary || data.excerpt || content.excerpt;
const parentChain = showContextMetadata && Array.isArray(data.parentChain) ? data.parentChain : [];
const relationships = showContextMetadata && Array.isArray(data.relationships) ? data.relationships : [];
---

<BaseLayout title={contentTitle} description={description} robots={robots}>
  <GlobalNavigation />
  <CampaignsContentHeader
    title={contentTitle}
    authors={data.authors || content.authors}
    created={data.createdAt || content.createdAt}
    campaign={data.campaign || content.campaign}
    visibility={data.visibility || content.visibility}
    excerpt={contentExcerpt}
    tags={data.tags || content.tags}
    publication={data.publication || content.publication}
    contentState={data.contentState || content.contentState}
    audienceWarnings={data.audienceWarnings || content.audienceWarnings}
    type={data.type}
    parentChain={parentChain}
    relationships={relationships}
  />
  <div class="min-h-screen bg-base-100">
    <article class="reading-prose py-8 md:py-12">
      <main class="content-container">
        <slot />
      </main>
    </article>
  </div>
</BaseLayout>
