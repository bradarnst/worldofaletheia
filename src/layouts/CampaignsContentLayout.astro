---
import BaseLayout from './BaseLayout.astro';
import GlobalNavigation from '@components/GlobalNavigation.astro';
import CampaignsNav from '@components/CampaignsNav.astro';
import CampaignsContentHeader from '@components/CampaignsContentHeader.astro';

interface Props {
  content: any;
  title?: string;
  description?: string;
  robots?: string;
  children: any;
}

const { content, title, description, robots } = Astro.props;

const data = content.data || content;
const contentTitle = title || data.title || content.title;
const contentExcerpt = data.summary || data.excerpt || content.excerpt;
---

<BaseLayout title={contentTitle} description={description} robots={robots}>
  <GlobalNavigation />
  <CampaignsNav />
  <CampaignsContentHeader
    title={contentTitle}
    author={data.author || content.author}
    created={data.created || content.created}
    campaign={data.campaign || content.campaign}
    visibility={data.visibility || content.visibility}
    excerpt={contentExcerpt}
    tags={data.tags || content.tags}
    type={data.type}
  />
  <div class="min-h-screen bg-base-100">
    <article class="reading-prose py-8 md:py-12">
      <main class="content-container">
        <slot />
      </main>
    </article>
  </div>
</BaseLayout>
