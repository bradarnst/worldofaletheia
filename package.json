{
  "name": "",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:fast": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "dev:cf:build": "astro build",
    "dev:cf": "wrangler dev ./dist/server/entry.mjs --config ./dist/server/wrangler.json --local",
    "dev:cf:auth": "pnpm dev:cf:build && pnpm db:migrate:local && pnpm db:migrate:auth:local && pnpm db:migrate:email-hardening:local && pnpm db:seed:memberships:local && pnpm dev:cf",
    "astro": "astro",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 execute DB --local --file ./migrations/0001_campaign_memberships.sql",
    "db:migrate:memberships:staging": "wrangler d1 execute DB --remote --env staging --file ./migrations/0001_campaign_memberships.sql",
    "db:migrate:memberships:prod": "wrangler d1 execute DB --remote --file ./migrations/0001_campaign_memberships.sql",
    "db:migrate:gm:local": "wrangler d1 execute DB --local --file ./migrations/0002_campaign_gm_assignments.sql",
    "db:migrate:gm:staging": "wrangler d1 execute DB --remote --env staging --file ./migrations/0002_campaign_gm_assignments.sql",
    "db:migrate:gm:prod": "wrangler d1 execute DB --remote --file ./migrations/0002_campaign_gm_assignments.sql",
    "db:migrate:auth:local": "wrangler d1 execute DB --local --file ./migrations/0003_auth_core.sql",
    "db:migrate:auth:staging": "wrangler d1 execute DB --remote --env staging --file ./migrations/0003_auth_core.sql",
    "db:migrate:auth:prod": "wrangler d1 execute DB --remote --file ./migrations/0003_auth_core.sql",
    "db:migrate:email-hardening:local": "wrangler d1 execute DB --local --file ./migrations/0004_auth_email_hardening.sql",
    "db:migrate:email-hardening:staging": "wrangler d1 execute DB --remote --env staging --file ./migrations/0004_auth_email_hardening.sql",
    "db:migrate:email-hardening:prod": "wrangler d1 execute DB --remote --file ./migrations/0004_auth_email_hardening.sql",
    "db:seed:memberships:local": "mkdir -p ./.wrangler && node ./scripts/seed-campaign-memberships.mjs > ./.wrangler/campaign-memberships.seed.sql && wrangler d1 execute DB --local --file ./.wrangler/campaign-memberships.seed.sql",
    "ops:a2:preflight:staging": "wrangler d1 execute DB --remote --env staging --file ./scripts/operator-sql/preflight.sql",
    "ops:a2:preflight:prod": "wrangler d1 execute DB --remote --file ./scripts/operator-sql/preflight.sql",
    "ops:a2:verify:staging": "wrangler d1 execute DB --remote --env staging --file ./scripts/operator-sql/verify.sql",
    "ops:a2:verify:prod": "wrangler d1 execute DB --remote --file ./scripts/operator-sql/verify.sql",
    "ops:a2:audit:staging": "wrangler d1 execute DB --remote --env staging --file ./scripts/operator-sql/audit.sql",
    "ops:a2:audit:prod": "wrangler d1 execute DB --remote --file ./scripts/operator-sql/audit.sql",
    "ops:a2:resolve:staging": "test -n \"$OP_FILE\" && wrangler d1 execute DB --remote --env staging --file \"$OP_FILE\" || (echo 'Set OP_FILE=./scripts/operator-sql/identity-resolution.sql (copied/edited)' && exit 1)",
    "ops:a2:resolve:prod": "test -n \"$OP_FILE\" && wrangler d1 execute DB --remote --file \"$OP_FILE\" || (echo 'Set OP_FILE=./scripts/operator-sql/identity-resolution.sql (copied/edited)' && exit 1)",
    "ops:a2:apply:staging": "test -n \"$OP_FILE\" && wrangler d1 execute DB --remote --env staging --file \"$OP_FILE\" || (echo 'Set OP_FILE=./path/to/operator.sql' && exit 1)",
    "ops:a2:apply:prod": "test -n \"$OP_FILE\" && wrangler d1 execute DB --remote --file \"$OP_FILE\" || (echo 'Set OP_FILE=./path/to/operator.sql' && exit 1)",
    "content:sync": "node ./scripts/content-sync/index.mjs",
    "content:sync:dry-run": "node ./scripts/content-sync/index.mjs --dry-run",
    "content:validate": "node ./scripts/content-sync/index.mjs --validate-only"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.0.0-beta.8",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/vite": "^4.2.0",
    "astro": "6.0.0-beta.14",
    "astro-seo": "^1.1.0",
    "better-auth": "^1.5.3",
    "fuse.js": "^7.1.0",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "daisyui": "^5.5.19",
    "miniflare": "4.20260219.0",
    "sharp": "^0.34.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
