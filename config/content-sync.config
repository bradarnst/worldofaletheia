{
  "vaultRoot": "/home/brad/gaming/aletheia-vault",
  "mappings": [
    { "from": "lore", "to": "src/content/lore" },
    { "from": "places", "to": "src/content/places" },
    { "from": "sentients", "to": "src/content/sentients" },
    { "from": "factions", "to": "src/content/factions" },
    { "from": "flora", "to": "src/content/flora" },
    { "from": "bestiary", "to": "src/content/bestiary" },
    { "from": "systems", "to": "src/content/systems" },
    { "from": "campaigns", "to": "src/content/campaigns" },
    { "from": "meta", "to": "src/content/meta" },
    { "from": "assets/images", "to": "src/assets/images" },
    { "from": "assets/docs", "to": "src/assets/docs" }
  ],
  "includeExtensions": [".md", ".png", ".jpg", ".jpeg", ".webp", ".pdf"],
  "backupRoot": ".content-sync-backups",
  "staleFilePolicy": "prompt",
  "defaultCommitMessage": "chore(content): sync Obsidian content",
  "requireCleanWorkingTreeBeforePull": false
}
